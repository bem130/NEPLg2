//: string: alloc/string.nepl に関する機能を提供するライブラリ
//:
//: [目的/もくてき]:
//: - このモジュールの公開 API を提供します。
//: - 実装の変更時に最小限の doctest 実行経路を維持します。
//:
//: [注意/ちゅうい]:
//: - 利用時は各関数の「目的」「注意」「計算量」を確認してください。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| fn main <()*>i32> ():
//:     ()
//:     0
//: ```

#indent 4

#import "core/mem" as *
#import "core/result" as *
#import "core/option" as *
#import "core/math" as *
#import "core/cast" as *
#import "alloc/collections/vec" as v
#import "core/field" as *

// string: 文字列操作（長さ付きUTF-8）
//
// 目的:
// - [len:i32][bytes...] 形式の UTF-8 文字列を扱う関数群を提供します。
//
// 実装(アルゴリズム):
// - 文字列はヒープに確保し、先頭 4 バイトに長さを格納します。
//
// 注意(重要):
// - 文字列は NUL 終端ではありません。
// - 変換関数は i32/i64/f32/f64 の主要経路を提供します。
//
// 計算量:
// - 連結や変換は O(n)

//: string_alloc_region: 文字列用の領域を確保する
//:
//: [目的/もくてき]:
//: - 先頭 4 バイトの長さヘッダを含む文字列領域を確保します。
//:
//: [実装/じっそう]:
//: - `alloc_region_bytes<u8>` に `4 + byte_len` を渡し、文字列レイアウト専用の `RegionToken<u8>` を返します。
//:
//: [注意/ちゅうい]:
//: - `byte_len` は文字列本文のバイト数です。
//: - 失敗時は `Result::Err` を返します。
//:
//: [計算量/けいさんりょう]:
//: - 確保器に依存します。平均 O(1)、free list 探索時は最悪 O(n) です。
fn string_alloc_region <(i32)->Result<RegionToken<u8>,str>> (byte_len):
    if:
        lt byte_len 0
        then:
            Result<RegionToken<u8>,str>::Err "string.alloc invalid length"
        else:
            alloc_region_bytes<u8> add 4 byte_len

//: string_region_len_ptr: 文字列領域ヘッダへの型付きポインタを得る
//:
//: [目的/もくてき]:
//: - 文字列領域の長さヘッダを `MemPtr<i32>` として扱えるようにします。
//:
//: [実装/じっそう]:
//: - `region_ptr_at<u8,i32> region 0` を利用します。
//:
//: [注意/ちゅうい]:
//: - 文字列領域レイアウトを前提とする内部ヘルパです。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn string_region_len_ptr <(RegionToken<u8>)->MemPtr<i32>> (region):
    unwrap_ok region_ptr_at<u8,i32> region 0

//: string_region_data_ptr: 文字列本文先頭への型付きポインタを得る
//:
//: [目的/もくてき]:
//: - 文字列本文の 1 バイト目を `MemPtr<u8>` として扱えるようにします。
//:
//: [実装/じっそう]:
//: - `region_ptr_at<u8,u8> region 4` を利用します。
//:
//: [注意/ちゅうい]:
//: - 先頭 4 バイトが長さヘッダであることを前提にしています。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn string_region_data_ptr <(RegionToken<u8>)->MemPtr<u8>> (region):
    unwrap_ok region_ptr_at<u8,u8> region 4

//: string_data_ptr: 既存文字列の本文先頭を型付きポインタとして扱う
//:
//: [目的/もくてき]:
//: - `str` の内部表現を直接露出せずに、本文領域へアクセスします。
//:
//: [実装/じっそう]:
//: - 長さヘッダの直後を `MemPtr<u8>` として包みます。
//:
//: [注意/ちゅうい]:
//: - 既存の `str` 表現に依存する内部ヘルパです。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn string_data_ptr <(str)->MemPtr<u8>> (s):
    mem_ptr_wrap add s 4

//: string_finish: 文字列領域を `str` として確定する
//:
//: [目的/もくてき]:
//: - 文字列領域へ長さを書き込み、公開型 `str` に変換します。
//:
//: [実装/じっそう]:
//: - ヘッダへ長さを書き込み、領域先頭アドレスを返します。
//:
//: [注意/ちゅうい]:
//: - 確定後は領域の所有権を `str` 側へ移します。
//: - 書き込み不能な領域は内部不整合として `unreachable` 扱いです。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn string_finish <(RegionToken<u8>,i32)->str> (region, byte_len):
    let base <MemPtr<u8>> get region "ptr"
    let len_ptr <MemPtr<i32>> mem_ptr_wrap mem_ptr_addr base
    match store_i32 len_ptr byte_len:
        Result::Ok _:
            mem_ptr_addr base
        Result::Err _e:
            #intrinsic "unreachable" <> ()

// len: 文字列の長さを返す
//
// 目的:
// - 文字列のバイト長を返します。
//
// 実装(アルゴリズム):
// - 先頭 4 バイトの長さを読み出します。
//
// 注意(重要):
// - UTF-8 のバイト長であり、文字数とは一致しません。
//
// 計算量:
// - O(1)
//: len: 主な用途
//:
//: [目的/もくてき]:
//: - len の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn len <(str)->i32> (s):
    load_i32 s

// concat: 2つの文字列を連結する
//
// 目的:
// - a と b を連結した新しい文字列を返します。
//
// 実装(アルゴリズム):
// - 長さを計算し、新領域を確保して順にコピーします。
//
// 注意(重要):
// - 新しいバッファを確保するため O(n) のコストがかかります。
//
// 計算量:
// - O(la + lb)
//: concat: 主な用途
//:
//: [目的/もくてき]:
//: - concat の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn concat <(str,str)->str> (a,b):
    let la <i32> load_i32 a;
    let lb <i32> load_i32 b;
    let total <i32> add la lb;
    let out_region <RegionToken<u8>> unwrap_ok string_alloc_region total;
    let out_data <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr get out_region "ptr" 4;
    let a_data <MemPtr<u8>> string_data_ptr a;
    let b_data <MemPtr<u8>> string_data_ptr b;
    let mut i <i32> 0;
    while lt i la:
        do:
            let ch <i32> unwrap load_u8 mem_ptr_add a_data i;
            match store_u8 mem_ptr_add out_data i ch:
                Result::Ok _:
                    ()
                Result::Err _e:
                    #intrinsic "unreachable" <> ()
            set i <i32> add i 1;
    let mut j <i32> 0;
    while lt j lb:
        do:
            let ch <i32> unwrap load_u8 mem_ptr_add b_data j;
            let dst <i32> add la j;
            match store_u8 mem_ptr_add out_data dst ch:
                Result::Ok _:
                    ()
                Result::Err _e:
                    #intrinsic "unreachable" <> ()
            set j <i32> add j 1;
    string_finish out_region total

// concat3: 3つの文字列を連結する
//
// 目的:
// - a,b,c を連結した文字列を返します。
//
// 実装(アルゴリズム):
// - concat を 2 回呼び出します。
//
// 注意(重要):
// - 中間文字列を確保するため余分なコストが発生します。
//
// 計算量:
// - O(la + lb + lc)
//: concat3: 主な用途
//:
//: [目的/もくてき]:
//: - concat3 の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn concat3 <(str,str,str)->str> (a,b,c):
    let ab <str> concat a b;
    concat ab c

// StringBuilder: 文字列ビルダ
//
// 目的:
// - 複数の文字列を段階的に追加し、最後に 1 つへまとめます。
//
// 実装(アルゴリズム):
// - Vec<str> に部分文字列を保持します。
//
// 注意(重要):
// - sb_build は concat を繰り返すため O(n^2) になり得ます。
//
// 計算量:
// - 追加: ならし O(1)
// - build: O(n^2)
//: StringBuilder: 構造体の概要
//:
//: [目的/もくてき]:
//: - StringBuilder の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 定義そのものは O(1) です。
struct StringBuilder:
    parts <Vec<str>>

// string_builder_new: 空のビルダを作る
//
// 目的:
// - 空の StringBuilder を返します。
//
// 実装(アルゴリズム):
// - `v::new` で `Vec<str>` を作ります。
//
// 注意(重要):
// - 初期容量は Vec の既定値に従います。
//
// 計算量:
// - O(1)
//: string_builder_new: 主な用途
//:
//: [目的/もくてき]:
//: - string_builder_new の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn string_builder_new <()->StringBuilder> ():
    StringBuilder unwrap_ok v::new<str>

// sb_append: 文字列を追加する
//
// 目的:
// - s をビルダに追加して返します。
//
// 実装(アルゴリズム):
// - 内部 Vec に push します。
//
// 注意(重要):
// - 返り値の StringBuilder を受け取り直してください。
//
// 計算量:
// - ならし O(1)
//: sb_append: 主な用途
//:
//: [目的/もくてき]:
//: - sb_append の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn sb_append <(StringBuilder,str)->StringBuilder> (sb, s):
    get sb "parts"
    |> v::push<str> s
    |> unwrap_ok
    |> StringBuilder

// sb_append_i32: i32 を追加する
//
// 目的:
// - v を文字列化して追加します。
//
// 実装(アルゴリズム):
// - from_i32 を呼び、sb_append に渡します。
//
// 注意(重要):
// - 負数は from_i32 の制約に従います。
//
// 計算量:
// - O(d)
//: sb_append_i32: 主な用途
//:
//: [目的/もくてき]:
//: - sb_append_i32 の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn sb_append_i32 <(StringBuilder,i32)->StringBuilder> (sb, v):
    sb
    |> sb_append from_i32 v

// sb_build: 文字列を生成する
//
// 目的:
// - 追加された部分文字列を 1 つに連結して返します。
//
// 実装(アルゴリズム):
// - まず全パーツ長を合計して 1 回だけ領域を確保します。
// - 次に各パーツのバイト列を確保済み領域へ順にコピーします。
//
// 注意(重要):
// - 返り値は新規確保された文字列です。
//
// 計算量:
// - O(total_bytes + part_count)
//: sb_build: 主な用途
//:
//: [目的/もくてき]:
//: - sb_build の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn sb_build <(StringBuilder)->str> (sb):
    let parts_vec <Vec<str>> get sb "parts";
    let n <i32> get parts_vec "len";
    let parts_data <i32> mem_ptr_addr get parts_vec "data";
    let mut total <i32> 0;
    let mut idx0 <i32> 0;
    while lt idx0 n:
        do:
            let part <str> load<str> add parts_data mul idx0 size_of<str>;
            set total add total load_i32 part;
            set idx0 add idx0 1;
    let out_region <RegionToken<u8>> unwrap_ok string_alloc_region total;
    let out_data <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr get out_region "ptr" 4;
    let mut idx <i32> 0;
    let mut dst <i32> 0;
    while lt idx n:
        do:
            let part <str> load<str> add parts_data mul idx size_of<str>;
            let plen <i32> load_i32 part;
            let part_data <MemPtr<u8>> string_data_ptr part;
            let mut i <i32> 0;
            while lt i plen:
                do:
                    let ch <i32> unwrap load_u8 mem_ptr_add part_data i;
                    let wr_off <i32> add dst i;
                    match store_u8 mem_ptr_add out_data wr_off ch:
                        Result::Ok _:
                            ()
                        Result::Err _e:
                            #intrinsic "unreachable" <> ()
                    set i add i 1;
            set dst add dst plen;
            set idx add idx 1;
    string_finish out_region total

// str_eq: 文字列が等しいか判定する
//
// 目的:
// - a と b の内容が同じなら true を返します。
//
// 実装(アルゴリズム):
// - 長さが一致する場合のみ、バイト単位で比較します。
//
// 注意(重要):
// - 大文字小文字などの正規化は行いません。
//
// 計算量:
// - O(n)
//: str_eq: 主な用途
//:
//: [目的/もくてき]:
//: - str_eq の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_eq <(str,str)->bool> (a,b):
    let la <i32> load_i32 a;
    let lb <i32> load_i32 b;
    if:
        eq la lb
        then str_eq_loop a b la 0
        else false

// str_eq_loop: 文字列比較の内部ループ
//
// 目的:
// - 先頭から len までを比較します。
//
// 実装(アルゴリズム):
// - インデックス i を進めながら 1 バイトずつ比較します。
//
// 注意(重要):
// - 呼び出し側で長さ一致を確認している前提です。
//
// 計算量:
// - O(n)
//: str_eq_loop: 主な用途
//:
//: [目的/もくてき]:
//: - str_eq_loop の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_eq_loop <(str,str,i32,i32)->bool> (a,b,n,i):
    if:
        eq i n
        then:
            true
        else:
            let ba <i32> load_u8 <i32> add a <i32> add 4 i;
            let bb <i32> load_u8 <i32> add b <i32> add 4 i;
            if:
                eq ba bb
                then str_eq_loop a b n <i32> add i 1
                else false

// str_is_space: ASCII 空白文字か判定する
//
// 目的:
// - 空白文字（スペース/タブ/改行/CR）かどうかを返します。
//
// 実装(アルゴリズム):
// - 候補バイト値を if で順に比較します。
//
// 注意(重要):
// - UTF-8 の空白全般は扱いません（ASCII のみ）。
//
// 計算量:
// - O(1)
//: str_is_space: 主な用途
//:
//: [目的/もくてき]:
//: - str_is_space の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_is_space <(i32)->bool> (b):
    if:
        eq b 32
        then true
        else:
            if:
                eq b 9
                then true
                else:
                    if:
                        eq b 10
                        then true
                        else:
                            if:
                                eq b 13
                                then true
                                else false

// str_starts_with: 先頭一致を判定する
//
// 目的:
// - s が prefix で始まるなら true を返します。
//
// 実装(アルゴリズム):
// - prefix の長さを確認し、前方 len バイトを比較します。
//
// 注意(重要):
// - UTF-8 のバイト列として比較します。
//
// 計算量:
// - O(n)
//: str_starts_with: 主な用途
//:
//: [目的/もくてき]:
//: - str_starts_with の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_starts_with <(str,str)->bool> (s, prefix):
    let ls <i32> load_i32 s;
    let lp <i32> load_i32 prefix;
    if:
        lt ls lp
        then false
        else str_eq_loop s prefix lp 0

// str_eq_at: 指定位置からの一致判定
//
// 目的:
// - s の start 位置から len バイトが pat と一致するか返します。
//
// 実装(アルゴリズム):
// - インデックスを進めながら 1 バイトずつ比較します。
//
// 注意(重要):
// - 呼び出し側で範囲内であることを保証してください。
//
// 計算量:
// - O(n)
//: str_eq_at: 主な用途
//:
//: [目的/もくてき]:
//: - str_eq_at の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_eq_at <(str,str,i32,i32,i32)->bool> (s, pat, start, n, i):
    if:
        eq i n
        then true
        else:
            let s_ptr <i32> add s 4;
            let s_off <i32> add start i;
            let bs <i32> load_u8 <i32> add s_ptr s_off;
            let bp <i32> load_u8 <i32> add pat <i32> add 4 i;
            if:
                eq bs bp
                then str_eq_at s pat start n <i32> add i 1
                else false

// str_ends_with: 末尾一致を判定する
//
// 目的:
// - s が suffix で終わるなら true を返します。
//
// 実装(アルゴリズム):
// - s の末尾から長さ分を比較します。
//
// 注意(重要):
// - UTF-8 のバイト列として比較します。
//
// 計算量:
// - O(n)
//: str_ends_with: 主な用途
//:
//: [目的/もくてき]:
//: - str_ends_with の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_ends_with <(str,str)->bool> (s, suffix):
    let ls <i32> load_i32 s;
    let lp <i32> load_i32 suffix;
    if:
        lt ls lp
        then false
        else:
            let start <i32> sub ls lp;
            str_eq_at s suffix start lp 0

// str_slice: 部分文字列を切り出す
//
// 目的:
// - [start, end) の範囲を新しい文字列として返します。
//
// 実装(アルゴリズム):
// - start/end を範囲内に収め、該当バイトをコピーします。
//
// 注意(重要):
// - start/end はバイト位置です（UTF-8 の文字境界は考慮しません）。
// - 範囲外は 0..len に丸めます。
//
// 計算量:
// - O(n)
//: str_slice: 主な用途
//:
//: [目的/もくてき]:
//: - str_slice の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_slice <(str,i32,i32)->str> (s, start, end):
    let len <i32> load_i32 s;
    let mut s0 <i32> start;
    let mut e0 <i32> end;
    if:
        lt s0 0
        then set s0 0
        else ()
    if:
        lt e0 s0
        then set e0 s0
        else ()
    if:
        lt len e0
        then set e0 len
        else ()
    let out_len <i32> sub e0 s0;
    let out_region <RegionToken<u8>> unwrap_ok string_alloc_region out_len;
    let out_data <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr get out_region "ptr" 4;
    let s_data <MemPtr<u8>> string_data_ptr s;
    let mut i <i32> 0;
    while lt i out_len:
        do:
            let rd_off <i32> add s0 i;
            let b <i32> unwrap load_u8 mem_ptr_add s_data rd_off;
            match store_u8 mem_ptr_add out_data i b:
                Result::Ok _:
                    ()
                Result::Err _e:
                    #intrinsic "unreachable" <> ()
            set i <i32> add i 1;
    string_finish out_region out_len

// str_trim: 前後の空白を取り除く
//
// 目的:
// - 先頭と末尾の ASCII 空白を除去した文字列を返します。
//
// 実装(アルゴリズム):
// - 先頭から空白を飛ばし、末尾から空白を削ります。
// - 最後に str_slice で切り出します。
//
// 注意(重要):
// - 空白判定は ASCII のみです。
// - UTF-8 の文字境界は考慮しません。
//
// 計算量:
// - O(n)
//: str_trim: 主な用途
//:
//: [目的/もくてき]:
//: - str_trim の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_trim <(str)->str> (s):
    let len <i32> load_i32 s;
    let mut start <i32> 0;
    let mut end <i32> len;
    let mut done <i32> 0;
    while eq done 0:
        do:
            if:
                lt start end
                then:
                    let b <i32> load_u8 <i32> add s <i32> add 4 start;
                    if:
                        str_is_space b
                        then set start <i32> add start 1
                        else set done 1
                else:
                    set done 1
    let mut done2 <i32> 0;
    while eq done2 0:
        do:
            if:
                lt start end
                then:
                    let idx <i32> sub end 1;
                    let b <i32> load_u8 <i32> add s <i32> add 4 idx;
                    if:
                        str_is_space b
                        then set end <i32> sub end 1
                        else set done2 1
                else:
                    set done2 1
    str_slice s start end

// str_match_at: 位置一致を判定する（split 用）
//
// 目的:
// - s の pos から sep が一致するかを返します。
//
// 実装(アルゴリズム):
// - sep_len 文字分を順に比較します。
//
// 注意(重要):
// - 呼び出し側で pos+sep_len が範囲内であることを保証してください。
//
// 計算量:
// - O(n)
//: str_match_at: 主な用途
//:
//: [目的/もくてき]:
//: - str_match_at の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_match_at <(str,str,i32,i32)->bool> (s, sep, pos, sep_len):
    let mut i <i32> 0;
    let mut ok <i32> 1;
    while lt i sep_len:
        do:
            let s_ptr <i32> add s 4;
            let rd_off <i32> add pos i;
            let bs <i32> load_u8 <i32> add s_ptr rd_off;
            let bp <i32> load_u8 <i32> add sep <i32> add 4 i;
            if:
                eq bs bp
                then set i <i32> add i 1
                else:
                    set ok 0
                    set i sep_len
    eq ok 1

// str_split: 区切り文字で分割する
//
// 目的:
// - s を sep で分割し、部分文字列の Vec を返します。
//
// 実装(アルゴリズム):
// - 走査しながら sep 一致位置で区切り、str_slice を積み上げます。
//
// 注意(重要):
// - sep が空文字列の場合は s だけを返します。
// - UTF-8 の文字境界は考慮しません。
//
// 計算量:
// - O(n * m)（n=文字列長, m=sep長）
//: str_split: 主な用途
//:
//: [目的/もくてき]:
//: - str_split の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn str_split <(str,str)->Vec<str>> (s, sep):
    let sep_len <i32> load_i32 sep;
    let mut out <Vec<str>> unwrap_ok v::new<str>;
    if:
        eq sep_len 0
        then:
            set out unwrap_ok v::push<str> out s
            out
        else:
            let s_len <i32> load_i32 s;
            let mut i <i32> 0;
            let mut start <i32> 0;
            let mut scan_end <i32> add i sep_len;
            while le <i32> scan_end s_len:
                do:
                    if:
                        str_match_at s sep i sep_len
                        then:
                            let part <str> str_slice s start i;
                            set out unwrap_ok v::push<str> out part;
                            set i <i32> add i sep_len;
                            set start i;
                            set scan_end <i32> add i sep_len;
                        else:
                            set i <i32> add i 1;
                            set scan_end <i32> add i sep_len;
            let tail <str> str_slice s start s_len;
            set out unwrap_ok v::push<str> out tail;
            out

// from_bool: bool を文字列へ変換する
//
// 目的:
// - bool を "true" または "false" の文字列へ変換します。
// - 診断文やテスト失敗メッセージで、論理値をそのまま表示したい時に使います。
//
// 実装(アルゴリズム):
// - `if` で分岐し、あらかじめ用意された定数文字列を返します。
//
// 注意(重要):
// - 返す文字列はヒープ確保を伴わない定数文字列です。
// - 数値変換ではなく表示用の文字列表現です。
//
// 計算量:
// - O(1)
//: from_bool: 主な用途
//:
//: [目的/もくてき]:
//: - bool を人間向けの文字列へ変換する使い方を示します。
//:
//: [実装/じっそう]:
//: - true と false を、それぞれ固定文字列へ直接対応付けます。
//:
//: [注意/ちゅうい]:
//: - 返値は表示や比較には使えますが、bool としては扱えません。
//:
//: [計算量/けいさんりょう]:
//: - 分岐 1 回だけなので O(1) です。
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/string" as *
//:| #import "core/math" as *
//: fn main <()*>i32> ():
//:     let ok0 <bool> eq from_bool true "true";
//:     let ok1 <bool> eq from_bool false "false";
//:     let ok <bool> and ok0 ok1;
//:     if ok 1 0
//: ```
fn from_bool <(bool)->str> (b):
    if:
        b
        then:
            "true"
        else:
            "false"

// to_bool: 文字列を bool に変換する
//
// 目的:
// - `"true"` または `"false"` の文字列を `bool` として読み取ります。
// - 設定値や CLI 引数、テスト入力などで論理値を文字列から受け取る時に使います。
//
// 実装(アルゴリズム):
// - 先に `str_eq` で `"true"` と一致するかを確認します。
// - 続いて `"false"` と一致するかを確認し、どちらでもなければ `Err` を返します。
//
// 注意(重要):
// - 受理する表記は小文字の `"true"` / `"false"` のみです。
// - `"True"` や `"0"` / `"1"` は bool として扱いません。
// - 解析失敗は `Result::Err 1` で返します。
//
// 計算量:
// - O(n)  (n は入力文字列長)
//:
//: to_bool: 主な用途
//:
//: [目的/もくてき]:
//: - 文字列入力から bool を安全に読む使い方を示します。
//:
//: [実装/じっそう]:
//: - 固定文字列 `"true"` / `"false"` との比較で判定します。
//:
//: [注意/ちゅうい]:
//: - 大文字小文字は区別します。
//:
//: [計算量/けいさんりょう]:
//: - 比較は文字列長に比例するため O(n) です。
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/test" as *
//:| #import "core/result" as *
//:| #import "alloc/string" as *
//: fn main <()*>()> ():
//:     match to_bool "true":
//:         Result::Ok v:
//:             assert_eq_i32 1 cast v;
//:         Result::Err _:
//:             assert_eq_i32 1 0;
//:     match to_bool "false":
//:         Result::Ok v:
//:             assert_eq_i32 0 cast v;
//:         Result::Err _:
//:             assert_eq_i32 1 0;
//: ```
fn to_bool <(str)->Result<bool,i32>> (s):
    if:
        str_eq s "true"
        then:
            Result::Ok<bool,i32> true
        else:
            if:
                str_eq s "false"
                then:
                    Result::Ok<bool,i32> false
                else:
                    Result::Err<bool,i32> 1

// digit_to_char_lower: 0..15 の数値を小文字 16 進数字へ変換する
//
// 目的:
// - 基数変換で得た 1 桁分の値を、`0-9` または `a-f` の 1 文字へ変換します。
//
// 実装(アルゴリズム):
// - `v < 10` のときは `'0' + v` を返します。
// - それ以外は `'a' + (v - 10)` を返します。
//
// 注意(重要):
// - 呼び出し側は `0 <= v < 16` を満たす値だけを渡す必要があります。
// - 16 以上の値を渡した場合の挙動は未定義です。
//
// 計算量:
// - O(1)
fn digit_to_char_lower <(i32)->i32> (v):
    if:
        lt v 10
        then:
            add 48 v
        else:
            add 87 v

// digit_from_char: 1 文字を数値へ変換する
//
// 目的:
// - `0-9`、`a-f`、`A-F` を数値 0..15 へ変換します。
// - 基数付きの文字列解析で各文字の意味を判定する時に使います。
//
// 実装(アルゴリズム):
// - ASCII 範囲を順に判定し、対応する値へ写像します。
// - 数字でも英字でもない場合は `Result::Err 1` を返します。
//
// 注意(重要):
// - 返る値が基数未満かどうかの判定は、この関数ではなく呼び出し側が行います。
// - 英字は大小どちらも受理します。
//
// 計算量:
// - O(1)
fn digit_from_char <(i32)->Result<i32,i32>> (ch):
    if:
        and ge ch 48 le ch 57
        then:
            Result::Ok<i32,i32> sub ch 48
        else:
            if:
                and ge ch 97 le ch 102
                then:
                    Result::Ok<i32,i32> add 10 sub ch 97
                else:
                    if:
                        and ge ch 65 le ch 70
                        then:
                            Result::Ok<i32,i32> add 10 sub ch 65
                        else:
                            Result::Err<i32,i32> 1

// validate_radix: 文字列変換で使える基数かを判定する
//
// 目的:
// - 2 / 8 / 10 / 16 のみを受理し、それ以外の基数を早期に弾きます。
//
// 実装(アルゴリズム):
// - 許可された 4 値との等値比較だけで判定します。
//
// 注意(重要):
// - 現在の文字列変換 API は NEPLg2 の標準的な整数リテラル系に合わせ、2 / 8 / 10 / 16 に限定します。
// - それ以外の基数を使いたい場合は、この関数と対応する doctest を拡張してください。
//
// 計算量:
// - O(1)
fn validate_radix <(i32)->Result<i32,i32>> (radix):
    if:
        or or eq radix 2 eq radix 8 or eq radix 10 eq radix 16
        then:
            Result::Ok<i32,i32> radix
        else:
            Result::Err<i32,i32> 1

//: U128DivRem: u128 の小基数除算の結果
struct U128DivRem:
    quotient <u128>
    remainder <i32>

// u128_zero: 0 の u128 値を返す
//
// 目的:
// - u128 補助関数群で共通して使う 0 値を作ります。
//
// 実装(アルゴリズム):
// - hi / lo の両方を 0 にした `u128` を直接構築します。
//
// 注意(重要):
// - これは補助関数であり、公開 API の型変換ではありません。
//
// 計算量:
// - O(1)
fn u128_zero <()->u128> ():
    u128 <i64> cast 0 <i64> cast 0

// u128_is_zero: u128 が 0 かを判定する
//
// 目的:
// - 桁生成や解析で `u128` の終了条件を判定します。
//
// 実装(アルゴリズム):
// - hi / lo の両方が 0 かを確認します。
//
// 注意(重要):
// - `u128` は `i64` 2 ワード表現なので、単純なフィールド比較で判定できます。
//
// 計算量:
// - O(1)
fn u128_is_zero <(u128)->bool> (v):
    and eq get v "hi" <i64> cast 0 eq get v "lo" <i64> cast 0

// u128_from_i128_bits: i128 のビット列をそのまま u128 として見る
//
// 目的:
// - 符号付き i128 の内部表現を、同じ 128-bit 幅の符号なし値として扱います。
//
// 実装(アルゴリズム):
// - hi / lo をそのまま `u128` へ詰め替えます。
//
// 注意(重要):
// - 数値変換ではなくビット列の再解釈です。
//
// 計算量:
// - O(1)
fn u128_from_i128_bits <(i128)->u128> (v):
    u128 get v "hi" get v "lo"

// i128_from_u128_bits: u128 のビット列をそのまま i128 として見る
//
// 目的:
// - 符号なし u128 の内部表現を、同じ 128-bit 幅の符号付き値として扱います。
//
// 実装(アルゴリズム):
// - hi / lo をそのまま `i128` へ詰め替えます。
//
// 注意(重要):
// - 数値変換ではなくビット列の再解釈です。
//
// 計算量:
// - O(1)
fn i128_from_u128_bits <(u128)->i128> (v):
    i128 get v "hi" get v "lo"

// i128_is_negative: i128 が負数かを判定する
//
// 目的:
// - 文字列表現で負号を付けるべきかを判定します。
//
// 実装(アルゴリズム):
// - 上位 64-bit の符号だけを見ます。
//
// 注意(重要):
// - `i128` は 2 の補数表現を前提にしています。
//
// 計算量:
// - O(1)
fn i128_is_negative <(i128)->bool> (v):
    lt get v "hi" <i64> cast 0

// i128_neg: i128 の符号を反転する
//
// 目的:
// - 符号付き文字列化で絶対値を求める前段として使います。
//
// 実装(アルゴリズム):
// - `0 - v` を `i128` 演算で行います。
//
// 注意(重要):
// - 最小値も 2 の補数 mod 2^128 で反転します。ビット列としてはそのまま絶対値の大きさに使えます。
//
// 計算量:
// - O(1)
fn i128_neg <(i128)->i128> (v):
    sub <i128> cast 0 v

// i128_abs_u128: i128 の絶対値を u128 として返す
//
// 目的:
// - 符号付き整数の文字列表現生成を、符号処理と magnitude 処理に分離します。
//
// 実装(アルゴリズム):
// - 非負ならそのまま、負なら `i128_neg` したビット列を `u128` として返します。
//
// 注意(重要):
// - `i128` 最小値でも `u128` の大きさとして正しく扱えます。
//
// 計算量:
// - O(1)
fn i128_abs_u128 <(i128)->u128> (v):
    if:
        i128_is_negative v
        then:
            u128_from_i128_bits i128_neg v
        else:
            u128_from_i128_bits v

// u128_get_bit: u128 の指定ビットを取り出す
//
// 目的:
// - 小基数除算の long division で、上位ビットから順に 1bit ずつ読むために使います。
//
// 実装(アルゴリズム):
// - idx が 64 以上か未満かで hi / lo を切り替え、右シフト後の最下位ビットを読みます。
//
// 注意(重要):
// - `0 <= idx < 128` を呼び出し側が守る前提です。
//
// 計算量:
// - O(1)
fn u128_get_bit <(u128,i32)->i32> (v, idx):
    if:
        ge idx 64
        then:
            let shifted <i64> shr_u get v "hi" <i64> cast sub idx 64;
            let bit64 <i64> and shifted <i64> cast 1;
            <i32> cast bit64
        else:
            let shifted <i64> shr_u get v "lo" <i64> cast idx;
            let bit64 <i64> and shifted <i64> cast 1;
            <i32> cast bit64

// u128_set_bit: u128 の指定ビットを 1 にする
//
// 目的:
// - 小基数除算で求めた商のビットを立てます。
//
// 実装(アルゴリズム):
// - idx に対応する mask を作り、hi または lo に `or` します。
//
// 注意(重要):
// - 既に 1 のビットを再度立てても問題ありません。
//
// 計算量:
// - O(1)
fn u128_set_bit <(u128,i32)->u128> (v, idx):
    if:
        ge idx 64
        then:
            let mask <i64> shl <i64> cast 1 <i64> cast sub idx 64;
            u128 or get v "hi" mask get v "lo"
        else:
            let mask <i64> shl <i64> cast 1 <i64> cast idx;
            u128 get v "hi" or get v "lo" mask

// u128_add_small: u128 に小さい非負整数を加える
//
// 目的:
// - 基数付き解析で `res = res * radix + digit` を構成する末尾加算に使います。
//
// 実装(アルゴリズム):
// - `digit` を `u128` に持ち上げて通常の `u128 add` に渡します。
//
// 注意(重要):
// - `digit` は 0..15 の範囲を前提にしています。
//
// 計算量:
// - O(1)
fn u128_add_small <(u128,i32)->u128> (v, digit):
    add v to_u128 <i64> cast digit

// u128_mul_small: u128 に小さい非負整数を掛ける
//
// 目的:
// - 文字列解析で基数倍を行うための補助です。
//
// 実装(アルゴリズム):
// - 二進法の繰り返し加算で `v * factor` を作ります。
// - factor は 2 / 8 / 10 / 16 のいずれかなので、回数は定数で抑えられます。
//
// 注意(重要):
// - オーバーフローは `u128` の mod 2^128 としてラップします。
//
// 計算量:
// - O(log factor) だが factor は固定小定数なので実質 O(1)
fn u128_mul_small <(u128,i32)->u128> (v, factor):
    let mut out <u128> u128_zero;
    let mut base <u128> v;
    let mut n <i32> factor;
    while gt n 0:
        do:
            if:
                ne and n 1 0
                then:
                    set out add out base;
                else:
                    ();
            set base add base base;
            set n shr_u n 1;
    out

// u128_divrem_small: u128 を小さい正基数で割った商と余りを返す
//
// 目的:
// - `u128` の文字列表現生成で、下位 1 桁ずつを取り出します。
//
// 実装(アルゴリズム):
// - 128bit の long division を上位ビットから順に行います。
// - 余りは `i32` に収まるので、各段階では `rem = rem * 2 + bit` を更新します。
//
// 注意(重要):
// - radix は 2 / 8 / 10 / 16 を前提にしています。
// - 商は `u128`、余りは 0..radix-1 の `i32` です。
//
// 計算量:
// - O(128) = O(1)
fn u128_divrem_small <(u128,i32)->U128DivRem> (v, radix):
    let mut q <u128> u128_zero;
    let mut rem <i32> 0;
    let mut idx <i32> 127;
    while ge idx 0:
        do:
            set rem add shl rem 1 u128_get_bit v idx;
            if:
                ge rem radix
                then:
                    set rem sub rem radix;
                    set q u128_set_bit q idx;
                else:
                    ();
            set idx sub idx 1;
    U128DivRem q rem

// from_i32: i32 を文字列へ変換する
//
// 目的:
// - i32 を符号付き 10 進文字列へ変換します。
// - 診断文やログで、負数を含む整数をそのまま表示したい時に使います。
//
// 実装(アルゴリズム):
// - まず i32 を i64 へ符号拡張し、その後 `from_i64` に委譲します。
// - 桁生成と負号処理を `from_i64` に集約し、整数文字列化の実装を一箇所に保ちます。
//
// 注意(重要):
// - `from_i32` 自身は薄いラッパで、実際の計算量とメモリ確保は `from_i64` に従います。
// - これは型変換ではなく文字列表現の生成なので、`cast` ではなく `alloc/string` に置いています。
//
// 計算量:
// - O(d)  (d は桁数)
//: from_i32: 主な用途
//:
//: [目的/もくてき]:
//: - 正数と負数の両方を 10 進文字列へ変換する例を示します。
//:
//: [実装/じっそう]:
//: - i64 共通実装へ渡すことで、符号と桁列の処理を重複させません。
//:
//: [注意/ちゅうい]:
//: - 返値は新しい文字列であり、桁数に応じた確保コストがあります。
//:
//: [計算量/けいさんりょう]:
//: - 桁数 d に対して O(d) です。
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/string" as *
//:| #import "core/math" as *
//: fn main <()*>i32> ():
//:     let ok0 <bool> eq from_i32 42 "42";
//:     let ok1 <bool> eq from_i32 -42 "-42";
//:     let ok <bool> and ok0 ok1;
//:     if ok 1 0
//: ```
fn from_i32 <(i32)->str> (x):
    match from_i32_radix x 10:
        Result::Ok s:
            s
        Result::Err _:
            "0"

// to_i32: 文字列を i32 に変換する
//
// 目的:
// - 10 進の符号付き文字列を i32 に変換します。
//
// 実装(アルゴリズム):
// - `to_i32_radix s 10` に委譲し、基数付き実装へ統一します。
//
// 注意(重要):
// - 負号は先頭 1 文字だけを受理します。
// - 現在はオーバーフロー検査を行っていないため、表現域外入力は `to_i32_radix` の仕様に従います。
//
// 計算量:
// - O(n)
//: to_i32: 主な用途
//:
//: [目的/もくてき]:
//: - to_i32 の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn to_i32 <(str)->Result<i32,i32>> (s):
    match to_i32_radix s 10:
        Result::Ok v:
            Result::Ok<i32,i32> v
        Result::Err e:
            Result::Err<i32,i32> e

// from_i32_radix: i32 を指定した基数の文字列へ変換する
//
// 目的:
// - i32 を 2 / 8 / 10 / 16 進の文字列へ変換します。
// - ログ、テスト、シリアライズで基数を明示した文字列表現が必要な場面に使います。
//
// 実装(アルゴリズム):
// - `i32` を `i64` に符号拡張してから `from_i64_radix` に委譲します。
// - 桁列生成の本体は i64 共通実装に集約します。
//
// 注意(重要):
// - 対応基数は 2 / 8 / 10 / 16 のみです。
// - 結果は小文字英字を使うため、16 進では `ff` のような表記になります。
//
// 計算量:
// - O(d)  (d は指定基数での桁数)
fn from_i32_radix <(i32,i32)->Result<str,i32>> (x, radix):
    from_i64_radix <i64> cast x radix

// to_i32_radix: 指定基数の文字列を i32 に変換する
//
// 目的:
// - 2 / 8 / 10 / 16 進で書かれた文字列を i32 に変換します。
// - 設定値やリテラル風入力を i32 として読み取りたい時に使います。
//
// 実装(アルゴリズム):
// - まず `to_i64_radix` で共通解析を行います。
// - その後、i32 の範囲に収まるかを確認してから縮小します。
//
// 注意(重要):
// - 接頭辞 `0x` や `0b` は解釈しません。文字列本体だけを渡してください。
// - 解析失敗と範囲外はどちらも `Result::Err` を返します。
//
// 計算量:
// - O(n)  (n は入力文字列長)
fn to_i32_radix <(str,i32)->Result<i32,i32>> (s, radix):
    match to_i64_radix s radix:
        Result::Ok v64:
            if:
                and ge v64 <i64> cast -2147483648 le v64 <i64> cast 2147483647
                then:
                    Result::Ok<i32,i32> <i32> cast v64
                else:
                    Result::Err<i32,i32> 1
        Result::Err e:
            Result::Err<i32,i32> e

//: from_i64: 主な用途
//:
//: [目的/もくてき]:
//: - `i64` を 10 進の符号付き文字列へ変換する基本例を示します。
//:
//: [実装/じっそう]:
//: - 本体は `from_i64_radix x 10` に委譲し、基数付き実装へ統一しています。
//:
//: [注意/ちゅうい]:
//: - 負数でも `-42` のような符号付き表記を返します。
//:
//: [計算量/けいさんりょう]:
//: - 桁数 `d` に対して O(d) です。
fn from_i64 <(i64)->str> (x):
    match from_i64_radix x 10:
        Result::Ok s:
            s
        Result::Err _:
            "0"

// from_i64_radix: i64 を指定した基数の文字列へ変換する
//
// 目的:
// - i64 を 2 / 8 / 10 / 16 進文字列へ変換します。
// - 整数の可視化や、基数を固定したテストデータ生成に使います。
//
// 実装(アルゴリズム):
// - `i64` を `i128` に持ち上げ、符号と magnitude の処理を `from_i128_radix` に統一します。
//
// 注意(重要):
// - すべての基数で負数は `-ff` のような符号付き文字列として返します。
// - 16 進の英字は小文字です。
// - 基数が不正な場合は `Result::Err 1` を返します。
//
// 計算量:
// - O(d)  (d は指定基数での桁数)
fn from_i64_radix <(i64,i32)->Result<str,i32>> (x, radix):
    from_i128_radix <i128> cast x radix

//: to_i64: 主な用途
//:
//: [目的/もくてき]:
//: - 10 進文字列を `i64` として読む基本例を示します。
//:
//: [実装/じっそう]:
//: - 本体は `to_i64_radix s 10` に委譲し、基数付き実装へ統一しています。
//:
//: [注意/ちゅうい]:
//: - 接頭辞は読まず、文字列本体だけを解析します。
//:
//: [計算量/けいさんりょう]:
//: - 入力長 `n` に対して O(n) です。
fn to_i64 <(str)->Result<i64,i32>> (s):
    to_i64_radix s 10

// to_i64_radix: 指定基数の文字列を i64 に変換する
//
// 目的:
// - 2 / 8 / 10 / 16 進文字列を i64 として解釈します。
// - 数値入力の解析や、基数別テストデータの読み戻しに使います。
//
// 実装(アルゴリズム):
// - `to_i128_radix` で共通解析を行い、最後に `i64` へ縮小します。
//
// 注意(重要):
// - 接頭辞 `0b` / `0o` / `0x` は解釈しません。
// - `-ff` のような符号付き文字列は、すべての対応基数で受理します。
// - 現在はオーバーフロー検査を行っていないため、表現域外入力は未定義です。
//
// 計算量:
// - O(n)  (n は入力文字列長)
fn to_i64_radix <(str,i32)->Result<i64,i32>> (s, radix):
    match to_i128_radix s radix:
        Result::Ok v128:
            Result::Ok<i64,i32> <i64> cast v128
        Result::Err e:
            Result::Err<i64,i32> e

// from_u128: u128 を 10 進文字列へ変換する
//
// 目的:
// - `u128` の大きな値を 10 進文字列として可視化します。
//
// 実装(アルゴリズム):
// - `from_u128_radix v 10` に委譲します。
//
// 注意(重要):
// - 返る文字列は常に非負で、負号は付きません。
//
// 計算量:
// - O(d)
fn from_u128 <(u128)->str> (v):
    match from_u128_radix v 10:
        Result::Ok s:
            s
        Result::Err _:
            "0"

// from_u128_radix: u128 を指定基数の文字列へ変換する
//
// 目的:
// - `u128` を 2 / 8 / 10 / 16 進文字列へ変換します。
//
// 実装(アルゴリズム):
// - 小さい基数での `u128_divrem_small` を繰り返し、下位桁から順に取り出します。
// - 取り出した桁は一時バッファに逆順で積み、最後に反転して確定文字列を作ります。
//
// 注意(重要):
// - 英字桁は小文字です。
// - 基数が不正な場合は `Result::Err 1` を返します。
//
// 計算量:
// - O(128 * d) だが 128 は固定幅なので、桁数 d に対して実質 O(d)
fn from_u128_radix <(u128,i32)->Result<str,i32>> (v, radix):
    match validate_radix radix:
        Result::Err e:
            Result::Err<str,i32> e
        Result::Ok _:
            if:
                u128_is_zero v
                then:
                    Result::Ok<str,i32> "0"
                else:
                    let scratch_region <RegionToken<u8>> unwrap_ok alloc_region_bytes<u8> 132;
                    let scratch <MemPtr<u8>> get scratch_region "ptr";
                    let mut idx <i32> 0;
                    let mut n <u128> v;
                    while not u128_is_zero n:
                        do:
                            let qr <U128DivRem> u128_divrem_small n radix;
                            match store_u8 mem_ptr_add scratch idx digit_to_char_lower get qr "remainder":
                                Result::Ok _:
                                    ()
                                Result::Err _e:
                                    #intrinsic "unreachable" <> ()
                            set idx add idx 1;
                            set n get qr "quotient";
                    let out_region <RegionToken<u8>> unwrap_ok string_alloc_region idx;
                    let out_data <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr get out_region "ptr" 4;
                    let mut i <i32> 0;
                    while lt i idx:
                        do:
                            let rev <i32> sub idx add i 1;
                            let ch <i32> unwrap load_u8 mem_ptr_add scratch rev;
                            match store_u8 mem_ptr_add out_data i ch:
                                Result::Ok _:
                                    ()
                                Result::Err _e:
                                    #intrinsic "unreachable" <> ()
                            set i add i 1;
                    match dealloc_region scratch_region:
                        Result::Ok _:
                            Result::Ok<str,i32> string_finish out_region idx
                        Result::Err _e:
                            #intrinsic "unreachable" <> ()

// to_u128: 10 進文字列を u128 に変換する
//
// 目的:
// - 大きな非負整数文字列を `u128` として読み取ります。
//
// 実装(アルゴリズム):
// - `to_u128_radix s 10` に委譲します。
//
// 注意(重要):
// - 負号は受理しません。
//
// 計算量:
// - O(n)
fn to_u128 <(str)->Result<u128,i32>> (s):
    to_u128_radix s 10

// to_u128_radix: 指定基数の文字列を u128 に変換する
//
// 目的:
// - 非負の 2 / 8 / 10 / 16 進文字列を `u128` に変換します。
//
// 実装(アルゴリズム):
// - 各文字を `digit_from_char` で数値化し、`res = res * radix + digit` を `u128_mul_small` と `u128_add_small` で構築します。
//
// 注意(重要):
// - 接頭辞 `0b` / `0o` / `0x` は解釈しません。
// - 負号付き文字列は `Result::Err 1` です。
// - 現在はオーバーフロー検査を行っていないため、表現域外入力は mod 2^128 でラップします。
//
// 計算量:
// - O(n)
fn to_u128_radix <(str,i32)->Result<u128,i32>> (s, radix):
    match validate_radix radix:
        Result::Err e:
            Result::Err<u128,i32> e
        Result::Ok _:
            let n <i32> load_i32 s;
            let mut i <i32> 0;
            let mut res <u128> u128_zero;
            let mut ok <i32> 1;
            if:
                eq n 0
                then:
                    set ok 0;
                else:
                    let first_ptr <i32> add s 4;
                    let first <i32> load_u8 first_ptr;
                    if:
                        eq first 45
                        then:
                            set ok 0;
                        else:
                            while lt i n:
                                do:
                                    let digit_off <i32> add 4 i;
                                    let digit_ptr <i32> add s digit_off;
                                    let digit_chr <i32> load_u8 digit_ptr;
                                    match digit_from_char digit_chr:
                                        Result::Ok digit:
                                            if:
                                                ge digit radix
                                                then:
                                                    set ok 0;
                                                    set i n;
                                                else:
                                                    set res u128_add_small u128_mul_small res radix digit;
                                                    set i add i 1;
                                        Result::Err _:
                                            set ok 0;
                                            set i n;
            if:
                eq ok 1
                then:
                    Result::Ok<u128,i32> res
                else:
                    Result::Err<u128,i32> 1

// from_i128: i128 を 10 進文字列へ変換する
//
// 目的:
// - `i128` を 10 進の符号付き文字列へ変換します。
//
// 実装(アルゴリズム):
// - `from_i128_radix v 10` に委譲します。
//
// 注意(重要):
// - 大きさの処理は `u128` の桁生成へ寄せています。
//
// 計算量:
// - O(d)
fn from_i128 <(i128)->str> (v):
    match from_i128_radix v 10:
        Result::Ok s:
            s
        Result::Err _:
            "0"

// from_i128_radix: i128 を指定基数の文字列へ変換する
//
// 目的:
// - `i128` を 2 / 8 / 10 / 16 進の符号付き文字列へ変換します。
//
// 実装(アルゴリズム):
// - 負号の有無だけを `i128` 側で判定し、大きさは `i128_abs_u128` を通して `from_u128_radix` に渡します。
//
// 注意(重要):
// - すべての基数で負数は `-...` の形に統一します。
// - 16 進英字は小文字です。
//
// 計算量:
// - O(d)
fn from_i128_radix <(i128,i32)->Result<str,i32>> (v, radix):
    let neg <bool> i128_is_negative v;
    let mag <u128> i128_abs_u128 v;
    match from_u128_radix mag radix:
        Result::Ok body:
            if:
                neg
                then:
                    Result::Ok<str,i32> concat "-" body
                else:
                    Result::Ok<str,i32> body
        Result::Err e:
            Result::Err<str,i32> e

// to_i128: 10 進文字列を i128 に変換する
//
// 目的:
// - 大きな符号付き整数文字列を `i128` として読み取ります。
//
// 実装(アルゴリズム):
// - `to_i128_radix s 10` に委譲します。
//
// 注意(重要):
// - 接頭辞は解釈しません。
//
// 計算量:
// - O(n)
fn to_i128 <(str)->Result<i128,i32>> (s):
    to_i128_radix s 10

// to_i128_radix: 指定基数の文字列を i128 に変換する
//
// 目的:
// - 2 / 8 / 10 / 16 進の符号付き文字列を `i128` に変換します。
//
// 実装(アルゴリズム):
// - 先頭の `-` を切り出した後、残りを `to_u128_radix` で非負の大きさとして解析します。
// - 符号が負なら `i128_neg` で符号反転します。
//
// 注意(重要):
// - 現在はオーバーフロー検査を行っていないため、表現域外入力は mod 2^128 でラップします。
// - 接頭辞 `0x` などは解釈しません。
//
// 計算量:
// - O(n)
fn to_i128_radix <(str,i32)->Result<i128,i32>> (s, radix):
    let n <i32> load_i32 s;
    if:
        eq n 0
        then:
            Result::Err<i128,i32> 1
        else:
            let first <i32> load_u8 add s 4;
            let neg <bool> eq first 45;
            let body <str> if neg:
                then str_slice s 1 n
                else s
            match to_u128_radix body radix:
                Result::Ok mag:
                    let base <i128> i128_from_u128_bits mag;
                    if:
                        neg
                        then:
                            Result::Ok<i128,i32> i128_neg base
                        else:
                            Result::Ok<i128,i32> base
                Result::Err e:
                    Result::Err<i128,i32> e

//: cast: 主な用途
//:
//: [目的/もくてき]:
//: - cast の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
//: from_f64: 主な用途
//:
//: [目的/もくてき]:
//: - from_f64 の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn from_f64 <(f64)->str> (x):
    if:
        ne x x
        then:
            "nan"
        else:
            let neg <bool> lt x <f64> cast 0;
            let absx <f64> if neg:
                then sub <f64> cast 0 x
                else x
            let int_part <i64> cast absx;
            let int_f <f64> cast int_part;
            let mut frac <f64> sub absx int_f;
            let int_s <str> from_i64 int_part;
            let mut sb <StringBuilder> string_builder_new;
            if:
                neg
                then:
                    set sb sb_append sb "-";
                else:
                    ();
            set sb sb_append sb int_s;

            let scratch_region <RegionToken<u8>> unwrap_ok alloc_region_bytes<u8> 6;
            let scratch_ptr <MemPtr<u8>> get scratch_region "ptr";
            let scratch_size <i32> get scratch_region "size";
            let scratch <MemPtr<u8>> scratch_ptr;
            let mut k <i32> 0;
            while lt k 6:
                do:
                    set frac mul frac <f64> cast 10;
                    let d <i32> cast frac;
                    match store_u8 mem_ptr_add scratch k add 48 d:
                        Result::Ok _:
                            ()
                        Result::Err _e:
                            #intrinsic "unreachable" <> ()
                    set frac sub frac <f64> cast d;
                    set k add k 1;

            let mut trim <i32> 6;
            let mut done_trim <i32> 0;
            while eq done_trim 0:
                do:
                    if:
                        lt 0 trim
                        then:
                            let idx <i32> sub trim 1;
                            let b <i32> unwrap load_u8 mem_ptr_add scratch idx;
                            if:
                                eq b 48
                                then:
                                    set trim sub trim 1;
                                else:
                                    set done_trim 1;
                        else:
                            set done_trim 1;

            if:
                gt trim 0
                then:
                    let frac_region <RegionToken<u8>> unwrap_ok string_alloc_region trim;
                    let frac_ptr <MemPtr<u8>> get frac_region "ptr";
                    let frac_size <i32> get frac_region "size";
                    let frac_data <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr frac_ptr 4;
                    let mut i <i32> 0;
                    while lt i trim:
                        do:
                            let ch <i32> unwrap load_u8 mem_ptr_add scratch i;
                            match store_u8 mem_ptr_add frac_data i ch:
                                Result::Ok _:
                                    ()
                                Result::Err _e:
                                    #intrinsic "unreachable" <> ()
                            set i add i 1;
                    set sb sb_append sb ".";
                    set sb sb_append sb string_finish region_new frac_ptr frac_size trim;
                else:
                    ();
            match dealloc_ptr<u8> scratch_ptr scratch_size:
                Result::Ok _:
                    sb_build sb
                Result::Err _e:
                    #intrinsic "unreachable" <> ()

//: cast: 主な用途
//:
//: [目的/もくてき]:
//: - cast の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
//: to_f64: 主な用途
//:
//: [目的/もくてき]:
//: - to_f64 の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn to_f64 <(str)->Result<f64,i32>> (s):
    let n <i32> load_i32 s;
    let mut i <i32> 0;
    let mut ok <i32> 1;
    let mut neg <i32> 0;
    let mut int_part <f64> cast 0;
    let mut frac_part <f64> cast 0;
    let mut frac_scale <f64> cast 1;
    let mut has_digit <i32> 0;
    let ten <f64> cast 10;
    let mut out_res <Result<f64,i32>> Result::Err<f64,i32> 1;

    if:
        eq n 0
        then:
            set ok 0;
        else:
            let first <i32> load_u8 add s 4;
            if:
                eq first 45
                then:
                    set neg 1;
                    set i 1;
                else:
                    if:
                        eq first 43
                        then:
                            set i 1;
                        else:
                            ();

            while and eq ok 1 lt i n:
                do:
                    let b <i32> load_u8 <i32> add s <i32> add 4 i;
                    let d <i32> sub b 48;
                    if:
                        and ge d 0 le d 9
                        then:
                            set has_digit 1;
                            let scaled <f64> mul int_part ten;
                            let dv <f64> cast d;
                            let next_int <f64> add scaled dv;
                            set int_part next_int;
                            set i add i 1;
                        else:
                            set ok 2;

            if:
                and eq ok 2 lt i n
                then:
                    let dot <i32> load_u8 <i32> add s <i32> add 4 i;
                    if:
                        eq dot 46
                        then:
                            set ok 1;
                            set i add i 1;
                            while and eq ok 1 lt i n:
                                do:
                                    let b <i32> load_u8 <i32> add s <i32> add 4 i;
                                    let d <i32> sub b 48;
                                    if:
                                        and ge d 0 le d 9
                                        then:
                                            set has_digit 1;
                                            let next_scale <f64> div frac_scale ten;
                                            set frac_scale next_scale;
                                            let dv <f64> cast d;
                                            let addv <f64> mul dv frac_scale;
                                            let next_frac <f64> add frac_part addv;
                                            set frac_part next_frac;
                                            set i add i 1;
                                        else:
                                            set ok 2;
                        else:
                            set ok 0;
                else:
                    ();

            let mut exp_val <i32> 0;
            let mut exp_neg <i32> 0;
            if:
                and eq ok 2 lt i n
                then:
                    let eb <i32> load_u8 <i32> add s <i32> add 4 i;
                    if:
                        or eq eb 101 eq eb 69
                        then:
                            set i add i 1;
                            if:
                                lt i n
                                then:
                                    let sb <i32> load_u8 <i32> add s <i32> add 4 i;
                                    if:
                                        eq sb 45
                                        then:
                                            set exp_neg 1;
                                            set i add i 1;
                                        else:
                                            if:
                                                eq sb 43
                                                then:
                                                    set i add i 1;
                                                else:
                                                    ();
                                else:
                                    set ok 0;

                            let mut exp_digits <i32> 0;
                            while and eq ok 2 lt i n:
                                do:
                                    let b <i32> load_u8 <i32> add s <i32> add 4 i;
                                    let d <i32> sub b 48;
                                    if:
                                        and ge d 0 le d 9
                                        then:
                                            set exp_digits 1;
                                            set exp_val <i32> add <i32> mul exp_val 10 d;
                                            set i add i 1;
                                        else:
                                            set ok 0;
                            if:
                                eq exp_digits 0
                                then:
                                    set ok 0;
                                else:
                                    ();
                        else:
                            ();
                else:
                    ();

            if:
                ne i n
                then:
                    set ok 0;
                else:
                    ();

            if:
                eq has_digit 0
                then:
                    set ok 0;
                else:
                    ();

            let mut out <f64> add int_part frac_part;
            let mut k <i32> 0;
            while and eq ok 2 lt k exp_val:
                do:
                    if:
                        eq exp_neg 1
                        then:
                            let next_out <f64> div out ten;
                            set out next_out;
                        else:
                            let next_out <f64> mul out ten;
                            set out next_out;
                    set k add k 1;

            if:
                eq ok 2
                then:
                    if:
                        eq neg 1
                        then:
                            let zero <f64> cast 0;
                            let signed_out <f64> sub zero out;
                            set out_res Result::Ok<f64,i32> signed_out;
                        else:
                            set out_res Result::Ok<f64,i32> out;
                else:
                    set out_res Result::Err<f64,i32> 1;

    out_res

//: cast: 主な用途
//:
