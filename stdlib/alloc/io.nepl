//: # io
//: [target/たーげっと][非依存/ひいぞん]の stream [抽象/ちゅうしょう]と binary buffer を[集/あつ]めるライブラリ
//:
//: ### [目的/もくてき]
//: - byte stream / text stream の[読/よ]み[書/か]き[能力/のうりょく]を trait として[分離/ぶんり]し、`std` や `kp` が[共通/きょうつう]の[入口/いりぐち]に[依存/いそん]できるようにします。
//: - binary stream の[媒体/ばいたい]として、`fd_read` / `fd_write` にそのまま[渡/わた]せる[連続/れんぞく] byte buffer `ByteBuf` を[定義/ていぎ]します。
//:
//: ### [注意/ちゅうい]
//: - ここでは syscall や descriptor を[扱/あつか]いません。[具体的/ぐたいてき]な[入出力/にゅうしゅつりょく]は `std/streamio` や `std/fs` が[担当/たんとう]します。
//: - `ByteBuf` は[所有権/しょゆうけん]を[持/も]つので `Copy` / `Clone` を[実装/じっそう]しません。
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/test" as *
//:| #import "alloc/io" as *
//: struct CountSink:
//:     total <i32>
//:
//: impl ByteWriter for CountSink:
//:     fn write_bytes <(CountSink,ByteBuf)*>Result<CountSink, StdErrorKind>> (sink, bytes):
//:         let n <i32> get bytes "len";
//:         io_bytebuf_free bytes;
//:         Result::Ok CountSink add get sink "total" n
//:
//: fn main <()*>i32> ():
//:     let bytes0 <ByteBuf> io_bytebuf_from_str "AB";
//:     match io_write_bytes (CountSink 3) bytes0:
//:         Result::Ok sink1:
//:             if eq get sink1 "total" 5 0 1
//:         Result::Err _e:
//:             0
//: ```

#indent 4

#import "alloc/diag/error" as *
#import "alloc/string" as *
#import "core/mem" as *
#import "core/result" as *

//: ## ByteBuf
//: [連続/れんぞく]した raw byte buffer を[所有/しょゆう]する handle
//:
//: ### [目的/もくてき]
//: - `Vec<u8>` の[内部表現/ないぶひょうげん]に[依存/いそん]せず、binary I/O の[媒体/ばいたい]を[明示的/めいじてき]に[表/あらわ]します。
//:
//: ### [注意/ちゅうい]
//: - `ptr` は `len` byte の[所有領域/しょゆうりょういき]を[指/さ]します。
//: - [使/つか]い[終/お]わったら `io_bytebuf_free` で[解放/かいほう]してください。
struct ByteBuf:
    ptr <MemPtr<u8>>
    len <i32>

fn io_bytebuf_empty <()->ByteBuf> ():
    ByteBuf mem_ptr_wrap 0 0

fn io_bytebuf_len <(ByteBuf)->i32> (buf):
    get buf "len"

fn io_bytebuf_free <(ByteBuf)->()> (buf):
    let ptr <MemPtr<u8>> get buf "ptr"
    let len <i32> get buf "len"
    if:
        gt len 0
        then:
            match dealloc_ptr<u8> ptr len:
                Result::Ok _:
                    ()
                Result::Err _e:
                    ()
        else:
            ()

fn io_bytebuf_from_str <(str)->ByteBuf> (text):
    let byte_len <i32> load_i32 text
    let data <MemPtr<u8>> string_data_ptr text
    match alloc_ptr<u8> byte_len:
        Result::Err _e:
            io_bytebuf_empty
        Result::Ok out:
            let mut i <i32> 0
            while lt i byte_len:
                do:
                    let b <i32> unwrap<i32> load_u8 mem_ptr_add data i
                    match store_u8 mem_ptr_add out i b:
                        Result::Ok _:
                            ()
                        Result::Err _e:
                            #intrinsic "unreachable" <> ()
                    set i add i 1
            ByteBuf out byte_len

fn io_bytebuf_to_str <(ByteBuf)*>str> (buf):
    let byte_len <i32> get buf "len"
    let data <MemPtr<u8>> get buf "ptr"
    match string_alloc_region byte_len:
        Result::Err _e:
            io_bytebuf_free buf
            ""
        Result::Ok region:
            let out <MemPtr<u8>> get region "ptr"
            let mut i <i32> 0
            while lt i byte_len:
                do:
                    let b <i32> unwrap<i32> load_u8 mem_ptr_add data i
                    match store_u8 mem_ptr_add out add 4 i b:
                        Result::Ok _:
                            ()
                        Result::Err _e:
                            #intrinsic "unreachable" <> ()
                    set i add i 1
            io_bytebuf_free buf
            string_finish region byte_len

//: ## ByteReader
//: [生/なま]の[バイト列/ばいとれつ]を[読/よ]み[出/だ]す[能力/のうりょく]
trait ByteReader:
    fn read_all_bytes <(Self)*>Result<ByteBuf, StdErrorKind>> (stream):
        Result::Err StdErrorKind::IoError

//: ## ByteWriter
//: [生/なま]の[バイト列/ばいとれつ]を[書/か]き[込/こ]む[能力/のうりょく]
trait ByteWriter:
    fn write_bytes <(Self, ByteBuf)*>Result<Self, StdErrorKind>> (stream, bytes):
        Result::Err StdErrorKind::IoError

//: ## TextReader
//: text として[全体/ぜんたい]を[読/よ]み[出/だ]す[能力/のうりょく]
trait TextReader:
    fn read_all_text <(Self)*>Result<str, StdErrorKind>> (stream):
        Result::Err StdErrorKind::IoError

//: ## TextWriter
//: text を[書/か]き[込/こ]む[能力/のうりょく]
trait TextWriter:
    fn write_str <(Self, str)*>Result<Self, StdErrorKind>> (stream, text):
        Result::Err StdErrorKind::IoError

//: ## Flush
//: [保留中/ほりゅうちゅう]の[出力/しゅつりょく]を[外部/がいぶ]へ[反映/はんえい]する[能力/のうりょく]
trait Flush:
    fn flush <(Self)*>Result<Self, StdErrorKind>> (stream):
        Result::Err StdErrorKind::IoError

//: ## Close
//: stream を[閉/と]じる[能力/のうりょく]
trait Close:
    fn close <(Self)*>Result<(), StdErrorKind>> (stream):
        Result::Err StdErrorKind::IoError

fn io_read_all_bytes <.T: ByteReader> <(.T)*>Result<ByteBuf, StdErrorKind>> (stream):
    ByteReader::read_all_bytes stream

fn io_write_bytes <.T: ByteWriter> <(.T, ByteBuf)*>Result<.T, StdErrorKind>> (stream, bytes):
    ByteWriter::write_bytes stream bytes

fn io_read_all_text <.T: TextReader> <(.T)*>Result<str, StdErrorKind>> (stream):
    TextReader::read_all_text stream

fn io_write_str <.T: TextWriter> <(.T, str)*>Result<.T, StdErrorKind>> (stream, text):
    TextWriter::write_str stream text

fn io_flush <.T: Flush> <(.T)*>Result<.T, StdErrorKind>> (stream):
    Flush::flush stream

fn io_close <.T: Close> <(.T)*>Result<(), StdErrorKind>> (stream):
    Close::close stream
