//: # hash32
//: 32-bit [非暗号/ひあんごう]ハッシュの bare overload
//:
//: ### [目的/もくてき]
//: - bare overload `hash32` で primitive / `str` の 32-bit [非暗号/ひあんごう]ハッシュを[得/え]られるようにします。
//: - `HashMap` / `HashSet` が[受/う]け[取/と]る hash function value の default [候補/こうほ]として[再利用/さいりよう]できるようにします。
//:
//: ### [実装/じっそう]
//: - primitive key と UTF-8 byte [列/れつ]に[対/たい]して avalanche [混合/こんごう]を[行/おこな]います。
//:
//: ### [注意/ちゅうい]
//: - [暗号用途/あんごうようと]には[使/つか]えません。
//:
//: ### [計算量/けいさんりょう]
//: - `i32` / `bool` / `u8` / `i64` は O(1)、`str` は[文字列長/もじれつちょう]を n として O(n) です。

#indent 4

#import "core/math" as *
#import "core/cast" as *
#import "alloc/string" as string
#import "alloc/hash/fnv1a32" as *

//: ## mix
//: 32-bit [値/あたい]を avalanche [混合/こんごう]する
//:
//: ### [目的/もくてき]
//: - hash の[下位/かい] bit まで[偏/かたよ]りを[散/ちら]し、bucket [選択/せんたく]での[偏在/へんざい]を[減/へ]らします。
fn mix <(i32)->i32> (x):
    let x_s16 <i32> shr_u x 16
    let h1 <i32> xor x x_s16
    let h2 <i32> mul h1 -2048144789
    let h2_s13 <i32> shr_u h2 13
    let h3 <i32> xor h2 h2_s13
    let h4 <i32> mul h3 -1028477387
    let h4_s16 <i32> shr_u h4 16
    xor h4 h4_s16

fn hash_bytes_loop <(str,i32,i32,Fnv1a32)->Fnv1a32> (s, n, idx, h):
    if:
        ge idx n
        then h
        else:
            let s_data <i32> add s 4
            let p <i32> add s_data idx
            let b <i32> load_u8 p
            hash_bytes_loop s n add idx 1 fnv1a32_update h b

//: ## hash32
//: `bool` を 32-bit ハッシュへ[変換/へんかん]する
fn hash32 <(bool)->i32> (key):
    let k <i32> cast key
    mix xor k -1640531527

//: ## hash32
//: `i32` を 32-bit ハッシュへ[変換/へんかん]する
fn hash32 <(i32)->i32> (key):
    mix xor key -1640531527

//: ## hash32
//: `u8` を 32-bit ハッシュへ[変換/へんかん]する
fn hash32 <(u8)->i32> (key):
    let k <i32> cast key
    mix xor k -1640531527

//: ## hash32
//: `i64` を 32-bit ハッシュへ[変換/へんかん]する
fn hash32 <(i64)->i32> (key):
    let lo <i32> cast key
    let hi64 <i64> shr_u key <i64> cast 32
    let hi <i32> cast hi64
    let folded <i32> xor lo hi
    mix xor folded -1640531527

//: ## hash32
//: `str` を 32-bit ハッシュへ[変換/へんかん]する
fn hash32 <(str)->i32> (s):
    let n <i32> string::len s
    let h0 <Fnv1a32> new_fnv1a32
    let h1 <Fnv1a32> hash_bytes_loop s n 0 h0
    mix fnv1a32_finalize h1
