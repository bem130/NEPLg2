//: # fnv1a32
//: FNV-1a 32-bit [非暗号/ひあんごう] hash
//:
//: ### [目的/もくてき]
//: - [短/みじか]い key や byte [列/れつ]に[対/たい]する lightweight hash state を[提供/ていきょう]します。
//: - `update` を[繰/く]り[返/かえ]して byte を[混合/こんごう]し、`finalize` で 32-bit [値/あたい]を[取/と]り[出/だ]せるようにします。
//:
//: ### [実装/じっそう]
//: - FNV-1a の[更新式/こうしんしき] `(hash xor byte) * prime` をそのまま[実装/じっそう]します。
//: - state は `Fnv1a32` struct 1 [個/こ]に[保持/ほじ]します。
//:
//: ### [注意/ちゅうい]
//: - [暗号/あんごう]用途には[使/つか]えません。
//: - [永続化/えいぞくか]や[通信/つうしん]で[互換/ごかん]を[保証/ほしょう]する fingerprint として[使/つか]うものではなく、主に stdlib [内部/ないぶ]の分散用途です。
//:
//: ### [計算量/けいさんりょう]
//: - `update` / `finalize` は O(1) です。

#indent 4
#import "core/math" as *

//: Fnv1a32: 構造体の概要
//:
//: [目的/もくてき]:
//: - Fnv1a32 の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 定義そのものは O(1) です。
struct Fnv1a32:
    hash <i32>

//: new_fnv1a32: 主な用途
//:
//: [目的/もくてき]:
//: - オフセット基底値で初期化された `Fnv1a32` を[返/かえ]します。
//:
//: [実装/じっそう]:
//: - 基底値 `0x811c9dc5` (`-2128831035`) を state に[保持/ほじ]します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn new_fnv1a32 <()->Fnv1a32> ():
    Fnv1a32 -2128831035

//: fnv1a32_update: 主な用途
//:
//: [目的/もくてき]:
//: - byte を 1 [個/こ][混合/こんごう]した新しい state を[返/かえ]します。
//:
//: [実装/じっそう]:
//: - `(hash xor byte) * 16777619` を[計算/けいさん]します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn fnv1a32_update <(Fnv1a32, i32)->Fnv1a32> (h, byte):
    let prime <i32> 16777619
    let current <i32> h.hash
    let x <i32> xor current byte
    let next <i32> mul x prime
    Fnv1a32 next

//: fnv1a32_finalize: 主な用途
//:
//: [目的/もくてき]:
//: - [現在/げんざい]の 32-bit hash [値/あたい]を[返/かえ]します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn fnv1a32_finalize <(Fnv1a32)->i32> (h):
    h.hash
