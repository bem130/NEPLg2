#indent 4

//: # bloom_filter
//: [近似/きんじ] membership test を[提供/ていきょう]する Bloom Filter
//:
//: ### [目的/もくてき]
//: - `BloomFilter<.T, .H>` を[提供/ていきょう]し、`new` / `len` / `insert` / `contains` / `clear` / `free` の bare API で[近似/きんじ][集合/しゅうごう][判定/はんてい]を[扱/あつか]えるようにします。
//: - [正確/せいかく]な `Set` より[少/すく]ない[記憶/きおく][領域/りょういき]で「[入/はい]っていないこと」を[高速/こうそく]に[判定/はんてい]する[用途/ようと]を[標準/ひょうじゅん]で[支/ささ]えます。
//:
//: ### [実装/じっそう]
//: - [内部/ないぶ]は byte [配列/はいれつ] bitset と hasher [値/あたい]を[保持/ほじ]します。
//: - [各要素/かくようそ]に[対/たい]して 3 [本/ぼん]の probe index を[生成/せいせい]し、[対応/たいおう] bit を[立/た]てます。
//: - `contains` は 3 [本/ぼん]すべての bit が[立/た]っているときだけ true を[返/かえ]します。
//:
//: ### [注意/ちゅうい]
//: - false negative は[起/お]きませんが、false positive は[起/お]こりえます。
//: - `insert` は[重複/ちょうふく]を[区別/くべつ]しません。
//: - `new` は bit [長/ちょう]が 1 [未満/みまん]なら `Result::Err Diag` を[返/かえ]します。
//:
//: ### [計算量/けいさんりょう]
//: - `len` は O(1) です。
//: - `insert` / `contains` は probe [本数/ほんすう]を k=3 として O(1) です。
//: - `clear` は bit [配列/はいれつ][長/ちょう]を m byte として O(m) です。

#import "core/mem" as *
#import "core/math" as *
#import "core/result" as *
#import "core/field" as field
#import "core/traits/hash_key" as *
#import "core/traits/hash" as *
#import "alloc/diag/error" as *

//: ## BloomFilter
//: bitset と hasher を[保持/ほじ]する[所有者/しょゆうしゃ]
//:
//: ### [目的/もくてき]
//: - bit [長/ちょう]・byte [長/ちょう]・bitset pointer・hasher を 1 [値/あたい]として[受/う]け[渡/わた]しできるようにします。
//:
//: ### [注意/ちゅうい]
//: - bitset [領域/りょういき]の[所有権/しょゆうけん]を[持/も]つので、[不要/ふよう]になったら `free` します。
//: - hasher 型 `.H` は `Hasher<.T>` と `copy` capability を[持/も]つ[必要/ひつよう]があります。
struct BloomFilter<.T,.H>:
    nbits <i32>
    nbytes <i32>
    bits <MemPtr<u8>>
    hasher <.H>

fn bloom_invalid_len_diag <(i32)*>Diag> (nbits):
    let msg0 <str> concat "bloom_filter new invalid bit length " from_i32 nbits
    diag_error StdErrorKind::CapacityExceeded msg0

fn bloom_hash0 <.T: HashKey,.H: Hasher<.T>> <(.H,.T)->i32> (hasher, key):
    hash_with hasher key

fn bloom_hash1 <.T: HashKey,.H: Hasher<.T>> <(.H,.T)->i32> (hasher, key):
    let h0 <i32> bloom_hash0<.T,.H> hasher key
    let hk <i32> hashkey_hash32 key
    let mixed <i32> mix xor h0 hk
    if eq mixed 0 1 mixed

fn bloom_probe_index <(i32,i32,i32)->i32> (nbits, h0, h1):
    rem_u add h0 h1 nbits

fn bloom_byte_index <(i32)->i32> (bit_idx):
    div_s bit_idx 8

fn bloom_bit_mask <(i32)->i32> (bit_idx):
    shl 1 rem_s bit_idx 8

fn bloom_set_bit <(MemPtr<u8>,i32)->()> (bits, bit_idx):
    let byte_idx <i32> bloom_byte_index bit_idx
    let mask <i32> bloom_bit_mask bit_idx
    let ptr <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr bits byte_idx
    let cur <i32> load_u8 mem_ptr_addr ptr
    store_u8 mem_ptr_addr ptr or cur mask

fn bloom_test_bit <(MemPtr<u8>,i32)->bool> (bits, bit_idx):
    let byte_idx <i32> bloom_byte_index bit_idx
    let mask <i32> bloom_bit_mask bit_idx
    let ptr <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr bits byte_idx
    let cur <i32> load_u8 mem_ptr_addr ptr
    ne and cur mask 0

//: ## new
//: [空/から]の Bloom Filter を[作/つく]る
//:
//: ### [計算量/けいさんりょう]
//: - bit [長/ちょう]を n とすると O(n/8) です。
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bloom_filter" as *
//:| #import "core/traits/hash" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bf <BloomFilter<i32, DefaultHash32>> unwrap_ok<BloomFilter<i32, DefaultHash32>, Diag> new DefaultHash32 64;
//:     if eq len bf 64 1 0
//: ```
fn new <.T: HashKey,.H: Hasher<.T>> <(.H,i32)*>Result<BloomFilter<.T,.H>, Diag>> (hasher, nbits):
    if:
        le nbits 0
        then diag_err<BloomFilter<.T,.H>> bloom_invalid_len_diag nbits
        else:
            let nbytes <i32> div_s add nbits 7 8
            match alloc_ptr<u8> nbytes:
                Result::Err _e:
                    diag_err<BloomFilter<.T,.H>> diag_out_of_memory "bloom_filter_new(bits)"
                Result::Ok bits:
                    let mut i <i32> 0
                    while lt i nbytes:
                        do:
                            let ptr <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr bits i
                            store_u8 mem_ptr_addr ptr 0
                            set i add i 1
                    ok<BloomFilter<.T,.H>, Diag> BloomFilter<.T,.H> nbits nbytes bits hasher

//: ## len
//: bit [長/ちょう]を[返/かえ]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bloom_filter" as *
//:| #import "core/traits/hash" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bf <BloomFilter<i32, DefaultHash32>> unwrap_ok<BloomFilter<i32, DefaultHash32>, Diag> new DefaultHash32 32;
//:     if eq len bf 32 1 0
//: ```
fn len <.T,.H> <(BloomFilter<.T,.H>)->i32> (bf):
    field::get bf "nbits"

//: ## insert
//: [要素/ようそ]を[登録/とうろく]する
//:
//: ### [計算量/けいさんりょう]
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bloom_filter" as *
//:| #import "core/traits/hash" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/math" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bf0 <BloomFilter<i32, DefaultHash32>> unwrap_ok<BloomFilter<i32, DefaultHash32>, Diag> new DefaultHash32 64;
//:     let bf1 <BloomFilter<i32, DefaultHash32>> insert<i32, DefaultHash32> bf0 7;
//:     let ok <bool> contains<i32, DefaultHash32> bf1 7;
//:     if ok 1 0
//: ```
fn insert <.T: HashKey,.H: Hasher<.T>> <(BloomFilter<.T,.H>,.T)->BloomFilter<.T,.H>> (bf, key):
    let bf_mem <i32> alloc_raw size_of<BloomFilter<.T,.H>>
    store<BloomFilter<.T,.H>> bf_mem bf
    let nbits <i32> get load<BloomFilter<.T,.H>> bf_mem "nbits"
    let bits <MemPtr<u8>> get load<BloomFilter<.T,.H>> bf_mem "bits"
    let hasher <.H> get load<BloomFilter<.T,.H>> bf_mem "hasher"
    let h0 <i32> bloom_hash0<.T,.H> hasher key
    let h1 <i32> bloom_hash1<.T,.H> hasher key
    let i0 <i32> rem_u h0 nbits
    let i1 <i32> bloom_probe_index nbits h0 h1
    let i2 <i32> bloom_probe_index nbits i1 h1
    bloom_set_bit bits i0
    bloom_set_bit bits i1
    bloom_set_bit bits i2
    let out <BloomFilter<.T,.H>> load<BloomFilter<.T,.H>> bf_mem
    dealloc_raw bf_mem size_of<BloomFilter<.T,.H>>
    out

//: ## contains
//: [要素/ようそ]が[登録済/とうろくず]みかを[近似/きんじ][判定/はんてい]する
//:
//: ### [注意/ちゅうい]
//: - true でも[実際/じっさい]には[入/はい]っていない false positive がありえます。
//:
//: ### [計算量/けいさんりょう]
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bloom_filter" as *
//:| #import "core/traits/hash" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bf0 <BloomFilter<i32, DefaultHash32>> unwrap_ok<BloomFilter<i32, DefaultHash32>, Diag> new DefaultHash32 64;
//:     let bf1 <BloomFilter<i32, DefaultHash32>> insert<i32, DefaultHash32> bf0 7;
//:     let bf2 <BloomFilter<i32, DefaultHash32>> insert<i32, DefaultHash32> bf1 12;
//:     let ok <bool> contains<i32, DefaultHash32> bf2 7;
//:     if ok 1 0
//: ```
fn contains <.T: HashKey,.H: Hasher<.T>> <(BloomFilter<.T,.H>,.T)->bool> (bf, key):
    let bf_mem <i32> alloc_raw size_of<BloomFilter<.T,.H>>
    store<BloomFilter<.T,.H>> bf_mem bf
    let nbits <i32> get load<BloomFilter<.T,.H>> bf_mem "nbits"
    let bits <MemPtr<u8>> get load<BloomFilter<.T,.H>> bf_mem "bits"
    let hasher <.H> get load<BloomFilter<.T,.H>> bf_mem "hasher"
    let h0 <i32> bloom_hash0<.T,.H> hasher key
    let h1 <i32> bloom_hash1<.T,.H> hasher key
    let i0 <i32> rem_u h0 nbits
    let i1 <i32> bloom_probe_index nbits h0 h1
    let i2 <i32> bloom_probe_index nbits i1 h1
    let ok0 <bool> bloom_test_bit bits i0
    let ok1 <bool> bloom_test_bit bits i1
    let ok2 <bool> bloom_test_bit bits i2
    dealloc_raw bf_mem size_of<BloomFilter<.T,.H>>
    and ok0 and ok1 ok2

//: ## clear
//: [全/すべ]ての bit を 0 に[戻/もど]す
//:
//: ### [計算量/けいさんりょう]
//: - byte [長/ちょう]を m として O(m)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bloom_filter" as *
//:| #import "core/traits/hash" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/math" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bf0 <BloomFilter<i32, DefaultHash32>> unwrap_ok<BloomFilter<i32, DefaultHash32>, Diag> new DefaultHash32 64;
//:     let bf1 <BloomFilter<i32, DefaultHash32>> insert<i32, DefaultHash32> bf0 7;
//:     let bf2 <BloomFilter<i32, DefaultHash32>> clear<i32, DefaultHash32> bf1;
//:     let ok <bool> contains<i32, DefaultHash32> bf2 7;
//:     if ok 0 1
//: ```
fn clear <.T,.H> <(BloomFilter<.T,.H>)->BloomFilter<.T,.H>> (bf):
    let bf_mem <i32> alloc_raw size_of<BloomFilter<.T,.H>>
    store<BloomFilter<.T,.H>> bf_mem bf
    let nbytes <i32> get load<BloomFilter<.T,.H>> bf_mem "nbytes"
    let bits <MemPtr<u8>> get load<BloomFilter<.T,.H>> bf_mem "bits"
    let mut i <i32> 0
    while lt i nbytes:
        do:
            let ptr <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr bits i
            store_u8 mem_ptr_addr ptr 0
            set i add i 1
    let out <BloomFilter<.T,.H>> load<BloomFilter<.T,.H>> bf_mem
    dealloc_raw bf_mem size_of<BloomFilter<.T,.H>>
    out

//: ## free
//: bitset [領域/りょういき]を[解放/かいほう]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bloom_filter" as *
//:| #import "core/traits/hash" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bf <BloomFilter<i32, DefaultHash32>> unwrap_ok<BloomFilter<i32, DefaultHash32>, Diag> new DefaultHash32 64;
//:     free bf;
//:     0
//: ```
fn free <.T,.H> <(BloomFilter<.T,.H>)->()> (bf):
    let bf_mem <i32> alloc_raw size_of<BloomFilter<.T,.H>>
    store<BloomFilter<.T,.H>> bf_mem bf
    let nbytes <i32> get load<BloomFilter<.T,.H>> bf_mem "nbytes"
    let bits <MemPtr<u8>> get load<BloomFilter<.T,.H>> bf_mem "bits"
    let _ <()> uwok dealloc_ptr<u8> bits nbytes
    dealloc_raw bf_mem size_of<BloomFilter<.T,.H>>
