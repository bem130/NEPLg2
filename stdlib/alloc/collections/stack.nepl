//: stack: [後入先出/あといれさきだし]（LIFO）スタックを扱うライブラリ
//:
//: [目的/もくてき]:
//: - `push` / `pop` / `peek` / `len` など、スタック操作の基本 API を提供します。
//: - parser や探索処理で使いやすい軽量なスタック実装を提供します。
//:
//: [実装/じっそう]:
//: - スタック本体は `Vec<.T>` で表し、内部でヘッダ `[len, cap, data_ptr]` を保持します。
//: - 容量不足時は 2 倍拡張して `realloc` します。
//:
//: [注意/ちゅうい]:
//: - `push` / `clear` は更新後の `Stack<.T>` を返します。
//: - `pop` は `Option<.T>` を返します。
//: - `peek` は値のみを返します。
//: - `free` 後のスタック値は再利用できません。
//:
//: [計算量/けいさんりょう]:
//: - `len`/`is_empty`/`peek`/`pop` は O(1)。
//: - `push` はならし O(1)、拡張発生時のみ O(n)。
//:
//: 追加の使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/option" as *
//:| #import "core/field" as *
//:| #import "core/result" as *
//:| #import "core/math" as *
//: fn main <()*>i32> ():
//:     let st0 <Stack<i32>>:
//:         unwrap_ok<Stack<i32>, Diag> new<i32>
//:         |> push 10 |> uwok
//:         |> push 20 |> uwok
//:     let ok0 if eq len st0 2 1 0;
//:     let st1 <Stack<i32>>:
//:         unwrap_ok<Stack<i32>, Diag> new<i32>
//:         |> push 10 |> uwok
//:         |> push 20 |> uwok
//:     let ok1 match peek st1:
//:         Option::Some x:
//:             if eq x 20 1 0
//:         Option::None:
//:             0
//:     let st2 <Stack<i32>>:
//:         unwrap_ok<Stack<i32>, Diag> new<i32>
//:         |> push 10 |> uwok
//:         |> push 20 |> uwok
//:     let p pop st2;
//:     let ok2 match p:
//:         Option::Some x:
//:             if eq x 20 1 0
//:         Option::None:
//:             0
//:     let s01 <i32> add ok0 ok1;
//:     add s01 ok2
//: ```
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/string" as s
//:| #import "alloc/diag/error" as *
//:| #import "core/option" as *
//:| #import "core/field" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st <Stack<str>>:
//:         unwrap_ok<Stack<str>, Diag> new<str>
//:         |> push "a" |> uwok
//:         |> push "b" |> uwok
//:     let p pop st;
//:     let ok0 match p:
//:         Option::Some x:
//:             if s::str_eq x "b" 1 0
//:         Option::None:
//:             0
//:     ok0
//: ```

#indent 4

#import "core/mem" as *
#import "core/option" as *
#import "core/result" as *
#import "core/field" as *
#import "alloc/diag/error" as *

struct Stack<.T>:
    hdr <MemPtr<u8>>

//: stack_header_len_ptr: ヘッダの length [欄/らん]を[指/さ]す
//:
//: ### [目的/もくてき]
//: - `[len, cap, data_ptr]` [形式/けいしき]のヘッダ[領域/りょういき]から length [欄/らん]を `MemPtr<i32>` として[得/え]ます。
//:
//: ### [実装/じっそう]
//: - ヘッダ[先頭/せんとう]の 4 byte を `i32` [欄/らん]として[解釈/かいしゃく]します。
//:
//: ### [注意/ちゅうい]
//: - [公開/こうかい] API ではなく、`Stack` [内部/ないぶ]の[補助/ほじょ]です。
//:
//: ### [計算量/けいさんりょう]
//: - O(1)
fn stack_header_len_ptr <.T> <(Stack<.T>)->MemPtr<i32>> (stk):
    mem_ptr_wrap mem_ptr_addr get stk "hdr"

//: stack_header_cap_ptr: ヘッダの capacity [欄/らん]を[指/さ]す
//:
//: ### [目的/もくてき]
//: - ヘッダ[中/ちゅう]の capacity [欄/らん]を `MemPtr<i32>` として[得/え]ます。
//:
//: ### [実装/じっそう]
//: - ヘッダ[先頭/せんとう]から 4 byte [進/すす]めた[位置/いち]を `i32` [欄/らん]として[扱/あつか]います。
//:
//: ### [注意/ちゅうい]
//: - [公開/こうかい] API ではなく、`Stack` [内部/ないぶ]の[補助/ほじょ]です。
//:
//: ### [計算量/けいさんりょう]
//: - O(1)
fn stack_header_cap_ptr <.T> <(Stack<.T>)->MemPtr<i32>> (stk):
    mem_ptr_wrap add mem_ptr_addr get stk "hdr" 4

//: stack_header_data_ptr_ptr: ヘッダの data pointer [欄/らん]を[指/さ]す
//:
//: ### [目的/もくてき]
//: - データ[領域/りょういき]の raw address を[保持/ほじ]する[欄/らん]を `MemPtr<i32>` として[得/え]ます。
//:
//: ### [実装/じっそう]
//: - ヘッダ[先頭/せんとう]から 8 byte [進/すす]めた[位置/いち]を `i32` [欄/らん]として[扱/あつか]います。
//:
//: ### [注意/ちゅうい]
//: - [公開/こうかい] API ではなく、`Stack` [内部/ないぶ]の[補助/ほじょ]です。
//:
//: ### [計算量/けいさんりょう]
//: - O(1)
fn stack_header_data_ptr_ptr <.T> <(Stack<.T>)->MemPtr<i32>> (stk):
    mem_ptr_wrap add mem_ptr_addr get stk "hdr" 8

//: stack_len_raw: [内部/ないぶ]で length を[読/よ]む
//:
//: ### [目的/もくてき]
//: - `Stack` の length [欄/らん]を `i32` として[読/よ]みます。
//:
//: ### [実装/じっそう]
//: - ヘッダの length [欄/らん]を raw `load_i32` で[参照/さんしょう]します。
//:
//: ### [注意/ちゅうい]
//: - [公開/こうかい] API ではなく、`Stack` [内部/ないぶ]の[補助/ほじょ]です。
//:
//: ### [計算量/けいさんりょう]
//: - O(1)
fn stack_len_raw <.T> <(Stack<.T>)->i32> (stk):
    load_i32 mem_ptr_addr stack_header_len_ptr<.T> stk

//: stack_cap_raw: [内部/ないぶ]で capacity を[読/よ]む
//:
//: ### [目的/もくてき]
//: - `Stack` の capacity [欄/らん]を `i32` として[読/よ]みます。
//:
//: ### [実装/じっそう]
//: - ヘッダの capacity [欄/らん]を raw `load_i32` で[参照/さんしょう]します。
//:
//: ### [注意/ちゅうい]
//: - [公開/こうかい] API ではなく、`Stack` [内部/ないぶ]の[補助/ほじょ]です。
//:
//: ### [計算量/けいさんりょう]
//: - O(1)
fn stack_cap_raw <.T> <(Stack<.T>)->i32> (stk):
    load_i32 mem_ptr_addr stack_header_cap_ptr<.T> stk

//: stack_data_ptr: [内部/ないぶ]でデータ[先頭/せんとう]を[得/え]る
//:
//: ### [目的/もくてき]
//: - `Stack` の[要素/ようそ][領域/りょういき][先頭/せんとう]を `MemPtr<.T>` として[返/かえ]します。
//:
//: ### [実装/じっそう]
//: - ヘッダに[保持/ほじ]した raw address を[読/よ]み、`MemPtr<.T>` で[包/つつ]みます。
//:
//: ### [注意/ちゅうい]
//: - [公開/こうかい] API ではなく、`Stack` [内部/ないぶ]の[補助/ほじょ]です。
//:
//: ### [計算量/けいさんりょう]
//: - O(1)
fn stack_data_ptr <.T> <(Stack<.T>)->MemPtr<.T>> (stk):
    mem_ptr_wrap load_i32 mem_ptr_addr stack_header_data_ptr_ptr<.T> stk

//: new: 空のスタックを作る
//:
//: ### [目的/もくてき]
//: - [既定/きてい][容量/ようりょう]の[空/から]スタックを[作成/さくせい]し、`Stack<.T>` として[返/かえ]します。
//:
//: ### [実装/じっそう]
//: - 12 byte のヘッダ[領域/りょういき]と、[既定/きてい][容量/ようりょう]ぶんの[要素/ようそ][領域/りょういき]を[別々/べつべつ]に[確保/かくほ]します。
//: - ヘッダには `[len, cap, data_ptr]` を[保存/ほぞん]し、`Stack<.T>` はそのヘッダ[先頭/せんとう]を[保持/ほじ]します。
//:
//: ### [注意/ちゅうい]
//: - [失敗/しっぱい]すると `Result::Err Diag` を[返/かえ]します。
//: - [返/かえ]る `Stack<.T>` は[内部/ないぶ]ヘッダの[所有権/しょゆうけん]を[持/も]つので、[不要/ふよう]になったら `free` で[解放/かいほう]します。
//:
//: ### [計算量/けいさんりょう]
//: - [時間/じかん][計算量/けいさんりょう]は O(1)、[追加/ついか]の[空間/くうかん][計算量/けいさんりょう]も O(1) です。
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st <Stack<i32>>:
//:         unwrap_ok<Stack<i32>, Diag> new<i32>
//:     if is_empty<i32> st 0 1
//: ```
fn new <.T> <()*>Result<Stack<.T>, Diag>> ():
    let cap <i32> 8
    match alloc_ptr<u8> 12:
        Result::Err _e:
            diag_err<Stack<.T>> diag_out_of_memory "new(header)"
        Result::Ok header:
            match alloc_ptr<.T> mul cap size_of<.T>:
                Result::Err _e:
                    dealloc_ptr<u8> header 12
                    diag_err<Stack<.T>> diag_out_of_memory "new(data)"
                Result::Ok data:
                    let len_ptr <MemPtr<i32>> mem_ptr_wrap mem_ptr_addr header
                    let cap_ptr <MemPtr<i32>> mem_ptr_wrap add mem_ptr_addr header 4
                    let data_ptr_ptr <MemPtr<i32>> mem_ptr_wrap add mem_ptr_addr header 8
                    store_i32 mem_ptr_addr len_ptr 0
                    store_i32 mem_ptr_addr cap_ptr cap
                    store_i32 mem_ptr_addr data_ptr_ptr mem_ptr_addr data
                    ok<Stack<.T>, Diag> Stack header

//: push: 末尾に要素を積む
//:
//: ### [目的/もくてき]
//: - `item` を[末尾/まつび]に[積/つ]み、[更新後/こうしんご]のスタックを[返/かえ]します。
//:
//: ### [実装/じっそう]
//: - [容量/ようりょう]が[足/た]りる[場合/ばあい]は[末尾/まつび]に[直接/ちょくせつ][書/か]き[込/こ]みます。
//: - [容量/ようりょう][不足/ぶそく]なら 2 [倍/ばい]に[拡張/かくちょう]し、`realloc_ptr` でデータ[領域/りょういき]を[移動/いどう]してから[追加/ついか]します。
//:
//: ### [注意/ちゅうい]
//: - [更新後/こうしんご]の `Stack<.T>` を[返/かえ]すので、[呼/よ]び[出/だ]し[側/がわ]で[束縛/そくばく]し[直/なお]す[必要/ひつよう]があります。
//: - [拡張/かくちょう]が[発生/はっせい]した[場合/ばあい]、[内部/ないぶ]データ[領域/りょういき]の[番地/ばんち]は[変/か]わりえます。
//:
//: ### [計算量/けいさんりょう]
//: - [償却/しょうきゃく][時間/じかん][計算量/けいさんりょう]は O(1)、[拡張/かくちょう][発生時/はっせいじ]の[最悪/さいあく][時間/じかん][計算量/けいさんりょう]は O(n) です。
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//:| #import "core/math" as *
//: fn main <()*>i32> ():
//:     let mut st <Stack<i32>>:
//:         unwrap_ok<Stack<i32>, Diag> new<i32>
//:     set st:
//:         push<i32> st 10 |> uwok
//:     if eq len<i32> st 1 0 1
//: ```
fn push <.T> <(Stack<.T>,.T)*>Result<Stack<.T>, Diag>> (stk, item):
    let hdr <MemPtr<u8>> get stk "hdr"
    let len_ptr <MemPtr<i32>> mem_ptr_wrap mem_ptr_addr hdr
    let cap_ptr <MemPtr<i32>> mem_ptr_wrap add mem_ptr_addr hdr 4
    let data_ptr_ptr <MemPtr<i32>> mem_ptr_wrap add mem_ptr_addr hdr 8
    let len <i32> load_i32 mem_ptr_addr len_ptr
    let cap <i32> load_i32 mem_ptr_addr cap_ptr
    let data <MemPtr<.T>> mem_ptr_wrap load_i32 mem_ptr_addr data_ptr_ptr
    if:
        eq len cap
        then:
            let new_cap <i32> mul cap 2
            match realloc_ptr<.T> data mul cap size_of<.T> mul new_cap size_of<.T>:
                Result::Err _e:
                    diag_err<Stack<.T>> diag_out_of_memory "push(realloc_raw)"
                Result::Ok new_data:
                    store_i32 mem_ptr_addr cap_ptr new_cap
                    store_i32 mem_ptr_addr data_ptr_ptr mem_ptr_addr new_data
                    let off <i32> mul len size_of<.T>
                    store<.T> add mem_ptr_addr new_data off item
                    store_i32 mem_ptr_addr len_ptr add len 1
                    ok<Stack<.T>, Diag> Stack hdr
        else:
            let off <i32> mul len size_of<.T>
            store<.T> add mem_ptr_addr data off item
            store_i32 mem_ptr_addr len_ptr add len 1
            ok<Stack<.T>, Diag> Stack hdr

//: pop: 末尾要素を取り出す
//:
//: ### [目的/もくてき]
//: - [末尾/まつび][要素/ようそ]を[取/と]り[出/だ]し、[存在/そんざい]すれば `Option::Some` として[返/かえ]します。
//:
//: ### [実装/じっそう]
//: - `len == 0` なら `Option::None` を[返/かえ]します。
//: - [要素/ようそ]がある[場合/ばあい]は[最後/さいご]の[添字/そえじ]を[計算/けいさん]し、`load` 後に length を 1 [減/へ]らします。
//:
//: ### [注意/ちゅうい]
//: - [返/かえ]り[値/あたい]は `Option<.T>` です。
//: - [空/から]スタックを[異常/いじょう]にせず、`None` で[表/あらわ]します。
//:
//: ### [計算量/けいさんりょう]
//: - [時間/じかん][計算量/けいさんりょう]は O(1) です。
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/option" as *
//:| #import "core/result" as *
//:| #import "core/math" as *
//: fn main <()*>i32> ():
//:     let st <Stack<i32>>:
//:         unwrap_ok<Stack<i32>, Diag> new<i32>
//:         |> push<i32> 10 |> uwok
//:     let p pop<i32> st;
//:     match p:
//:         Option::Some x:
//:             if eq x 10 0 1
//:         Option::None:
//:             1
//: ```
fn pop <.T> <(Stack<.T>)->Option<.T>> (stk):
    let hdr <MemPtr<u8>> get stk "hdr"
    let len_ptr <MemPtr<i32>> mem_ptr_wrap mem_ptr_addr hdr
    let data_ptr_ptr <MemPtr<i32>> mem_ptr_wrap add mem_ptr_addr hdr 8
    let len <i32> load_i32 mem_ptr_addr len_ptr
    if:
        eq len 0
        then:
            none<.T>
        else:
            let new_len <i32> sub len 1
            let data <MemPtr<.T>> mem_ptr_wrap load_i32 mem_ptr_addr data_ptr_ptr
            let off <i32> mul new_len size_of<.T>
            let item <.T> load<.T> add mem_ptr_addr data off
            store_i32 mem_ptr_addr len_ptr new_len
            some<.T> item

//: peek: 末尾要素を覗く
//:
//: ### [目的/もくてき]
//: - [末尾/まつび][要素/ようそ]を[削除/さくじょ]せずに[参照/さんしょう]したいときに[使/つか]います。
//:
//: ### [実装/じっそう]
//: - `pop` と[同様/どうよう]に[最後/さいご]の[添字/そえじ]を[求/もと]めますが、length は[更新/こうしん]しません。
//:
//: ### [注意/ちゅうい]
//: - [返/かえ]り[値/あたい]は `Option<.T>` です。
//: - [空/から]スタックでは `None` を[返/かえ]します。
//:
//: ### [計算量/けいさんりょう]
//: - [時間/じかん][計算量/けいさんりょう]は O(1) です。
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/option" as *
//:| #import "core/result" as *
//:| #import "core/math" as *
//: fn main <()*>i32> ():
//:     let st <Stack<i32>>:
//:         unwrap_ok<Stack<i32>, Diag> new<i32>
//:         |> push<i32> 20 |> uwok
//:     match peek<i32> st:
//:         Option::Some x:
//:             if eq x 20 0 1
//:         Option::None:
//:             1
//: ```
fn peek <.T> <(Stack<.T>)->Option<.T>> (stk):
    let hdr <MemPtr<u8>> get stk "hdr"
    let len_ptr <MemPtr<i32>> mem_ptr_wrap mem_ptr_addr hdr
    let data_ptr_ptr <MemPtr<i32>> mem_ptr_wrap add mem_ptr_addr hdr 8
    let len <i32> load_i32 mem_ptr_addr len_ptr
    if:
        eq len 0
        then:
            none<.T>
        else:
            let data <MemPtr<.T>> mem_ptr_wrap load_i32 mem_ptr_addr data_ptr_ptr
            let last <i32> sub len 1
            let off <i32> mul last size_of<.T>
            let v <.T> load<.T> add mem_ptr_addr data off
            some<.T> v

//: len: 長さを返す
//:
//: ### [目的/もくてき]
//: - [現在/げんざい]の[要素数/ようそすう]を[返/かえ]します。
//:
//: ### [実装/じっそう]
//: - ヘッダ[先頭/せんとう]の length [欄/らん]を[読/よ]むだけです。
//:
//: ### [注意/ちゅうい]
//: - [変更/へんこう]を[伴/ともな]わない[読/よ]み[取/と]り API です。
//:
//: ### [計算量/けいさんりょう]
//: - [時間/じかん][計算量/けいさんりょう]は O(1) です。
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//:| #import "core/math" as *
//: fn main <()*>i32> ():
//:     let mut st <Stack<i32>> unwrap_ok<Stack<i32>, Diag> new<i32>;
//:     set st uwok push<i32> st 1;
//:     set st uwok push<i32> st 2;
//:     if eq len<i32> st 2 0 1
//: ```
fn len <.T> <(Stack<.T>)->i32> (stk):
    stack_len_raw<.T> stk

//: is_empty: 空か判定する
//:
//: ### [目的/もくてき]
//: - スタックが[空/から]かどうかを `bool` で[返/かえ]します。
//:
//: ### [実装/じっそう]
//: - `len` で[要素数/ようそすう]を[得/え]て 0 と[比較/ひかく]します。
//:
//: ### [注意/ちゅうい]
//: - [変更/へんこう]を[伴/ともな]わない[読/よ]み[取/と]り API です。
//:
//: ### [計算量/けいさんりょう]
//: - [時間/じかん][計算量/けいさんりょう]は O(1) です。
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st <Stack<i32>> unwrap_ok<Stack<i32>, Diag> new<i32>;
//:     if is_empty<i32> st 0 1
//: ```
fn is_empty <.T> <(Stack<.T>)->bool> (stk):
    eq len<.T> stk 0

//: clear: すべての要素を削除する
//:
//: ### [目的/もくてき]
//: - [要素数/ようそすう]を 0 に[戻/もど]し、スタックを[空/から]にします。
//:
//: ### [実装/じっそう]
//: - ヘッダの length [欄/らん]だけを書き[換/か]えます。
//:
//: ### [注意/ちゅうい]
//: - [確保/かくほ]ずみの[容量/ようりょう]は[維持/いじ]され、メモリは[解放/かいほう]されません。
//: - [更新後/こうしんご]の `Stack<.T>` を[返/かえ]すので、[呼/よ]び[出/だ]し[側/がわ]で[束縛/そくばく]し[直/なお]します。
//:
//: ### [計算量/けいさんりょう]
//: - [時間/じかん][計算量/けいさんりょう]は O(1) です。
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let mut st <Stack<i32>> unwrap_ok<Stack<i32>, Diag> new<i32>;
//:     set st uwok push<i32> st 9;
//:     set st clear<i32> st;
//:     if is_empty<i32> st 0 1
//: ```
fn clear <.T> <(Stack<.T>)->Stack<.T>> (stk):
    let hdr <MemPtr<u8>> get stk "hdr"
    let len_ptr <MemPtr<i32>> mem_ptr_wrap mem_ptr_addr hdr
    store_i32 mem_ptr_addr len_ptr 0
    Stack hdr

//: free: メモリを解放する
//:
//: ### [目的/もくてき]
//: - `Stack<.T>` が[所有/しょゆう]するデータ[領域/りょういき]とヘッダ[領域/りょういき]を[解放/かいほう]します。
//:
//: ### [実装/じっそう]
//: - capacity からデータ[領域/りょういき]の byte [数/すう]を[計算/けいさん]して `dealloc_ptr<.T>` を[呼/よ]び、[続/つづ]けてヘッダ 12 byte も[解放/かいほう]します。
//:
//: ### [注意/ちゅうい]
//: - [解放後/かいほうご]に `stk` を[再利用/さいりよう]してはいけません。
//: - `Stack<.T>` の[所有権/しょゆうけん]を[消費/しょうひ]する[終端/しゅうたん]操作として[扱/あつか]います。
//:
//: ### [計算量/けいさんりょう]
//: - [時間/じかん][計算量/けいさんりょう]は O(1) です。
//:
//: 使い方:
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/stack" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st <Stack<i32>> unwrap_ok<Stack<i32>, Diag> new<i32>;
//:     free<i32> st;
//:     0
//: ```
fn free <.T> <(Stack<.T>)*>()> (stk):
    let hdr <MemPtr<u8>> get stk "hdr"
    let cap_ptr <MemPtr<i32>> mem_ptr_wrap add mem_ptr_addr hdr 4
    let data_ptr_ptr <MemPtr<i32>> mem_ptr_wrap add mem_ptr_addr hdr 8
    let cap <i32> load_i32 mem_ptr_addr cap_ptr
    let data <MemPtr<.T>> mem_ptr_wrap load_i32 mem_ptr_addr data_ptr_ptr
    let _ <()> uwok dealloc_ptr<.T> data mul cap size_of<.T>
    let _ <()> uwok dealloc_ptr<u8> hdr 12

fn pop_keep <.T> <(Stack<.T>)->Option<.T>> (stk):
    pop<.T> stk

fn peek_keep <.T> <(Stack<.T>)->Option<.T>> (stk):
    peek<.T> stk
