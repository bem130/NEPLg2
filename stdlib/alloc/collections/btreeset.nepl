//: # btreeset
//: [順序付き/じゅんじょつき] set
//:
//: ### [目的/もくてき]
//: - `BTreeSet<.T>` を[提供/ていきょう]し、`new` / `insert` / `contains` / `remove` / `len` / `clear` / `free` の bare 名で[扱/あつか]えるようにします。
//: - [要素/ようそ]の[比較/ひかく]は `Ord` trait に[委譲/いじょう]し、`i32` 固定の collection から[脱却/だっきゃく]します。
//:
//: ### [実装/じっそう]
//: - [名前/なまえ]は `BTreeSet` ですが、[実体/じったい]は[整列済/せいれつず]み key [配列/はいれつ]です。
//: - [検索/けんさく]は lower_bound、[挿入/そうにゅう] / [削除/さくじょ]は shift で[実装/じっそう]します。
//:
//: ### [注意/ちゅうい]
//: - [本物/ほんもの]の B-tree ではありません。
//: - `Ord` impl が[全順序/ぜんじゅんじょ]を[満/み]たすことを[前提/ぜんてい]にします。
//:
//: ### [計算量/けいさんりょう]
//: - `contains` は O(log n)、`insert` / `remove` は O(n) です。

#indent 4

#import "core/mem" as *
#import "core/result" as *
#import "core/field" as field
#import "core/traits/ord" as *
#import "alloc/diag/error" as *

//: ## BTreeSet
//: [順序付き/じゅんじょつき] key [配列/はいれつ]の[本体/ほんたい]
//:
//: ### [目的/もくてき]
//: - key [配列/はいれつ]と[長/なが]さ header を 1 [値/あたい]として[所有/しょゆう]します。
//:
//: ### [注意/ちゅうい]
//: - [本物/ほんもの]の B-tree node [分割/ぶんかつ]は[持/も]たず、lower_bound と shift による[単純/たんじゅん][実装/じっそう]です。
struct BTreeSet<.T>:
    hdr <i32>

fn btreeset_keys_ptr <(i32)->i32> (hdr):
    load_i32 add hdr 8

fn btreeset_key_eq <.T: Ord> <(.T,.T)->bool> (a, b):
    and not ord_lt a b not ord_lt b a

fn btreeset_lower_bound <.T: Ord> <(i32,.T,i32,i32)->i32> (keys, key, low, high):
    if:
        lt low high
        then:
            let mid <i32> div_s add low high 2
            let saved <.T> load<.T> add keys mul mid size_of<.T>
            if:
                ord_lt saved key
                then btreeset_lower_bound<.T> keys key add mid 1 high
                else btreeset_lower_bound<.T> keys key low mid
        else low

fn btreeset_is_at <.T: Ord> <(i32,i32,i32,.T)->bool> (keys, len0, idx, key):
    if:
        lt idx len0
        then btreeset_key_eq<.T> load<.T> add keys mul idx size_of<.T> key
        else false

fn btreeset_grow <.T> <(BTreeSet<.T>)*>Result<BTreeSet<.T>, Diag>> (set0):
    let hdr <i32> field::get set0 "hdr"
    let len0 <i32> load_i32 hdr
    let cap0 <i32> load_i32 add hdr 4
    let keys0 <i32> btreeset_keys_ptr hdr
    let cap1 <i32> mul cap0 2
    let keys1 <i32> alloc_raw mul cap1 size_of<.T>
    if:
        eq keys1 0
        then diag_err<BTreeSet<.T>> diag_out_of_memory "btreeset_grow(keys)"
        else:
            let mut i <i32> 0
            while lt i len0:
                do:
                    store<.T> add keys1 mul i size_of<.T> load<.T> add keys0 mul i size_of<.T>
                    set i add i 1
            dealloc_raw keys0 mul cap0 size_of<.T>
            store_i32 add hdr 4 cap1
            store_i32 add hdr 8 keys1
            ok<BTreeSet<.T>, Diag> set0

//: ## new
//: [空/から]の `BTreeSet<.T>` を[作/つく]る
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/btreeset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <BTreeSet<i32>> unwrap_ok<BTreeSet<i32>, Diag> new<i32>;
//:     if eq len s 0 1 0
//: ```
fn new <.T> <()*>Result<BTreeSet<.T>, Diag>> ():
    let cap <i32> 8
    let keys <i32> alloc_raw mul cap size_of<.T>
    if:
        eq keys 0
        then diag_err<BTreeSet<.T>> diag_out_of_memory "btreeset_new(keys)"
        else:
            let hdr <i32> alloc_raw 12
            if:
                eq hdr 0
                then:
                    dealloc_raw keys mul cap size_of<.T>
                    diag_err<BTreeSet<.T>> diag_out_of_memory "btreeset_new(header)"
                else:
                    store_i32 hdr 0
                    store_i32 add hdr 4 cap
                    store_i32 add hdr 8 keys
                    ok<BTreeSet<.T>, Diag> BTreeSet hdr

//: ## len
//: [要素数/ようそすう]を[返/かえ]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/btreeset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <BTreeSet<i32>>:
//:         unwrap_ok<BTreeSet<i32>, Diag> new<i32>
//:         |> insert 3 |> uwok
//:         |> insert 7 |> uwok;
//:     if eq len s 2 1 0
//: ```
fn len <.T> <(BTreeSet<.T>)->i32> (set0):
    load_i32 field::get set0 "hdr"

//: ## contains
//: key の[存在/そんざい]を[確/たし]かめる
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/btreeset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <BTreeSet<i32>>:
//:         unwrap_ok<BTreeSet<i32>, Diag> new<i32>
//:         |> insert 7 |> uwok;
//:     if contains s 7 1 0
//: ```
fn contains <.T: Ord> <(BTreeSet<.T>,.T)->bool> (set0, key):
    let hdr <i32> field::get set0 "hdr"
    let len0 <i32> load_i32 hdr
    let keys <i32> btreeset_keys_ptr hdr
    let idx <i32> btreeset_lower_bound<.T> keys key 0 len0
    btreeset_is_at<.T> keys len0 idx key

//: ## insert
//: key を[集合/しゅうごう]へ[挿入/そうにゅう]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/btreeset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <BTreeSet<i32>>:
//:         unwrap_ok<BTreeSet<i32>, Diag> new<i32>
//:         |> insert 7 |> uwok
//:         |> insert 3 |> uwok;
//:     if eq len s 2 1 0
//: ```
fn insert <.T: Ord> <(BTreeSet<.T>,.T)*>Result<BTreeSet<.T>, Diag>> (set0, key):
    let hdr0 <i32> field::get set0 "hdr"
    let len_init <i32> load_i32 hdr0
    let cap_init <i32> load_i32 add hdr0 4
    let set1 <BTreeSet<.T>>:
        if:
            eq len_init cap_init
            then unwrap_ok<BTreeSet<.T>, Diag> btreeset_grow<.T> set0
            else set0
    let hdr <i32> field::get set1 "hdr"
    let len0 <i32> load_i32 hdr
    let keys <i32> btreeset_keys_ptr hdr
    let idx <i32> btreeset_lower_bound<.T> keys key 0 len0
    if:
        btreeset_is_at<.T> keys len0 idx key
        then ok<BTreeSet<.T>, Diag> set1
        else:
            let mut i <i32> len0
            while gt i idx:
                do:
                    let from <i32> sub i 1
                    store<.T> add keys mul i size_of<.T> load<.T> add keys mul from size_of<.T>
                    set i from
            store<.T> add keys mul idx size_of<.T> key
            store_i32 hdr add len0 1
            ok<BTreeSet<.T>, Diag> set1

//: ## remove
//: key を[集合/しゅうごう]から[削除/さくじょ]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/btreeset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <BTreeSet<i32>>:
//:         unwrap_ok<BTreeSet<i32>, Diag> new<i32>
//:         |> insert 7 |> uwok
//:         |> remove 7;
//:     if eq len s 0 1 0
//: ```
fn remove <.T: Ord> <(BTreeSet<.T>,.T)*>BTreeSet<.T>> (set0, key):
    let hdr <i32> field::get set0 "hdr"
    let len0 <i32> load_i32 hdr
    let keys <i32> btreeset_keys_ptr hdr
    let idx <i32> btreeset_lower_bound<.T> keys key 0 len0
    if:
        not btreeset_is_at<.T> keys len0 idx key
        then set0
        else:
            let mut i <i32> idx
            while lt i sub len0 1:
                do:
                    let nxt <i32> add i 1
                    store<.T> add keys mul i size_of<.T> load<.T> add keys mul nxt size_of<.T>
                    set i nxt
            store_i32 hdr sub len0 1
            set0

//: ## clear
//: [全要素/ぜんようそ]を[削除/さくじょ]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/btreeset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <BTreeSet<i32>>:
//:         unwrap_ok<BTreeSet<i32>, Diag> new<i32>
//:         |> insert 7 |> uwok
//:         |> clear;
//:     if eq len s 0 1 0
//: ```
fn clear <.T> <(BTreeSet<.T>)*>BTreeSet<.T>> (set0):
    let hdr <i32> field::get set0 "hdr"
    store_i32 hdr 0
    set0

//: ## free
//: [内部/ないぶ]メモリを[解放/かいほう]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/btreeset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <BTreeSet<i32>> unwrap_ok<BTreeSet<i32>, Diag> new<i32>;
//:     free s;
//:     0
//: ```
fn free <.T> <(BTreeSet<.T>)*>()> (set0):
    let hdr <i32> field::get set0 "hdr"
    let cap <i32> load_i32 add hdr 4
    dealloc_raw btreeset_keys_ptr hdr mul cap size_of<.T>
    dealloc_raw hdr 12
