#indent 4

//: # segment_tree
//: [区間和/くかんわ] query と[点更新/てんこうしん]を[扱/あつか]う Segment Tree
//:
//: ### [目的/もくてき]
//: - `SegmentTree` を[提供/ていきょう]し、`new` / `len` / `replace` / `add` / `sum_range` / `free` の bare API で[点更新/てんこうしん]と[区間和/くかんわ] query を[扱/あつか]えるようにします。
//: - Fenwick では[表現/ひょうげん]しにくい[一般区間/いっぱんくかん] query の[土台/どだい]を `alloc/collections` に[揃/そろ]えます。
//:
//: ### [実装/じっそう]
//: - [内部/ないぶ]は `base` を 2 [冪/べき]に[丸/まる]めた full binary tree を[配列/はいれつ]で[保持/ほじ]する iterative segment tree です。
//: - leaf は `[base, base+n)` に[置/お]き、internal node は[子/こ]の[和/わ]を[保持/ほじ]します。
//:
//: ### [注意/ちゅうい]
//: - [現在/げんざい]は `i32` の[加算/かさん] monoid に[固定/こてい]しています。
//: - `new` / `replace` / `add` は `Result` を[返/かえ]します。
//: - `sum_range` は `[l, r)` を[返/かえ]し、[不正/ふせい] range は `Result::Err Diag` です。
//:
//: ### [計算量/けいさんりょう]
//: - `len` は O(1)。
//: - `replace` / `add` / `sum_range` は O(log n)。
//: - `new` / `free` は O(n)。

#import "core/mem" as *
#import "core/math" as *
#import "core/result" as *
#import "core/field" as field
#import "alloc/diag/error" as *

//: ## SegmentTree
//: [長/なが]さと base と[内部配列/ないぶはいれつ]を[所有/しょゆう]する
//:
//: ### [注意/ちゅうい]
//: - `data` は `2 * base` [個/こ]の `i32` を[保持/ほじ]します。
//: - [不要/ふよう]になったら `free` します。
struct SegmentTree:
    n <i32>
    base <i32>
    data <MemPtr<i32>>

fn seg_diag_len <(i32)*>Diag> (n):
    let msg0 <str> concat "segment_tree new invalid length " from_i32 n
    diag_error StdErrorKind::CapacityExceeded msg0

fn seg_diag_index <(str,i32,i32)*>Diag> (op, idx, n):
    let msg0 <str> concat op ": index out of bounds "
    let msg1 <str> concat msg0 from_i32 idx
    let msg2 <str> concat msg1 " for len "
    let msg3 <str> concat msg2 from_i32 n
    diag_error StdErrorKind::IndexOutOfBounds msg3

fn seg_diag_range <(str,i32,i32,i32)*>Diag> (op, l, r, n):
    let msg0 <str> concat op ": invalid range ["
    let msg1 <str> concat msg0 from_i32 l
    let msg2 <str> concat msg1 ", "
    let msg3 <str> concat msg2 from_i32 r
    let msg4 <str> concat msg3 ") for len "
    let msg5 <str> concat msg4 from_i32 n
    diag_error StdErrorKind::IndexOutOfBounds msg5

fn seg_ptr <(MemPtr<i32>,i32)->MemPtr<i32>> (data, idx):
    mem_ptr_wrap add mem_ptr_addr data mul idx 4

fn seg_load <(MemPtr<i32>,i32)->i32> (data, idx):
    match load_i32 seg_ptr data idx:
        Option::Some v:
            v
        Option::None:
            0

fn seg_store <(MemPtr<i32>,i32,i32)->()> (data, idx, value):
    let _ <()> uwok store_i32 seg_ptr data idx value

fn seg_next_pow2 <(i32)->i32> (n):
    let mut x <i32> 1
    while lt x n:
        do:
            set x mul x 2
    x

//: ## new
//: [長/なが]さ `n` の[空/から] Segment Tree を[作/つく]る
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/segment_tree" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st <SegmentTree> unwrap_ok<SegmentTree, Diag> new 5;
//:     if eq len st 5 1 0
//: ```
fn new <(i32)*>Result<SegmentTree, Diag>> (n):
    if:
        lt n 0
        then diag_err<SegmentTree> seg_diag_len n
        else:
            let base <i32> seg_next_pow2 if eq n 0 1 n
            let cells <i32> mul base 2
            match alloc_ptr<i32> mul cells 4:
                Result::Err _e:
                    diag_err<SegmentTree> diag_out_of_memory "segment_tree_new(data)"
                Result::Ok data:
                    let mut i <i32> 0
                    while lt i cells:
                        do:
                            seg_store data i 0
                            set i add i 1
                    ok<SegmentTree, Diag> SegmentTree n base data

//: ## len
//: [保持/ほじ]している[長/なが]さを[返/かえ]す
fn len <(SegmentTree)->i32> (st):
    field::get st "n"

//: ## replace
//: `idx` の[値/あたい]を `value` に[置/お]き[換/か]える
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/segment_tree" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st0 <SegmentTree> unwrap_ok<SegmentTree, Diag> new 4;
//:     let st1 <SegmentTree> unwrap_ok<SegmentTree, Diag> replace st0 1 5;
//:     let total <i32> unwrap_ok<i32, Diag> sum_range st1 0 4;
//:     if eq total 5 1 0
//: ```
fn replace <(SegmentTree,i32,i32)*>Result<SegmentTree, Diag>> (st, idx, value):
    let mem <i32> alloc_raw size_of<SegmentTree>
    store<SegmentTree> mem st
    let n <i32> get load<SegmentTree> mem "n"
    let base <i32> get load<SegmentTree> mem "base"
    let data <MemPtr<i32>> get load<SegmentTree> mem "data"
    if:
        and le 0 idx lt idx n
        then:
            let mut pos <i32> add base idx
            seg_store data pos value
            while lt 1 pos:
                do:
                    set pos div_s pos 2
                    let left <i32> mul pos 2
                    let right <i32> add left 1
                    seg_store data pos add seg_load data left seg_load data right
            let out <SegmentTree> load<SegmentTree> mem
            dealloc_raw mem size_of<SegmentTree>
            ok<SegmentTree, Diag> out
        else:
            let d <Diag> seg_diag_index "segment_tree_replace" idx n
            dealloc_raw mem size_of<SegmentTree>
            err<SegmentTree, Diag> d

//: ## add
//: `idx` に `delta` を[加算/かさん]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/segment_tree" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st <SegmentTree>:
//:         unwrap_ok<SegmentTree, Diag> new 4
//:         |> add 0 2 |> uwok
//:         |> add 3 5 |> uwok
//:     let total <i32> unwrap_ok<i32, Diag> sum_range st 0 4;
//:     if eq total 7 1 0
//: ```
fn add <(SegmentTree,i32,i32)*>Result<SegmentTree, Diag>> (st, idx, delta):
    let mem <i32> alloc_raw size_of<SegmentTree>
    store<SegmentTree> mem st
    let n <i32> get load<SegmentTree> mem "n"
    let base <i32> get load<SegmentTree> mem "base"
    let data <MemPtr<i32>> get load<SegmentTree> mem "data"
    if:
        and le 0 idx lt idx n
        then:
            let leaf <i32> add base idx
            let cur <i32> seg_load data leaf
            let mut pos <i32> leaf
            seg_store data pos add cur delta
            while lt 1 pos:
                do:
                    set pos div_s pos 2
                    let left <i32> mul pos 2
                    let right <i32> add left 1
                    seg_store data pos add seg_load data left seg_load data right
            let out <SegmentTree> load<SegmentTree> mem
            dealloc_raw mem size_of<SegmentTree>
            ok<SegmentTree, Diag> out
        else:
            let d <Diag> seg_diag_index "segment_tree_add" idx n
            dealloc_raw mem size_of<SegmentTree>
            err<SegmentTree, Diag> d

//: ## sum_range
//: [区間/くかん] `[l, r)` の[和/わ]を[返/かえ]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/segment_tree" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st <SegmentTree>:
//:         unwrap_ok<SegmentTree, Diag> new 5
//:         |> replace 0 1 |> uwok
//:         |> replace 1 2 |> uwok
//:         |> replace 2 3 |> uwok
//:         |> replace 3 4 |> uwok
//:     let total <i32> unwrap_ok<i32, Diag> sum_range st 1 4;
//:     if eq total 9 1 0
//: ```
fn sum_range <(SegmentTree,i32,i32)*>Result<i32, Diag>> (st, l, r):
    let mem <i32> alloc_raw size_of<SegmentTree>
    store<SegmentTree> mem st
    let n <i32> get load<SegmentTree> mem "n"
    let base <i32> get load<SegmentTree> mem "base"
    let data <MemPtr<i32>> get load<SegmentTree> mem "data"
    if:
        and and le 0 l le l r le r n
        then:
            let mut left <i32> add base l
            let mut right <i32> add base r
            let mut acc_l <i32> 0
            let mut acc_r <i32> 0
            while lt left right:
                do:
                    if:
                        eq rem_s left 2 1
                        then:
                            set acc_l add acc_l seg_load data left
                            set left add left 1
                        else:
                            ()
                    if:
                        eq rem_s right 2 1
                        then:
                            set right sub right 1
                            set acc_r add seg_load data right acc_r
                        else:
                            ()
                    set left div_s left 2
                    set right div_s right 2
            dealloc_raw mem size_of<SegmentTree>
            ok<i32, Diag> add acc_l acc_r
        else:
            let d <Diag> seg_diag_range "segment_tree_sum_range" l r n
            dealloc_raw mem size_of<SegmentTree>
            err<i32, Diag> d

//: ## free
//: [内部配列/ないぶはいれつ]を[解放/かいほう]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/segment_tree" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let st <SegmentTree> unwrap_ok<SegmentTree, Diag> new 3;
//:     free st;
//:     0
//: ```
fn free <(SegmentTree)->()> (st):
    let mem <i32> alloc_raw size_of<SegmentTree>
    store<SegmentTree> mem st
    let base <i32> get load<SegmentTree> mem "base"
    let data <MemPtr<i32>> get load<SegmentTree> mem "data"
    let _ <()> uwok dealloc_ptr<i32> data mul mul base 2 4
    dealloc_raw mem size_of<SegmentTree>
