#indent 4

//: # bitset
//: [整数/せいすう] index に[対/たい]する bitset
//:
//: ### [目的/もくてき]
//: - `BitSet` を[提供/ていきょう]し、`new` / `len` / `contains` / `insert` / `remove` / `clear` / `fill` / `free` の bare API で bit [集合/しゅうごう]を[扱/あつか]えるようにします。
//: - [固定長/こていちょう]の membership structure を `alloc/collections` に[揃/そろ]え、`BloomFilter` と[違/ちが]って false positive のない[正確/せいかく]な[判定/はんてい]を[標準/ひょうじゅん]で[扱/あつか]えるようにします。
//:
//: ### [実装/じっそう]
//: - [内部/ないぶ]は `[nbits, nbytes, bits ptr]` を[持/も]つ owner struct です。
//: - bit [列/れつ]は byte [配列/はいれつ]として[確保/かくほ]し、index から byte offset と mask を[計算/けいさん]して[読書/よみか]きします。
//: - `clear` / `fill` は[全領域/ぜんりょういき]を[線形/せんけい]に[初期化/しょきか]します。
//:
//: ### [注意/ちゅうい]
//: - [有効/ゆうこう] index [範囲/はんい]は `[0, len)` です。
//: - `insert` / `remove` / `contains` は[範囲外/はんいがい] index に[対/たい]して `Result::Err Diag` を[返/かえ]します。
//: - `len` は set bit [数/すう]ではなく、[保持/ほじ]できる bit [長/ちょう]を[返/かえ]します。
//:
//: ### [計算量/けいさんりょう]
//: - `len` / `contains` / `insert` / `remove` は O(1) です。
//: - `clear` / `fill` は byte [長/ちょう]を m として O(m) です。

#import "core/mem" as *
#import "core/math" as *
#import "core/result" as *
#import "core/field" as field
#import "alloc/diag/error" as *

//: ## BitSet
//: bit [配列/はいれつ]を[所有/しょゆう]する fixed-length set
//:
//: ### [目的/もくてき]
//: - bit [長/ちょう]と byte [長/ちょう]と data pointer を 1 [値/あたい]として[受/う]け[渡/わた]せるようにします。
//:
//: ### [注意/ちゅうい]
//: - `free` しないかぎり[内部/ないぶ] byte [配列/はいれつ]の[所有権/しょゆうけん]を[保持/ほじ]します。
struct BitSet:
    nbits <i32>
    nbytes <i32>
    bits <MemPtr<u8>>

fn bitset_invalid_len_diag <(i32)*>Diag> (nbits):
    let msg0 <str> concat "bitset new invalid bit length " from_i32 nbits
    diag_error StdErrorKind::CapacityExceeded msg0

fn bitset_index_diag <(str,i32,i32)*>Diag> (who, idx, nbits):
    let msg0 <str> concat who " index "
    let msg1 <str> concat msg0 from_i32 idx
    let msg2 <str> concat msg1 " out of range for len "
    let msg3 <str> concat msg2 from_i32 nbits
    diag_error StdErrorKind::IndexOutOfBounds msg3

fn bitset_byte_index <(i32)->i32> (bit_idx):
    div_s bit_idx 8

fn bitset_mask <(i32)->i32> (bit_idx):
    shl 1 rem_s bit_idx 8

fn bitset_ptr_at <(MemPtr<u8>,i32)->MemPtr<u8>> (bits, bit_idx):
    mem_ptr_wrap add mem_ptr_addr bits bitset_byte_index bit_idx

fn bitset_valid_index <(i32,i32)->bool> (idx, nbits):
    and le 0 idx lt idx nbits

fn bitset_fill_bytes <(MemPtr<u8>,i32,i32)->()> (bits, nbytes, byte_value):
    let mut i <i32> 0
    while lt i nbytes:
        do:
            let ptr <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr bits i
            store_u8 mem_ptr_addr ptr byte_value
            set i add i 1

//: ## new
//: [空/から] bitset を[作/つく]る
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bitset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bs <BitSet> unwrap_ok<BitSet, Diag> new 64;
//:     if eq len bs 64 1 0
//: ```
fn new <(i32)*>Result<BitSet, Diag>> (nbits):
    if:
        le nbits 0
        then:
            diag_err<BitSet> bitset_invalid_len_diag nbits
        else:
            let nbytes <i32> div_s add nbits 7 8
            match alloc_ptr<u8> nbytes:
                Result::Err _e:
                    diag_err<BitSet> diag_out_of_memory "bitset_new(bits)"
                Result::Ok bits:
                    bitset_fill_bytes bits nbytes 0
                    ok<BitSet, Diag> BitSet nbits nbytes bits

//: ## len
//: [保持可能/ほじかのう]な bit [長/ちょう]を[返/かえ]す
fn len <(BitSet)->i32> (bs):
    field::get bs "nbits"

//: ## contains
//: bit が[立/た]っているかを[返/かえ]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bitset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bs <BitSet>:
//:         unwrap_ok<BitSet, Diag> new 32
//:         |> insert 5 |> uwok
//:     let ok <bool> unwrap_ok<bool, Diag> contains bs 5;
//:     if ok 1 0
//: ```
fn contains <(BitSet,i32)*>Result<bool, Diag>> (bs, idx):
    let nbits <i32> field::get bs "nbits"
    if:
        bitset_valid_index idx nbits
        then:
            let bits <MemPtr<u8>> field::get bs "bits"
            let ptr <MemPtr<u8>> bitset_ptr_at bits idx
            let mask <i32> bitset_mask idx
            let cur <i32> load_u8 mem_ptr_addr ptr
            ok<bool, Diag> ne and cur mask 0
        else:
            diag_err<bool> bitset_index_diag "bitset_contains" idx nbits

//: ## insert
//: bit を 1 に[設定/せってい]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bitset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bs <BitSet> unwrap_ok<BitSet, Diag> new 16;
//:     let bs1 <BitSet> unwrap_ok<BitSet, Diag> insert bs 3;
//:     let ok <bool> unwrap_ok<bool, Diag> contains bs1 3;
//:     if ok 1 0
//: ```
fn insert <(BitSet,i32)*>Result<BitSet, Diag>> (bs, idx):
    let nbits <i32> field::get bs "nbits"
    if:
        bitset_valid_index idx nbits
        then:
            let bits <MemPtr<u8>> field::get bs "bits"
            let ptr <MemPtr<u8>> bitset_ptr_at bits idx
            let mask <i32> bitset_mask idx
            let cur <i32> load_u8 mem_ptr_addr ptr
            store_u8 mem_ptr_addr ptr or cur mask
            ok<BitSet, Diag> bs
        else:
            diag_err<BitSet> bitset_index_diag "bitset_insert" idx nbits

//: ## remove
//: bit を 0 に[戻/もど]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bitset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bs <BitSet>:
//:         unwrap_ok<BitSet, Diag> new 16
//:         |> insert 3 |> uwok
//:         |> remove 3 |> uwok
//:     let ok <bool> unwrap_ok<bool, Diag> contains bs 3;
//:     if not ok 1 0
//: ```
fn remove <(BitSet,i32)*>Result<BitSet, Diag>> (bs, idx):
    let nbits <i32> field::get bs "nbits"
    if:
        bitset_valid_index idx nbits
        then:
            let bits <MemPtr<u8>> field::get bs "bits"
            let ptr <MemPtr<u8>> bitset_ptr_at bits idx
            let mask <i32> bitset_mask idx
            let cur <i32> load_u8 mem_ptr_addr ptr
            store_u8 mem_ptr_addr ptr and cur xor mask 255
            ok<BitSet, Diag> bs
        else:
            diag_err<BitSet> bitset_index_diag "bitset_remove" idx nbits

//: ## clear
//: [全/すべ]ての bit を 0 に[戻/もど]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bitset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bs <BitSet>:
//:         unwrap_ok<BitSet, Diag> new 16
//:         |> insert 2 |> uwok
//:         |> clear
//:     let ok <bool> unwrap_ok<bool, Diag> contains bs 2;
//:     if not ok 1 0
//: ```
fn clear <(BitSet)->BitSet> (bs):
    let nbytes <i32> field::get bs "nbytes"
    let bits <MemPtr<u8>> field::get bs "bits"
    bitset_fill_bytes bits nbytes 0
    bs

//: ## fill
//: [全/すべ]ての bit を 1 に[設定/せってい]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bitset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bs <BitSet> unwrap_ok<BitSet, Diag> new 10;
//:     let bs1 <BitSet> fill bs;
//:     let ok <bool> unwrap_ok<bool, Diag> contains bs1 9;
//:     if ok 1 0
//: ```
fn fill <(BitSet)->BitSet> (bs):
    let nbytes <i32> field::get bs "nbytes"
    let bits <MemPtr<u8>> field::get bs "bits"
    bitset_fill_bytes bits nbytes 255
    bs

//: ## free
//: [内部/ないぶ] byte [配列/はいれつ]を[解放/かいほう]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/bitset" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let bs <BitSet> unwrap_ok<BitSet, Diag> new 16;
//:     free bs
//:     0
//: ```
fn free <(BitSet)->()> (bs):
    let bits <MemPtr<u8>> field::get bs "bits"
    let nbytes <i32> field::get bs "nbytes"
    let _ <()> uwok dealloc_ptr<u8> bits nbytes
