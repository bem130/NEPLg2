#indent 4

//: # adjacency_matrix
//: [有向/ゆうこう] graph を bit matrix で[表/あらわ]す collection
//:
//: ### [目的/もくてき]
//: - `AdjacencyMatrix` を[提供/ていきょう]し、`new` / `len` / `contains` / `insert` / `remove` / `clear` / `free` の bare API で[隣接行列/りんせつぎょうれつ]を[扱/あつか]えるようにします。
//: - graph [表現/ひょうげん]として `alloc/collections` に[固定長/こていちょう] edge set を[揃/そろ]え、`contains u v` を O(1) で[判定/はんてい]できるようにします。
//:
//: ### [実装/じっそう]
//: - [内部/ないぶ]は `[nverts, nbytes, bits ptr]` を[持/も]つ owner struct です。
//: - `(from, to)` を `from * nverts + to` の bit index に[写像/しゃぞう]し、byte [配列/はいれつ]へ[詰/つ]めて[保持/ほじ]します。
//: - `clear` は[全領域/ぜんりょういき]を 0 で[初期化/しょきか]します。
//:
//: ### [注意/ちゅうい]
//: - [頂点/ちょうてん] index の[有効範囲/ゆうこうはんい]は `[0, len)` です。
//: - `insert` / `remove` / `contains` は[範囲外/はんいがい] index に[対/たい]して `Result::Err Diag` を[返/かえ]します。
//: - [無向/むこう] graph として[使/つか]うときは、`insert g u v` と `insert g v u` を[両方/りょうほう] [行/おこな]ってください。
//:
//: ### [計算量/けいさんりょう]
//: - `len` / `contains` / `insert` / `remove` は O(1) です。
//: - `new` / `clear` / `free` は bit matrix byte [長/ちょう]を m として O(m) です。

#import "core/mem" as *
#import "core/math" as *
#import "core/result" as *
#import "core/field" as field
#import "alloc/diag/error" as *

//: ## AdjacencyMatrix
//: [隣接行列/りんせつぎょうれつ] byte [配列/はいれつ]を[所有/しょゆう]する graph container
//:
//: ### [目的/もくてき]
//: - [頂点数/ちょうてんすう]と byte [長/ちょう]と data pointer を 1 [値/あたい]として[受/う]け[渡/わた]せるようにします。
//:
//: ### [注意/ちゅうい]
//: - `free` しないかぎり[内部/ないぶ] byte [配列/はいれつ]の[所有権/しょゆうけん]を[保持/ほじ]します。
struct AdjacencyMatrix:
    nverts <i32>
    nbytes <i32>
    bits <MemPtr<u8>>

fn adjacency_matrix_invalid_len_diag <(i32)*>Diag> (nverts):
    let msg0 <str> concat "adjacency_matrix new invalid vertex length " from_i32 nverts
    diag_error StdErrorKind::CapacityExceeded msg0

fn adjacency_matrix_vertex_diag <(str,i32,i32)*>Diag> (who, idx, nverts):
    let msg0 <str> concat who " vertex "
    let msg1 <str> concat msg0 from_i32 idx
    let msg2 <str> concat msg1 " out of range for len "
    let msg3 <str> concat msg2 from_i32 nverts
    diag_error StdErrorKind::IndexOutOfBounds msg3

fn adjacency_matrix_bit_index <(i32,i32,i32)->i32> (nverts, from, to):
    add mul from nverts to

fn adjacency_matrix_byte_index <(i32)->i32> (bit_idx):
    div_s bit_idx 8

fn adjacency_matrix_mask <(i32)->i32> (bit_idx):
    shl 1 rem_s bit_idx 8

fn adjacency_matrix_ptr_at <(MemPtr<u8>,i32)->MemPtr<u8>> (bits, bit_idx):
    mem_ptr_wrap add mem_ptr_addr bits adjacency_matrix_byte_index bit_idx

fn adjacency_matrix_valid_vertex <(i32,i32)->bool> (idx, nverts):
    and le 0 idx lt idx nverts

fn adjacency_matrix_valid_edge <(i32,i32,i32)->bool> (nverts, from, to):
    and adjacency_matrix_valid_vertex from nverts adjacency_matrix_valid_vertex to nverts

fn adjacency_matrix_fill_bytes <(MemPtr<u8>,i32,i32)->()> (bits, nbytes, byte_value):
    let mut i <i32> 0
    while lt i nbytes:
        do:
            let ptr <MemPtr<u8>> mem_ptr_wrap add mem_ptr_addr bits i
            store_u8 mem_ptr_addr ptr byte_value
            set i add i 1

//: ## new
//: [空/から]の[隣接行列/りんせつぎょうれつ]を[作/つく]る
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/adjacency_matrix" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let g <AdjacencyMatrix> unwrap_ok<AdjacencyMatrix, Diag> new 5;
//:     if eq len g 5 1 0
//: ```
fn new <(i32)*>Result<AdjacencyMatrix, Diag>> (nverts):
    if:
        le nverts 0
        then:
            diag_err<AdjacencyMatrix> adjacency_matrix_invalid_len_diag nverts
        else:
            let nbits <i32> mul nverts nverts
            let nbytes <i32> div_s add nbits 7 8
            match alloc_ptr<u8> nbytes:
                Result::Err _e:
                    diag_err<AdjacencyMatrix> diag_out_of_memory "adjacency_matrix_new(bits)"
                Result::Ok bits:
                    adjacency_matrix_fill_bytes bits nbytes 0
                    ok<AdjacencyMatrix, Diag> AdjacencyMatrix nverts nbytes bits

//: ## len
//: [頂点数/ちょうてんすう]を[返/かえ]す
fn len <(AdjacencyMatrix)->i32> (g):
    field::get g "nverts"

//: ## contains
//: edge の[有無/うむ]を[返/かえ]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/adjacency_matrix" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let g <AdjacencyMatrix>:
//:         unwrap_ok<AdjacencyMatrix, Diag> new 4
//:         |> insert 1 3 |> uwok
//:     let ok <bool> unwrap_ok<bool, Diag> contains g 1 3;
//:     if ok 1 0
//: ```
fn contains <(AdjacencyMatrix,i32,i32)*>Result<bool, Diag>> (g, from, to):
    let nverts <i32> field::get g "nverts"
    if:
        adjacency_matrix_valid_edge nverts from to
        then:
            let bits <MemPtr<u8>> field::get g "bits"
            let bit_idx <i32> adjacency_matrix_bit_index nverts from to
            let ptr <MemPtr<u8>> adjacency_matrix_ptr_at bits bit_idx
            let mask <i32> adjacency_matrix_mask bit_idx
            let cur <i32> load_u8 mem_ptr_addr ptr
            ok<bool, Diag> ne and cur mask 0
        else:
            if:
                not adjacency_matrix_valid_vertex from nverts
                then:
                    diag_err<bool> adjacency_matrix_vertex_diag "adjacency_matrix_contains" from nverts
                else:
                    diag_err<bool> adjacency_matrix_vertex_diag "adjacency_matrix_contains" to nverts

//: ## insert
//: directed edge を 1 に[設定/せってい]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/adjacency_matrix" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let g <AdjacencyMatrix> unwrap_ok<AdjacencyMatrix, Diag> new 4;
//:     let g1 <AdjacencyMatrix> unwrap_ok<AdjacencyMatrix, Diag> insert g 2 0;
//:     let ok <bool> unwrap_ok<bool, Diag> contains g1 2 0;
//:     if ok 1 0
//: ```
fn insert <(AdjacencyMatrix,i32,i32)*>Result<AdjacencyMatrix, Diag>> (g, from, to):
    let nverts <i32> field::get g "nverts"
    if:
        adjacency_matrix_valid_edge nverts from to
        then:
            let bits <MemPtr<u8>> field::get g "bits"
            let bit_idx <i32> adjacency_matrix_bit_index nverts from to
            let ptr <MemPtr<u8>> adjacency_matrix_ptr_at bits bit_idx
            let mask <i32> adjacency_matrix_mask bit_idx
            let cur <i32> load_u8 mem_ptr_addr ptr
            store_u8 mem_ptr_addr ptr or cur mask
            ok<AdjacencyMatrix, Diag> g
        else:
            if:
                not adjacency_matrix_valid_vertex from nverts
                then:
                    diag_err<AdjacencyMatrix> adjacency_matrix_vertex_diag "adjacency_matrix_insert" from nverts
                else:
                    diag_err<AdjacencyMatrix> adjacency_matrix_vertex_diag "adjacency_matrix_insert" to nverts

//: ## remove
//: directed edge を 0 に[戻/もど]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/adjacency_matrix" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let g <AdjacencyMatrix>:
//:         unwrap_ok<AdjacencyMatrix, Diag> new 4
//:         |> insert 2 0 |> uwok
//:         |> remove 2 0 |> uwok
//:     let ok <bool> unwrap_ok<bool, Diag> contains g 2 0;
//:     if not ok 1 0
//: ```
fn remove <(AdjacencyMatrix,i32,i32)*>Result<AdjacencyMatrix, Diag>> (g, from, to):
    let nverts <i32> field::get g "nverts"
    if:
        adjacency_matrix_valid_edge nverts from to
        then:
            let bits <MemPtr<u8>> field::get g "bits"
            let bit_idx <i32> adjacency_matrix_bit_index nverts from to
            let ptr <MemPtr<u8>> adjacency_matrix_ptr_at bits bit_idx
            let mask <i32> adjacency_matrix_mask bit_idx
            let cur <i32> load_u8 mem_ptr_addr ptr
            store_u8 mem_ptr_addr ptr and cur xor mask 255
            ok<AdjacencyMatrix, Diag> g
        else:
            if:
                not adjacency_matrix_valid_vertex from nverts
                then:
                    diag_err<AdjacencyMatrix> adjacency_matrix_vertex_diag "adjacency_matrix_remove" from nverts
                else:
                    diag_err<AdjacencyMatrix> adjacency_matrix_vertex_diag "adjacency_matrix_remove" to nverts

//: ## clear
//: [全/すべ]ての edge を 0 に[戻/もど]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/adjacency_matrix" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let g <AdjacencyMatrix>:
//:         unwrap_ok<AdjacencyMatrix, Diag> new 4
//:         |> insert 0 1 |> uwok
//:         |> clear
//:     let ok <bool> unwrap_ok<bool, Diag> contains g 0 1;
//:     if not ok 1 0
//: ```
fn clear <(AdjacencyMatrix)->AdjacencyMatrix> (g):
    let nbytes <i32> field::get g "nbytes"
    let bits <MemPtr<u8>> field::get g "bits"
    adjacency_matrix_fill_bytes bits nbytes 0
    g

//: ## free
//: [内部/ないぶ] byte [配列/はいれつ]を[解放/かいほう]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/adjacency_matrix" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let g <AdjacencyMatrix> unwrap_ok<AdjacencyMatrix, Diag> new 3;
//:     free g
//:     0
//: ```
fn free <(AdjacencyMatrix)->()> (g):
    let nbytes <i32> field::get g "nbytes"
    let bits <MemPtr<u8>> field::get g "bits"
    let _ <()> uwok dealloc_ptr<u8> bits nbytes
