#indent 4

//: # sparse_set
//: dense/sparse [配列/はいれつ]で[実装/じっそう]した integer set
//:
//: ### [目的/もくてき]
//: - `SparseSet` を[提供/ていきょう]し、`new` / `len` / `universe_len` / `contains` / `insert` / `remove` / `clear` / `free` の bare API で integer set を[扱/あつか]えるようにします。
//: - `[0, n)` の[範囲/はんい]に[収/おさ]まる整数に[対/たい]して、membership と insert / remove を O(1) で[行/おこな]える set を `alloc/collections` に[揃/そろ]えます。
//:
//: ### [実装/じっそう]
//: - `dense[len]` に[現/げん]在の[要素/ようそ]を[詰/つ]め、`sparse[value]` に dense [上/じょう]の[位置/いち]を[記録/きろく]します。
//: - `contains` は `idx = sparse[value]` を[読/よ]み、`idx < len` かつ `dense[idx] == value` で membership を[判定/はんてい]します。
//: - `remove` は[末尾/まつび]の[要素/ようそ]を[削除位置/さくじょいち]へ[詰/つ]めて O(1) で[維持/いじ]します。
//:
//: ### [注意/ちゅうい]
//: - [扱/あつか]える key は `[0, universe_len)` に[限/かぎ]られます。
//: - `clear` は `len = 0` に[戻/もど]すだけで、`sparse` [配列/はいれつ]の[過去値/かこち]は[消/け]しません。membership [判定/はんてい]は `len` と `dense` の[両方/りょうほう]で[検証/けんしょう]するため[安全/あんぜん]です。
//:
//: ### [計算量/けいさんりょう]
//: - `len` / `universe_len` / `contains` は O(1) です。
//: - `insert` / `remove` / `clear` は O(1) です。
//: - `new` / `free` は O(n) です。

#import "core/mem" as *
#import "core/math" as *
#import "core/result" as *
#import "core/field" as field
#import "alloc/diag/error" as *

//: ## SparseSet
//: header が dense/sparse [配列/はいれつ]を[指/さ]す integer set
//:
//: ### [目的/もくてき]
//: - header pointer 1 [本/ほん]だけを[所有/しょゆう]し、dense/sparse [配列/はいれつ]と active [要素数/ようそすう]を[受/う]け[渡/わた]ししやすくします。
//:
//: ### [注意/ちゅうい]
//: - header には `[n, len0, dense_ptr, sparse_ptr]` を i32 で[格納/かくのう]します。
//: - [不要/ふよう]になったら `free` で header / dense / sparse をまとめて[解放/かいほう]します。
struct SparseSet:
    hdr <i32>

fn sparse_set_diag_len <(i32)*>Diag> (n):
    let msg0 <str> concat "sparse_set new invalid length " from_i32 n
    diag_error StdErrorKind::CapacityExceeded msg0

fn sparse_set_diag_index <(str,i32,i32)*>Diag> (op, idx, n):
    let msg0 <str> concat op ": index out of bounds "
    let msg1 <str> concat msg0 from_i32 idx
    let msg2 <str> concat msg1 " for universe_len "
    let msg3 <str> concat msg2 from_i32 n
    diag_error StdErrorKind::IndexOutOfBounds msg3

fn sparse_set_valid_index <(i32,i32)->bool> (idx, n):
    and le 0 idx lt idx n

fn sparse_set_slot_ptr <(MemPtr<i32>,i32)->MemPtr<i32>> (base, idx):
    mem_ptr_wrap add mem_ptr_addr base mul idx 4

fn sparse_set_load <(MemPtr<i32>,i32)->i32> (base, idx):
    match load_i32 sparse_set_slot_ptr base idx:
        Option::Some v:
            v
        Option::None:
            0

fn sparse_set_store <(MemPtr<i32>,i32,i32)->()> (base, idx, value):
    let _ <()> uwok store_i32 sparse_set_slot_ptr base idx value

fn sparse_set_contains_raw <(i32,MemPtr<i32>,MemPtr<i32>,i32,i32)->bool> (n, dense, sparse, len0, value):
    if:
        not sparse_set_valid_index value n
        then false
        else:
            let idx <i32> sparse_set_load sparse value
            if:
                and le 0 idx lt idx len0
                then eq sparse_set_load dense idx value
                else false

fn sparse_set_hdr_n_ptr <(i32)->MemPtr<i32>> (hdr):
    mem_ptr_wrap hdr

fn sparse_set_hdr_len0_ptr <(i32)->MemPtr<i32>> (hdr):
    mem_ptr_wrap add hdr 4

fn sparse_set_hdr_dense_ptr_ptr <(i32)->MemPtr<i32>> (hdr):
    mem_ptr_wrap add hdr 8

fn sparse_set_hdr_sparse_ptr_ptr <(i32)->MemPtr<i32>> (hdr):
    mem_ptr_wrap add hdr 12

fn sparse_set_hdr_n <(i32)->i32> (hdr):
    match load_i32 sparse_set_hdr_n_ptr hdr:
        Option::Some v:
            v
        Option::None:
            0

fn sparse_set_hdr_len0 <(i32)->i32> (hdr):
    match load_i32 sparse_set_hdr_len0_ptr hdr:
        Option::Some v:
            v
        Option::None:
            0

fn sparse_set_hdr_dense <(i32)->MemPtr<i32>> (hdr):
    match load_i32 sparse_set_hdr_dense_ptr_ptr hdr:
        Option::Some raw:
            mem_ptr_wrap raw
        Option::None:
            mem_ptr_wrap 0

fn sparse_set_hdr_sparse <(i32)->MemPtr<i32>> (hdr):
    match load_i32 sparse_set_hdr_sparse_ptr_ptr hdr:
        Option::Some raw:
            mem_ptr_wrap raw
        Option::None:
            mem_ptr_wrap 0

fn sparse_set_hdr_set_n <(i32,i32)->()> (hdr, n):
    let _ <()> uwok store_i32 sparse_set_hdr_n_ptr hdr n

fn sparse_set_hdr_set_len0 <(i32,i32)->()> (hdr, len0):
    let _ <()> uwok store_i32 sparse_set_hdr_len0_ptr hdr len0

fn sparse_set_hdr_set_dense <(i32,MemPtr<i32>)->()> (hdr, dense):
    let _ <()> uwok store_i32 sparse_set_hdr_dense_ptr_ptr hdr mem_ptr_addr dense

fn sparse_set_hdr_set_sparse <(i32,MemPtr<i32>)->()> (hdr, sparse):
    let _ <()> uwok store_i32 sparse_set_hdr_sparse_ptr_ptr hdr mem_ptr_addr sparse

//: ## new
//: domain `[0, n)` の[空/から] set を[作/つく]る
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/sparse_set" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <SparseSet> unwrap_ok<SparseSet, Diag> new 8;
//:     if eq len s 0 1 0
//: ```
fn new <(i32)*>Result<SparseSet, Diag>> (n):
    if:
        lt n 0
        then diag_err<SparseSet> sparse_set_diag_len n
        else:
            match alloc_ptr<u8> 16:
                Result::Err _e:
                    diag_err<SparseSet> diag_out_of_memory "sparse_set_new(hdr)"
                Result::Ok hdr:
                    match alloc_ptr<i32> mul n 4:
                        Result::Err _e:
                            let _ <()> uwok dealloc_ptr<u8> hdr 16
                            diag_err<SparseSet> diag_out_of_memory "sparse_set_new(dense)"
                        Result::Ok dense:
                            match alloc_ptr<i32> mul n 4:
                                Result::Err _e:
                                    let _ <()> uwok dealloc_ptr<i32> dense mul n 4
                                    let _ <()> uwok dealloc_ptr<u8> hdr 16
                                    diag_err<SparseSet> diag_out_of_memory "sparse_set_new(sparse)"
                                Result::Ok sparse:
                                    let hdr_raw <i32> mem_ptr_addr hdr
                                    let mut i <i32> 0
                                    while lt i n:
                                        do:
                                            sparse_set_store dense i 0
                                            sparse_set_store sparse i 0
                                            set i add i 1
                                    sparse_set_hdr_set_n hdr_raw n
                                    sparse_set_hdr_set_len0 hdr_raw 0
                                    sparse_set_hdr_set_dense hdr_raw dense
                                    sparse_set_hdr_set_sparse hdr_raw sparse
                                    ok<SparseSet, Diag> SparseSet hdr_raw

//: ## len
//: [現/げん]在[入/はい]っている[要素数/ようそすう]を[返/かえ]す
fn len <(SparseSet)->i32> (s):
    sparse_set_hdr_len0 field::get s "hdr"

//: ## universe_len
//: [扱/あつか]える整数 domain の[長/なが]さを[返/かえ]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/sparse_set" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <SparseSet> unwrap_ok<SparseSet, Diag> new 8;
//:     if eq universe_len s 8 1 0
//: ```
fn universe_len <(SparseSet)->i32> (s):
    sparse_set_hdr_n field::get s "hdr"

//: ## contains
//: value が[含/ふく]まれているかを[返/かえ]す
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/sparse_set" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <SparseSet>:
//:         unwrap_ok<SparseSet, Diag> new 8
//:         |> insert 3 |> uwok
//:     let ok <bool> unwrap_ok<bool, Diag> contains s 3;
//:     if ok 1 0
//: ```
fn contains <(SparseSet,i32)*>Result<bool, Diag>> (s, value):
    let hdr <i32> field::get s "hdr"
    let n <i32> sparse_set_hdr_n hdr
    let len0 <i32> sparse_set_hdr_len0 hdr
    let dense <MemPtr<i32>> sparse_set_hdr_dense hdr
    let sparse <MemPtr<i32>> sparse_set_hdr_sparse hdr
    if:
        sparse_set_valid_index value n
        then:
            ok<bool, Diag> sparse_set_contains_raw n dense sparse len0 value
        else:
            let d <Diag> sparse_set_diag_index "sparse_set_contains" value n
            err<bool, Diag> d

//: ## insert
//: value を 1 [個/こ][追加/ついか]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/sparse_set" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <SparseSet>:
//:         unwrap_ok<SparseSet, Diag> new 8
//:         |> insert 3 |> uwok
//:         |> insert 5 |> uwok
//:     if eq len s 2 1 0
//: ```
fn insert <(SparseSet,i32)*>Result<SparseSet, Diag>> (s, value):
    let hdr <i32> field::get s "hdr"
    let n <i32> sparse_set_hdr_n hdr
    let len0 <i32> sparse_set_hdr_len0 hdr
    let dense <MemPtr<i32>> sparse_set_hdr_dense hdr
    let sparse <MemPtr<i32>> sparse_set_hdr_sparse hdr
    if:
        not sparse_set_valid_index value n
        then:
            let d <Diag> sparse_set_diag_index "sparse_set_insert" value n
            err<SparseSet, Diag> d
        else:
            if:
                sparse_set_contains_raw n dense sparse len0 value
                then:
                    ok<SparseSet, Diag> s
                else:
                    sparse_set_store dense len0 value
                    sparse_set_store sparse value len0
                    sparse_set_hdr_set_len0 hdr add len0 1
                    ok<SparseSet, Diag> s

//: ## remove
//: value を 1 [個/こ][削除/さくじょ]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/sparse_set" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <SparseSet>:
//:         unwrap_ok<SparseSet, Diag> new 8
//:         |> insert 3 |> uwok
//:         |> insert 5 |> uwok
//:         |> remove 3 |> uwok
//:     if eq len s 1 1 0
//: ```
fn remove <(SparseSet,i32)*>Result<SparseSet, Diag>> (s, value):
    let hdr <i32> field::get s "hdr"
    let n <i32> sparse_set_hdr_n hdr
    let len0 <i32> sparse_set_hdr_len0 hdr
    let dense <MemPtr<i32>> sparse_set_hdr_dense hdr
    let sparse <MemPtr<i32>> sparse_set_hdr_sparse hdr
    if:
        not sparse_set_valid_index value n
        then:
            let d <Diag> sparse_set_diag_index "sparse_set_remove" value n
            err<SparseSet, Diag> d
        else:
            if:
                not sparse_set_contains_raw n dense sparse len0 value
                then:
                    ok<SparseSet, Diag> s
                else:
                    let idx <i32> sparse_set_load sparse value
                    let last_idx <i32> sub len0 1
                    let last_value <i32> sparse_set_load dense last_idx
                    sparse_set_store dense idx last_value
                    sparse_set_store sparse last_value idx
                    sparse_set_hdr_set_len0 hdr last_idx
                    ok<SparseSet, Diag> s

//: ## clear
//: [全/すべ]ての[要素/ようそ]を[削除/さくじょ]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/sparse_set" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <SparseSet>:
//:         unwrap_ok<SparseSet, Diag> new 8
//:         |> insert 3 |> uwok
//:         |> clear
//:     if eq len s 0 1 0
//: ```
fn clear <(SparseSet)->SparseSet> (s):
    let hdr <i32> field::get s "hdr"
    sparse_set_hdr_set_len0 hdr 0
    s

//: ## free
//: dense/sparse [配列/はいれつ]を[解放/かいほう]する
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "alloc/collections/sparse_set" as *
//:| #import "alloc/diag/error" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let s <SparseSet> unwrap_ok<SparseSet, Diag> new 8;
//:     free s
//:     0
//: ```
fn free <(SparseSet)->()> (s):
    let hdr <i32> field::get s "hdr"
    let n <i32> sparse_set_hdr_n hdr
    let dense <MemPtr<i32>> sparse_set_hdr_dense hdr
    let sparse <MemPtr<i32>> sparse_set_hdr_sparse hdr
    let _ <()> uwok dealloc_ptr<i32> dense mul n 4
    let _ <()> uwok dealloc_ptr<i32> sparse mul n 4
    let _ <()> uwok dealloc hdr 16
