//: # io
//: `stdio` / `fs` などの[入出力/にゅうしゅつりょく][系統/けいとう]を category target の enum で[束/たば]ねる facade
//:
//: ### [目的/もくてき]
//: - `read target` / `write target data` の[共通/きょうつう][入口/いりぐち]を `std` facade [側/がわ]に[置/お]き、`stdio` / `fs` / [将来/しょうらい]の `network` / `event` を[同/おな]じ[形/かたち]で[扱/あつか]える[土台/どだい]を[作/つく]ります。
//: - `streamio` が[個別/こべつ] stream handle を[対象/たいしょう]にするのに[対/たい]し、こちらは[入出力/にゅうしゅつりょく][系統/けいとう]そのものを enum target で[選/えら]ぶ facade とします。
//: - `ReadStream` / `WriteStream` を[分/わ]け、[読/よ]めない target や[書/か]けない target を compile error で[弾/はじ]けるようにします。
//:
//: ### [注意/ちゅうい]
//: - [現在/げんざい]は `stdio` と `fs` と in-memory text の[最小/さいしょう]構成だけを[実装/じっそう]しています。`network` / `event` は[将来/しょうらい]の variant [追加/ついか]を[想定/そうてい]した[設計/せっけい]です。
//: - file read [失敗/しっぱい]の[詳細/しょうさい] errno は[現状/げんじょう] `StdErrorKind::IoError` へ[丸/まる]めます。
//: - `ReadStream::Text "..."` を[使/つか]うと、文字列リテラルや in-memory text を stdin / fs と[同/おな]じ read target [面/めん]で[扱/あつか]えます。
//: - raw binary は `ReadStream::Bytes bytes` で[渡/わた]します。[型付/かたづ]き binary（`u8` / `u32` など）は[暗黙/あんもく]再解釈せず、[明示的/めいじてき]に byte buffer へ[符号化/ふごうか]してから[渡/わた]す[方針/ほうしん]です。
//:
//: ### [計算量/けいさんりょう]
//: - [各/かく] category backend の[実装/じっそう]に[依存/いそん]します。
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/io" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     match write WriteStream::Stdio "io facade\n":
//:         Result::Ok out:
//:             match flush out:
//:                 Result::Ok _:
//:                     0
//:                 Result::Err _e:
//:                     1
//:         Result::Err _e:
//:             1
//: ```

#indent 4

#import "alloc/diag/error" as *
#import "alloc/io" as *
#import "core/result" as *
#import "std/fs" as *
#import "std/iotarget" as *
#import "std/streamio" as *

//: ## TargetWritable
//: category target へ[書/か]き[込/こ]める[値/あたい]の[能力/のうりょく]
trait TargetWritable:
    fn write_target <(WriteStream,Self)*>Result<WriteStream, StdErrorKind>> (target, value):
        Result::Err StdErrorKind::InvalidOperation

//: ## TargetReadable
//: category target から[読/よ]み[出/だ]せる[値/あたい]の[能力/のうりょく]
trait TargetReadable:
    fn read_target <(ReadStream)*>Result<Self, StdErrorKind>> (target):
        Result::Err StdErrorKind::InvalidOperation

//: ## read
//: category target から byte [列/れつ]を[読/よ]む facade
//:
//: ### [目的/もくてき]
//: - `read ReadStream::Stdio` や `read ReadStream::Fs "a.txt"` のように、[媒体/ばいたい]の[種類/しゅるい]ではなく target enum [中心/ちゅうしん]で[読/よ]めるようにします。
//:
//: ### [実装/じっそう]
//: - `stdio` は[内部/ないぶ]で `StdinStream` / `StdoutStream` を[直接/ちょくせつ][使/つか]い、category facade [側/がわ]へ low-level handle を[漏/も]らしません。
//: - `fs` は `fs_read_to_bytes` を[呼/よ]び、error は `StdErrorKind::IoError` へ[正規化/せいきか]します。
//: - `ReadStream::Text` は `str` を `ByteBuf` へ[複製/ふくせい]して[返/かえ]します。
//:
//: ### [注意/ちゅうい]
//: - file read の[詳細/しょうさい] errno は[保持/ほじ]しません。
//: - [型引数/かたひきすう]または[受/う]け[側/がわ]の[型注釈/かたちゅうしゃく]で[返/かえ]す[型/かた]を[決/き]めます。
//:
//: ### [計算量/けいさんりょう]
//: - [各/かく] backend に[依存/いそん]します。
impl TargetReadable for ByteBuf:
    fn read_target <(ReadStream)*>Result<ByteBuf, StdErrorKind>> (target):
        match target:
            ReadStream::Stdio:
                io_read_all_bytes StdinStream ()
            ReadStream::Fs path:
                match fs_read_to_bytes path:
                    Result::Ok bytes:
                        Result<ByteBuf, StdErrorKind>::Ok bytes
                    Result::Err _e:
                        Result<ByteBuf, StdErrorKind>::Err StdErrorKind::IoError
            ReadStream::Text text:
                Result<ByteBuf, StdErrorKind>::Ok io_bytebuf_from_str text
            ReadStream::Bytes bytes:
                Result<ByteBuf, StdErrorKind>::Ok bytes

impl TargetReadable for str:
    fn read_target <(ReadStream)*>Result<str, StdErrorKind>> (target):
        match target:
            ReadStream::Stdio:
                io_read_all_text StdinStream ()
            ReadStream::Fs path:
                match fs_read_to_string path:
                    Result::Ok text:
                        Result<str, StdErrorKind>::Ok text
                    Result::Err _e:
                        Result<str, StdErrorKind>::Err StdErrorKind::IoError
            ReadStream::Text text:
                Result<str, StdErrorKind>::Ok text
            ReadStream::Bytes bytes:
                Result<str, StdErrorKind>::Ok io_bytebuf_to_str bytes

//: ## read
//: category target から byte [列/れつ]や text を[読/よ]む facade
fn read <.T: TargetReadable> <(ReadStream)*>Result<.T, StdErrorKind>> (target):
    TargetReadable::read_target target

impl TargetWritable for ByteBuf:
    fn write_target <(WriteStream,ByteBuf)*>Result<WriteStream, StdErrorKind>> (target, value):
        match target:
            WriteStream::Stdio:
                match io_write_bytes StdoutStream () value:
                    Result::Ok _out:
                        Result<WriteStream, StdErrorKind>::Ok WriteStream::Stdio
                    Result::Err e:
                        Result<WriteStream, StdErrorKind>::Err e
            WriteStream::Fs:
                Result<WriteStream, StdErrorKind>::Err StdErrorKind::IoError
impl TargetWritable for str:
    fn write_target <(WriteStream,str)*>Result<WriteStream, StdErrorKind>> (target, value):
        match target:
            WriteStream::Stdio:
                match io_write_str StdoutStream () value:
                    Result::Ok _out:
                        Result<WriteStream, StdErrorKind>::Ok WriteStream::Stdio
                    Result::Err e:
                        Result<WriteStream, StdErrorKind>::Err e
            WriteStream::Fs:
                Result<WriteStream, StdErrorKind>::Err StdErrorKind::IoError
//: ## write
//: category target へ byte [列/れつ]や text を[書/か]く facade
//:
//: ### [目的/もくてき]
//: - `write WriteStream::Stdio data` と `data |> write WriteStream::Stdio` を 1 [個/こ]の `write` へ[集約/しゅうやく]し、公開面に型 suffix を[残/のこ]しません。
fn write <.T: TargetWritable> <(WriteStream,.T)*>Result<WriteStream, StdErrorKind>> (target, value):
    TargetWritable::write_target target value

//: ## write
//: pipe [終端/しゅうたん]から category target へ byte [列/れつ]や text を[書/か]く overload
fn write <.T: TargetWritable> <(.T, WriteStream)*>Result<WriteStream, StdErrorKind>> (value, target):
    TargetWritable::write_target target value

//: ## writeln
//: category target へ text と `\n` を[続/つづ]けて[書/か]く facade
fn writeln <(WriteStream, str)*>Result<WriteStream, StdErrorKind>> (target, text):
    match write target text:
        Result::Ok target1:
            write target1 "\n"
        Result::Err e:
            Result<WriteStream, StdErrorKind>::Err e

//: ## writeln
//: pipe [終端/しゅうたん]から category target へ text と `\n` を[続/つづ]けて[書/か]く overload
fn writeln <(str, WriteStream)*>Result<WriteStream, StdErrorKind>> (text, target):
    writeln target text

//: ## flush
//: category target の[保留中/ほりゅうちゅう][出力/しゅつりょく]を[反映/はんえい]する
//:
//: ### [目的/もくてき]
//: - `flush WriteStream::Stdio` / `WriteStream::Stdio |> flush` で category target [単位/たんい]の flush を[扱/あつか]います。
//:
//: ### [実装/じっそう]
//: - [現在/げんざい]の `WriteStream::Stdio` は `StdoutStream` の flush に[委譲/いじょう]します。
fn flush <(WriteStream)*>Result<WriteStream, StdErrorKind>> (target):
    match target:
        WriteStream::Stdio:
            match io_flush StdoutStream ():
                Result::Ok _out:
                    Result<WriteStream, StdErrorKind>::Ok WriteStream::Stdio
                Result::Err e:
                    Result<WriteStream, StdErrorKind>::Err e
        WriteStream::Fs:
            Result<WriteStream, StdErrorKind>::Err StdErrorKind::IoError
//: ## close
//: category target を[閉/と]じる
//:
//: ### [目的/もくてき]
//: - `close WriteStream::Stdio` のように facade [側/がわ]から[終了/しゅうりょう]を[揃/そろ]えます。
//:
//: ### [注意/ちゅうい]
//: - [現在/げんざい]の `stdout` close は no-op です。
fn close <(WriteStream)*>Result<(), StdErrorKind>> (target):
    match target:
        WriteStream::Stdio:
            io_close StdoutStream ()
        WriteStream::Fs:
            Result<(), StdErrorKind>::Err StdErrorKind::IoError
