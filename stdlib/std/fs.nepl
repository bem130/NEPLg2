#indent 4

#if[target=wasm]
#extern "wasi_snapshot_preview1" "path_open" fn wasi_path_open <(i32,i32,i32,i32,i32,i64,i64,i32,i32)*>i32>
#if[target=wasm]
#extern "wasi_snapshot_preview1" "fd_read" fn wasi_fd_read <(i32,i32,i32,i32)*>i32>
#if[target=wasm]
#extern "wasi_snapshot_preview1" "fd_close" fn wasi_fd_close <(i32)*>i32>

#if[target=llvm]
#extern "c" "syscall" fn __fs_syscall <(i64,i64,i64,i64,i64,i64,i64)*>i64>

#import "core/cast" as *
#import "core/mem" as *
#import "core/math" as *
#import "core/result" as *
#import "alloc/io" as *
#import "alloc/string" as *

fn fs_i32_ptr <(MemPtr<u8>,i32,i32)->Result<MemPtr<i32>,str>> (base, size, off):
    region_ptr_at<u8,i32> region_new base size off

//: fs: ファイル読み込み（WASI / LLVM）
//:
//: 目的:
//: - `fs_read_to_bytes` / `fs_read_to_string` など、target 非依存のファイル読み込み API を提供します。
//:
//: 実装(アルゴリズム):
//: - wasm では WASI `path_open/fd_read/fd_close` を呼びます。
//: - llvm では libc `open/read/close` を使って同名 API を互換実装します。
//: - 読み込み結果は `ByteBuf` または str に変換します。
//:
//: 注意(重要):
//: - 権限/パス解決はホスト環境に依存します。
//: - UTF-8 検証は行わず、バイト列をそのまま str に格納します。
//:
//: 計算量:
//: - 読み込みバイト数に比例 (O(n))

#if[target=llvm]
fn __fs_copy_to_cstr <(i32,i32)*>Result<MemPtr<u8>,i32>> (src_ptr, src_len):
    let size <i32> add src_len 1;
    match alloc_ptr<u8> size:
        Result::Err e:
            Result<MemPtr<u8>,i32>::Err e
        Result::Ok dst:
            let mut i <i32> 0;
            while lt i src_len:
                do:
                    match store_u8 mem_ptr_add dst i load_u8 add src_ptr i:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ()
                    set i add i 1;
            match store_u8 mem_ptr_add dst src_len 0:
                Result::Ok _:
                    ()
                Result::Err _:
                    ()
            Result<MemPtr<u8>,i32>::Ok dst

#if[target=llvm]
fn __linux_syscall_read <(i32,i32,i32)*>i64> (fd,ptr,len):
    __fs_syscall <i64> cast 0 <i64> cast fd <i64> cast ptr <i64> cast len <i64> cast 0 <i64> cast 0 <i64> cast 0

#if[target=llvm]
fn wasi_path_open <(i32,i32,i32,i32,i32,i64,i64,i32,i32)*>i32> (_dirfd,_dirflags,path_ptr,path_len,_oflags,_rights_base,_rights_inheriting,_fdflags,fd_out):
    match __fs_copy_to_cstr path_ptr path_len:
        Result::Err e:
            e
        Result::Ok cpath:
            // Linux x86_64: openat(AT_FDCWD=-100, path, O_RDONLY=0, mode=0)
            let fd64 <i64> __fs_syscall <i64> cast 257 <i64> cast -100 <i64> cast mem_ptr_addr cpath <i64> cast 0 <i64> cast 0 <i64> cast 0 <i64> cast 0;
            match dealloc_ptr<u8> cpath add path_len 1:
                Result::Ok _:
                    ()
                Result::Err _:
                    ()
            if:
                cond:
                    lt fd64 <i64> cast 0
                then:
                    1
                else:
                    store_i32 fd_out <i32> cast fd64;
                    0

#if[target=llvm]
fn wasi_fd_read <(i32,i32,i32,i32)*>i32> (fd,iovs,iovs_len,nread_ptr):
    let mut total <i32> 0;
    let mut iov_idx <i32> 0;
    let mut err <i32> 0;
    let mut done <i32> 0;
    while eq done 0:
        do:
            if:
                cond:
                    lt iov_idx iovs_len
                then:
                    let iov_ptr <i32> add iovs mul iov_idx 8;
                    let base <i32> load_i32 iov_ptr;
                    let len <i32> load_i32 add iov_ptr 4;
                    // Linux x86_64: read(fd, buf, count)
                    let n64 <i64> __linux_syscall_read fd base len;
                    if:
                        cond:
                            lt n64 <i64> cast 0
                        then:
                            set err 1;
                            set done 1;
                        else:
                            let n <i32> cast n64;
                            set total add total n;
                            if:
                                cond:
                                    lt n len
                                then:
                                    set done 1;
                                else:
                                    ();
                    set iov_idx add iov_idx 1;
                else:
                    set done 1;
    store_i32 nread_ptr total;
    err

#if[target=llvm]
fn wasi_fd_close <(i32)*>i32> (fd):
    // Linux x86_64: close(fd)
    let rc64 <i64> __fs_syscall <i64> cast 3 <i64> cast fd <i64> cast 0 <i64> cast 0 <i64> cast 0 <i64> cast 0 <i64> cast 0;
    if:
        cond:
            lt rc64 <i64> cast 0
        then 1
        else 0

//: fs_open_read: ファイルを読み込み専用で開く
//:
//: 目的:
//: - path を開き、fd を返します。
//:
//: 実装(アルゴリズム):
//: - path_open を呼び、fd_out から fd を取得します。
//:
//: 注意(重要):
//: - dirfd は 3 (preopen) を仮定します。
//: - 失敗時は Err(errno) を返します。
//:
//: 計算量:
//: - O(1)
//: fs_open_read: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `fs_open_read` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/fs" as *
//: fn main <()*>()> ():
//:     fs_open_read "sample";
//: ```
fn fs_open_read <(str)*>Result<i32,i32>> (path):
    match alloc_ptr<u8> 4:
        Result::Err e:
            Result::Err e
        Result::Ok fd_out_buf:
            match fs_i32_ptr fd_out_buf 4 0:
                Result::Err _:
                    match dealloc_ptr<u8> fd_out_buf 4:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ()
                    Result::Err 12
                Result::Ok fd_out:
                    match store_i32 fd_out 0:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ()
                    let path_ptr <i32> add path 4;
                    let path_len <i32> load_i32 path;
                    let rights <i64> cast 0;
                    let errno <i32> wasi_path_open 3 0 path_ptr path_len 0 rights rights 0 mem_ptr_addr fd_out;
                    let res <Result<i32,i32>> if:
                        eq errno 0
                        then:
                            match load_i32 fd_out:
                                Option::Some fd:
                                    Result<i32,i32>::Ok fd
                                Option::None:
                                    Result<i32,i32>::Err 12
                        else Result<i32,i32>::Err errno
                    match dealloc_ptr<u8> fd_out_buf 4:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ()
                    res

//: fs_read_fd_bytes: fd から全て読み込んで `ByteBuf` を返す
//:
//: 目的:
//: - fd の内容をすべて読み込み、バイト列として返します。
//:
//: 実装(アルゴリズム):
//: - 64KiB から開始する連続 buffer を必要に応じて再確保し、EOF まで `fd_read` を繰り返します。
//:
//: 注意(重要):
//: - 途中でエラーが出た場合は Err(errno) を返します。
//:
//: 計算量:
//: - O(n)
//: fs_read_fd_bytes: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `fs_read_fd_bytes` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/fs" as *
//: fn main <()*>()> ():
//:     fs_read_fd_bytes 0;
//: ```
fn fs_read_fd_bytes <(i32)*>Result<ByteBuf,i32>> (fd):
    let mut cap <i32> 65536;
    match alloc_ptr<u8> cap:
        Result::Err e:
            Result::Err e
        Result::Ok buf0:
            let mut buf <MemPtr<u8>> buf0;
            match alloc_ptr<u8> 8:
                Result::Err e:
                    match dealloc_ptr<u8> buf cap:
                        Result::Ok _:
                            ()
                        Result::Err _e:
                            ();
                    Result::Err e
                Result::Ok iov_buf:
                    match fs_i32_ptr iov_buf 8 0:
                        Result::Err e:
                            match dealloc_ptr<u8> iov_buf 8:
                                Result::Ok _:
                                    ()
                                Result::Err _e:
                                    ();
                            match dealloc_ptr<u8> buf cap:
                                Result::Ok _:
                                    ()
                                Result::Err _e:
                                    ();
                            Result::Err e
                        Result::Ok iov_base:
                            match fs_i32_ptr iov_buf 8 4:
                                Result::Err e:
                                    match dealloc_ptr<u8> iov_buf 8:
                                        Result::Ok _:
                                            ()
                                        Result::Err _e:
                                            ();
                                    match dealloc_ptr<u8> buf cap:
                                        Result::Ok _:
                                            ()
                                        Result::Err _e:
                                            ();
                                    Result::Err e
                                Result::Ok iov_len:
                                    match alloc_ptr<u8> 4:
                                        Result::Err e:
                                            match dealloc_ptr<u8> iov_buf 8:
                                                Result::Ok _:
                                                    ()
                                                Result::Err _e:
                                                    ();
                                            match dealloc_ptr<u8> buf cap:
                                                Result::Ok _:
                                                    ()
                                                Result::Err _e:
                                                    ();
                                            Result::Err e
                                        Result::Ok nread_buf:
                                            match fs_i32_ptr nread_buf 4 0:
                                                Result::Err e:
                                                    match dealloc_ptr<u8> nread_buf 4:
                                                        Result::Ok _:
                                                            ()
                                                        Result::Err _e:
                                                            ();
                                                    match dealloc_ptr<u8> iov_buf 8:
                                                        Result::Ok _:
                                                            ()
                                                        Result::Err _e:
                                                            ();
                                                    match dealloc_ptr<u8> buf cap:
                                                        Result::Ok _:
                                                            ()
                                                        Result::Err _e:
                                                            ();
                                                    Result::Err e
                                                Result::Ok nread:
                                                    let mut read_len <i32> 0;
                                                    let mut done <i32> 0;
                                                    let mut err <i32> 0;
                                                    let mut alloc_failed <i32> 0;

                                                    while eq done 0:
                                                        do:
                                                            if:
                                                                eq read_len cap
                                                                then:
                                                                    let new_cap <i32> mul cap 2;
                                                                    match realloc_ptr<u8> buf cap new_cap:
                                                                        Result::Ok new_buf:
                                                                            set buf new_buf;
                                                                            set cap new_cap;
                                                                        Result::Err _e:
                                                                            set alloc_failed 1;
                                                                            set done 1;
                                                                else:
                                                                    ();
                                                            match store_i32 nread 0:
                                                                Result::Ok _:
                                                                    ()
                                                                Result::Err _:
                                                                    ()
                                                            match store_i32 iov_base add mem_ptr_addr buf read_len:
                                                                Result::Ok _:
                                                                    ()
                                                                Result::Err _:
                                                                    ();
                                                            match store_i32 iov_len sub cap read_len:
                                                                Result::Ok _:
                                                                    ()
                                                                Result::Err _:
                                                                    ();
                                                            let errno <i32> wasi_fd_read fd mem_ptr_addr iov_buf 1 mem_ptr_addr nread;
                                                            if:
                                                                eq errno 0
                                                                then:
                                                                    match load_i32 nread:
                                                                        Option::None:
                                                                            set err 12;
                                                                            set done 1
                                                                        Option::Some n:
                                                                            if:
                                                                                eq n 0
                                                                                then set done 1
                                                                                else:
                                                                                    set read_len add read_len n;
                                                                else:
                                                                    set err errno;
                                                                    set done 1;

                                                    let res <Result<ByteBuf,i32>> if:
                                                        eq alloc_failed 1
                                                        then Result<ByteBuf,i32>::Err 12
                                                        else:
                                                            if:
                                                                eq err 0
                                                                then Result<ByteBuf,i32>::Ok ByteBuf buf read_len
                                                                else Result<ByteBuf,i32>::Err err
                                                    match dealloc_ptr<u8> nread_buf 4:
                                                        Result::Ok _:
                                                            ()
                                                        Result::Err _e:
                                                            ();
                                                    match dealloc_ptr<u8> iov_buf 8:
                                                        Result::Ok _:
                                                            ()
                                                        Result::Err _e:
                                                            ();
                                                    if:
                                                        or eq alloc_failed 1 ne err 0
                                                        then:
                                                            match dealloc_ptr<u8> buf cap:
                                                                Result::Ok _:
                                                                    ()
                                                                Result::Err _e:
                                                                    ()
                                                        else:
                                                            ();
                                                    res

//: fs_bytes_to_string: `ByteBuf` を str に変換する
//:
//: 目的:
//: - バイト列をそのまま str 形式に詰め直します。
//:
//: 実装(アルゴリズム):
//: - `io_bytebuf_to_str` を使い、所有 buffer をそのまま str 形式へ詰め替えます。
//:
//: 注意(重要):
//: - UTF-8 の検証は行いません。
//:
//: 計算量:
//: - O(n)
//: fs_bytes_to_string: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `fs_bytes_to_string` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/fs" as *
//: fn main <()*>()> ():
//:     fs_bytes_to_string io_bytebuf_from_str "A";
//: ```
fn fs_bytes_to_string <(ByteBuf)*>str> (buf):
    io_bytebuf_to_str buf

//: fs_read_to_bytes: ファイルを読み込んで `ByteBuf` を返す
//:
//: 目的:
//: - path を開き、内容をバイト列として返します。
//:
//: 実装(アルゴリズム):
//: - fs_open_read → fs_read_fd_bytes → fd_close の順に処理します。
//:
//: 注意(重要):
//: - 失敗時は Err(errno) を返します。
//:
//: 計算量:
//: - O(n)
//: fs_read_to_bytes: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `fs_read_to_bytes` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/fs" as *
//: fn main <()*>()> ():
//:     fs_read_to_bytes "sample";
//: ```
fn fs_read_to_bytes <(str)*>Result<ByteBuf,i32>> (path):
    match fs_open_read path:
        Result::Ok fd:
            let res <Result<ByteBuf,i32>> fs_read_fd_bytes fd;
            let _ <i32> wasi_fd_close fd;
            res
        Result::Err e:
            Result::Err e

//: fs_read_to_string: ファイルを読み込んで str を返す
//:
//: 目的:
//: - path を読み込み、文字列として返します。
//:
//: 実装(アルゴリズム):
//: - fs_read_to_bytes で読み込み、fs_bytes_to_string で変換します。
//:
//: 注意(重要):
//: - UTF-8 検証は行いません。
//: - 失敗時は Err(errno) を返します。
//:
//: 計算量:
//: - O(n)
//: fs_read_to_string: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `fs_read_to_string` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/fs" as *
//: fn main <()*>()> ():
//:     fs_read_to_string "sample";
//: ```
fn fs_read_to_string <(str)*>Result<str,i32>> (path):
    match fs_read_to_bytes path:
        Result::Ok bytes:
            Result::Ok fs_bytes_to_string bytes
        Result::Err e:
            Result::Err e
