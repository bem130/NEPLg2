#indent 4

#if[target=wasm]
#extern "wasi_snapshot_preview1" "args_sizes_get" fn args_sizes_get <(i32,i32)*>i32>
#if[target=wasm]
#extern "wasi_snapshot_preview1" "args_get" fn args_get <(i32,i32)*>i32>
#if[target=llvm]
#extern "c" "syscall" fn __cli_syscall <(i64,i64,i64,i64,i64,i64,i64)*>i64>

#import "core/mem" as *
#import "core/math" as *
#import "core/cast" as *
#import "core/option" as *

fn cli_i32_ptr <(MemPtr<u8>,i32,i32)->Result<MemPtr<i32>,str>> (base, size, off):
    region_ptr_at<u8,i32> region_new base size off

//: cliarg: コマンドライン引数取得（WASI / LLVM）
//:
//: 目的:
//: - `cliarg_count` / `cliarg_get` で argv を読み出します。
//:
//: 実装(アルゴリズム):
//: - wasm は WASI `args_sizes_get/args_get` を使います。
//: - llvm は Linux `/proc/self/cmdline` を syscall で読み、互換 `args_sizes_get/args_get` を実装します。
//: - NUL 終端の文字列を [len][bytes] 形式の str にコピーします。
//:
//: 注意(重要):
//: - WASI ターゲット専用です（wasm では使用できません）。
//: - `cliarg_get` / `cliarg_program` は返り値の `str` を新しく確保します。
//: - 内部の一時バッファは各呼び出し内で解放します。
//: - argv[0] はプログラム名相当です。
//:
//: 計算量:
//: - 引数取得は O(total_bytes)

#if[target=llvm]
fn __cli_copy_to_cstr <(str)*>Result<MemPtr<u8>,i32>> (s):
    let len <i32> load_i32 s;
    let src <i32> add s 4;
    let size <i32> add len 1;
    match alloc_ptr<u8> size:
        Result::Err e:
            Result<MemPtr<u8>,i32>::Err e
        Result::Ok dst:
            let mut i <i32> 0;
            while lt i len:
                do:
                    match store_u8 mem_ptr_add dst i load_u8 add src i:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ()
                    set i add i 1;
            match store_u8 mem_ptr_add dst len 0:
                Result::Ok _:
                    ()
                Result::Err _:
                    ()
            Result<MemPtr<u8>,i32>::Ok dst

#if[target=llvm]
fn __cli_open_cmdline <()*>i32> ():
    let path <str> "/proc/self/cmdline";
    match __cli_copy_to_cstr path:
        Result::Err _:
            -1
        Result::Ok cpath:
            let fd64 <i64> __cli_syscall <i64> cast 257 <i64> cast -100 <i64> cast mem_ptr_addr cpath <i64> cast 0 <i64> cast 0 <i64> cast 0 <i64> cast 0;
            match dealloc_ptr<u8> cpath add load_i32 path 1:
                Result::Ok _:
                    ()
                Result::Err _:
                    ()
            if:
                cond:
                    lt fd64 <i64> cast 0
                then -1
                else <i32> cast fd64

#if[target=llvm]
fn __cli_read_cmdline <(MemPtr<u8>,i32)*>i32> (buf, cap):
    let fd <i32> __cli_open_cmdline;
    if:
        cond:
            lt fd 0
        then:
            -1
        else:
            let n64 <i64> __cli_syscall <i64> cast 0 <i64> cast fd <i64> cast mem_ptr_addr buf <i64> cast cap <i64> cast 0 <i64> cast 0 <i64> cast 0;
            __cli_syscall <i64> cast 3 <i64> cast fd <i64> cast 0 <i64> cast 0 <i64> cast 0 <i64> cast 0 <i64> cast 0;
            if:
                cond:
                    lt n64 <i64> cast 0
                then -1
                else <i32> cast n64

#if[target=llvm]
fn args_sizes_get <(i32,i32)*>i32> (argc_ptr, buf_ptr):
    let cap <i32> 65536;
    match alloc_ptr<u8> cap:
        Result::Err _:
            1
        Result::Ok tmp:
            let n <i32> __cli_read_cmdline tmp cap;
            if:
                cond:
                    lt n 0
                then:
                    match dealloc_ptr<u8> tmp cap:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ();
                    1
                else:
                    let mut argc <i32> 0;
                    let mut i <i32> 0;
                    while lt i n:
                        do:
                            if:
                                eq unwrap<i32> load_u8 mem_ptr_add tmp i 0
                                then set argc add argc 1
                                else ()
                            set i add i 1;
                    store_i32 argc_ptr argc;
                    store_i32 buf_ptr n;
                    match dealloc_ptr<u8> tmp cap:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ();
                    0

#if[target=llvm]
fn args_get <(i32,i32)*>i32> (argv_ptr, argv_buf):
    let cap <i32> 65536;
    match alloc_ptr<u8> cap:
        Result::Err _:
            1
        Result::Ok tmp:
            let argv_buf_ptr <MemPtr<u8>> mem_ptr_wrap argv_buf
            let argv_ptr_i32 <MemPtr<i32>> mem_ptr_wrap argv_ptr
            let n <i32> __cli_read_cmdline tmp cap;
            if:
                cond:
                    lt n 0
                then:
                    match dealloc_ptr<u8> tmp cap:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ();
                    1
                else:
                    let mut i <i32> 0;
                    while lt i n:
                        do:
                            match store_u8 mem_ptr_add argv_buf_ptr i unwrap<i32> load_u8 mem_ptr_add tmp i:
                                Result::Ok _:
                                    ()
                                Result::Err _:
                                    ()
                            set i add i 1;

                    let mut argi <i32> 0;
                    if:
                        cond:
                            lt 0 n
                        then:
                            match store_i32 argv_ptr_i32 argv_buf:
                                Result::Ok _:
                                    ()
                                Result::Err _:
                                    ()
                        else ()

                    let mut j <i32> 0;
                    while lt j n:
                        do:
                            if:
                                eq unwrap<i32> load_u8 mem_ptr_add argv_buf_ptr j 0
                                then:
                                    set argi add argi 1;
                                    if:
                                        cond:
                                            lt add j 1 n
                                        then:
                                            match store_i32 mem_ptr_add argv_ptr_i32 mul argi 4 add argv_buf add j 1:
                                                Result::Ok _:
                                                    ()
                                                Result::Err _:
                                                    ()
                                        else ()
                                else ()
                            set j add j 1;
                    match dealloc_ptr<u8> tmp cap:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ();
                    0

//: cstr_len: NUL 終端文字列の長さを求める
//:
//: 目的:
//: - `MemPtr<u8>` で与えられた C 文字列の長さを返します。
//:
//: 実装(アルゴリズム):
//: - 1 バイトずつ読み、0 に達したら停止します。
//:
//: 注意(重要):
//: - `p` は NUL 終端済みの有効なバイト列を指している必要があります。
//:
//: 計算量:
//: - O(n)
//: cstr_len: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `cstr_len` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/env/cliarg" as *
//:| #import "core/mem" as *
//: fn main <()*>()> ():
//:     cstr_len mem_ptr_wrap 0;
//: ```
fn cstr_len <(MemPtr<u8>)*>i32> (p):
    let mut i <i32> 0
    let mut done <i32> 0
    while eq done 0:
        do:
            let b <i32> unwrap<i32> load_u8 mem_ptr_add p i;
            if:
                cond:
                    eq b 0
                then:
                    set done 1;
                else:
                    set i add i 1;
    i

//: cstr_to_str: NUL 終端文字列を str にコピーする
//:
//: 目的:
//: - `MemPtr<u8>` から NUL 終端文字列を読み取り、独立した `str` にコピーします。
//:
//: 実装(アルゴリズム):
//: - まず `cstr_len` で長さを数え、`[len][bytes]` 形式の新領域へ転写します。
//:
//: 注意(重要):
//: - 呼び出しごとに新しい領域を確保します。
//: - 返り値は元の C 文字列の寿命と独立です。
//:
//: 計算量:
//: - O(n)
//: cstr_to_str: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `cstr_to_str` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/env/cliarg" as *
//:| #import "core/mem" as *
//: fn main <()*>()> ():
//:     cstr_to_str mem_ptr_wrap 0;
//: ```
fn cstr_to_str <(MemPtr<u8>)*>str> (p):
    let len <i32> cstr_len p
    match alloc_ptr<u8> add 4 len:
        Result::Err _:
            ""
        Result::Ok out:
            let out_len <MemPtr<i32>> mem_ptr_wrap mem_ptr_addr out
            match store_i32 out_len len:
                Result::Ok _:
                    ()
                Result::Err _:
                    ()
            let mut i <i32> 0
            while lt i len:
                do:
                    let b <i32> unwrap<i32> load_u8 mem_ptr_add p i;
                    match store_u8 mem_ptr_add out add 4 i b:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ()
                    set i add i 1;
            mem_ptr_addr out

//: cliarg_count: 引数の個数を返す
//:
//: 目的:
//: - argc を返します（argv[0] を含みます）。
//:
//: 実装(アルゴリズム):
//: - args_sizes_get で argc を取得します。
//:
//: 注意(重要):
//: - 失敗時は 0 を返します。
//:
//: 計算量:
//: - O(1)
//: cliarg_count: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `cliarg_count` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/env/cliarg" as *
//: fn main <()*>()> ():
//:     cliarg_count ();
//: ```
fn cliarg_count <()*>i32> ():
    match alloc_ptr<u8> 8:
        Result::Err _:
            0
        Result::Ok meta:
            match cli_i32_ptr meta 8 0:
                Result::Err _:
                    match dealloc_ptr<u8> meta 8:
                        Result::Ok _:
                            ()
                        Result::Err _:
                            ()
                    0
                Result::Ok argc_ptr:
                    match cli_i32_ptr meta 8 4:
                        Result::Err _:
                            match dealloc_ptr<u8> meta 8:
                                Result::Ok _:
                                    ()
                                Result::Err _:
                                    ()
                            0
                        Result::Ok buf_ptr:
                            let errno <i32> args_sizes_get mem_ptr_addr argc_ptr mem_ptr_addr buf_ptr
                            let res <i32> if:
                                eq errno 0
                                then:
                                    unwrap<i32> load_i32 argc_ptr
                                else:
                                    0
                            match dealloc_ptr<u8> meta 8:
                                Result::Ok _:
                                    ()
                                Result::Err _:
                                    ()
                            res

//: cliarg_get: 指定 index の引数を取得する
//:
//: 目的:
//: - idx が範囲内なら Some(str)、範囲外なら None を返します。
//:
//: 実装(アルゴリズム):
//: - args_sizes_get/args_get を呼び出し、argv を取得します。
//: - argv[idx] を NUL 終端として読み取り、str にコピーします。
//:
//: 注意(重要):
//: - idx < 0 は None になります。
//: - 取得ごとにメモリを確保します。
//:
//: 計算量:
//: - O(total_bytes + len)
//: cliarg_get: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `cliarg_get` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/env/cliarg" as *
//: fn main <()*>()> ():
//:     cliarg_get 0;
//: ```
fn cliarg_get <(i32)*>Option<str>> (idx):
    if:
        cond:
            lt idx 0
        then:
            none<str>
        else:
            match alloc_ptr<u8> 8:
                Result::Err _:
                    none<str>
                Result::Ok meta:
                    match cli_i32_ptr meta 8 0:
                        Result::Err _:
                            match dealloc_ptr<u8> meta 8:
                                Result::Ok _:
                                    ()
                                Result::Err _:
                                    ()
                            none<str>
                        Result::Ok argc_ptr:
                            match cli_i32_ptr meta 8 4:
                                Result::Err _:
                                    match dealloc_ptr<u8> meta 8:
                                        Result::Ok _:
                                            ()
                                        Result::Err _:
                                            ()
                                    none<str>
                                Result::Ok buf_ptr:
                                    let errno <i32> args_sizes_get mem_ptr_addr argc_ptr mem_ptr_addr buf_ptr
                                    let res <Option<str>> if:
                                        eq errno 0
                                        then:
                                            let argc <i32> unwrap<i32> load_i32 argc_ptr
                                            if:
                                                cond:
                                                    lt idx argc
                                                then:
                                                    match alloc_ptr<u8> mul argc 4:
                                                        Result::Err _:
                                                            none<str>
                                                        Result::Ok argv:
                                                            let buf_size <i32> unwrap<i32> load_i32 buf_ptr
                                                            match alloc_ptr<u8> buf_size:
                                                                Result::Err _:
                                                                    match dealloc_ptr<u8> argv mul argc 4:
                                                                        Result::Ok _:
                                                                            ()
                                                                        Result::Err _:
                                                                            ()
                                                                    none<str>
                                                                Result::Ok argv_buf:
                                                                    let errno2 <i32> args_get mem_ptr_addr argv mem_ptr_addr argv_buf
                                                                    let inner <Option<str>> if:
                                                                        eq errno2 0
                                                                        then:
                                                                            match cli_i32_ptr argv mul argc 4 mul idx 4:
                                                                                Result::Err _:
                                                                                    none<str>
                                                                                Result::Ok arg_slot:
                                                                                    match load_i32 arg_slot:
                                                                                        Option::None:
                                                                                            none<str>
                                                                                        Option::Some arg_ptr:
                                                                                            some<str> cstr_to_str mem_ptr_wrap arg_ptr
                                                                        else:
                                                                            none<str>
                                                                    match dealloc_ptr<u8> argv_buf buf_size:
                                                                        Result::Ok _:
                                                                            ()
                                                                        Result::Err _:
                                                                            ()
                                                                    match dealloc_ptr<u8> argv mul argc 4:
                                                                        Result::Ok _:
                                                                            ()
                                                                        Result::Err _:
                                                                            ()
                                                                    inner
                                                else:
                                                    none<str>
                                        else:
                                            none<str>
                                    match dealloc_ptr<u8> meta 8:
                                        Result::Ok _:
                                            ()
                                        Result::Err _:
                                            ()
                                    res

//: cliarg_program: argv[0] を返す
//:
//: 目的:
//: - プログラム名相当の引数を返します。
//:
//: 実装(アルゴリズム):
//: - cliarg_get 0 を呼びます。
//:
//: 注意(重要):
//: - 取得に失敗した場合は None です。
//:
//: 計算量:
//: - O(total_bytes + len)
//: cliarg_program: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `cliarg_program` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/env/cliarg" as *
//: fn main <()*>()> ():
//:     cliarg_program ();
//: ```
fn cliarg_program <()*>Option<str>> ():
    cliarg_get 0
