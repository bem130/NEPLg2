fn read <.T: StreamReadableResult> <(StdinStream)*>Result<.T, StdErrorKind>> (stream):
    StreamReadableResult::read_from_stdin stream

//: ## read
//: in-memory text stream を[指定/してい]した[型/かた]として[読/よ]む
fn read <.T: StreamReadableResult> <(TextInputStream)*>Result<.T, StdErrorKind>> (stream):
    StreamReadableResult::read_from_text_stream stream

//: ## read
//: in-memory byte stream を[指定/してい]した[型/かた]として[読/よ]む
