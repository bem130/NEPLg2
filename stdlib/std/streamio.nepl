        append_u64_impl w value

impl StreamWritable for f64:
    fn append <(StreamWriter,f64)*>StreamWriter> (w, value):
        append_f64_impl w value

impl StreamWritable for f32:
    fn append <(StreamWriter,f32)*>StreamWriter> (w, value):
        append_f32_impl w value

