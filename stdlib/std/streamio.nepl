fn flush <(StdoutStream)*>Result<StdoutStream, StdErrorKind>> (stream):
    io_flush stream

//: ## close
//: `StreamScanner` を[閉/と]じて[内部/ないぶ] buffer を[解放/かいほう]する
fn close <(StreamScanner)*>()> (sc):
    let header <MemPtr<u8>> get sc "header";
    let buf_addr <i32> stream_scanner_load_header header StreamScannerHeaderField::BufPtr;
    let len <i32> stream_scanner_load_header header StreamScannerHeaderField::Len;
    let bytes <ByteBuf> ByteBuf mem_ptr_wrap buf_addr len;
    io_bytebuf_free bytes;
    match dealloc_ptr<u8> header 12:
        Result::Ok _:
            ()
        Result::Err _e:
            ()

//: ## close
//: `StdinStream` を[閉/と]じる
fn close <(StdinStream)*>Result<(), StdErrorKind>> (stream):
    io_close stream

