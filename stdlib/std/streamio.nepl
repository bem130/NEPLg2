        Result::Err StdErrorKind::InvalidOperation

    fn read_from_text_stream <(TextInputStream)*>Result<Self, StdErrorKind>> (_stream):
        Result::Err StdErrorKind::InvalidOperation

    fn read_from_byte_stream <(ByteInputStream)*>Result<Self, StdErrorKind>> (_stream):
        Result::Err StdErrorKind::InvalidOperation

impl StreamReadableResult for ByteBuf:
    fn read_from_stdin <(StdinStream)*>Result<ByteBuf, StdErrorKind>> (stream):
        io_read_all_bytes stream

    fn read_from_text_stream <(TextInputStream)*>Result<ByteBuf, StdErrorKind>> (stream):
        io_read_all_bytes stream

    fn read_from_byte_stream <(ByteInputStream)*>Result<ByteBuf, StdErrorKind>> (stream):
        io_read_all_bytes stream

impl StreamReadableResult for str:
    fn read_from_stdin <(StdinStream)*>Result<str, StdErrorKind>> (stream):
        io_read_all_text stream

    fn read_from_text_stream <(TextInputStream)*>Result<str, StdErrorKind>> (stream):
        io_read_all_text stream

    fn read_from_byte_stream <(ByteInputStream)*>Result<str, StdErrorKind>> (stream):
        io_read_all_text stream

