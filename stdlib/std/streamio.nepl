//: ## writeln
//: `StdoutStream` へ text と `\n` を[続/つづ]けて[書/か]く
fn writeln <(StdoutStream, str)*>Result<StdoutStream, StdErrorKind>> (stream, text):
    match io_write_str stream text:
        Result::Ok stream1:
            io_write_str stream1 "\n"
        Result::Err e:
            Result<StdoutStream, StdErrorKind>::Err e

//: ## writeln
//: pipe [終端/しゅうたん]から `StdoutStream` へ text と `\n` を[続/つづ]けて[書/か]く overload
fn writeln <(str, StdoutStream)*>Result<StdoutStream, StdErrorKind>> (text, stream):
    match io_write_str stream text:
        Result::Ok stream1:
            io_write_str stream1 "\n"
        Result::Err e:
            Result<StdoutStream, StdErrorKind>::Err e

//: ## flush
