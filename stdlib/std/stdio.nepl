#indent 4

#if[target=wasm]
#extern "wasi_snapshot_preview1" "fd_read" fn fd_read <(i32,i32,i32,i32)*>i32>
#if[target=wasm]
#extern "wasi_snapshot_preview1" "fd_write" fn fd_write <(i32,i32,i32,i32)*>i32>

#if[target=llvm]
#extern "c" "syscall" fn __nepl_syscall <(i64,i64,i64,i64,i64,i64,i64)*>i64>

#import "alloc/collections/vec" as *
#import "alloc/io" as *
#import "core/mem" as *
#import "core/math" as *
#import "core/cast" as *

fn std_alloc <(i32)->Result<i32,str>> (size):
    alloc size

fn std_free <(i32,i32)->()> (ptr, size):
    match dealloc ptr size:
        Result::Ok _:
            ()
        Result::Err _:
            ()

fn std_store_i32_at <(MemPtr<u8>,i32,i32,i32)->Result<(),str>> (base, size, off, v):
    match region_ptr_at<u8,i32> region_new base size off:
        Result::Err _e:
            Result<(),str>::Err "stdio.mem store_i32 oob"
        Result::Ok p:
            store_i32 p v

fn std_load_i32_at <(MemPtr<u8>,i32,i32)->Result<i32,str>> (base, size, off):
    match region_ptr_at<u8,i32> region_new base size off:
        Result::Err _e:
            Result<i32,str>::Err "stdio.mem load_i32 oob"
        Result::Ok p:
            match load_i32 p:
                Option::Some v:
                    Result<i32,str>::Ok v
                Option::None:
                    Result<i32,str>::Err "stdio.mem load_i32 failed"

fn stdio_fd_read_mem <(i32,MemPtr<u8>,i32,MemPtr<u8>)*>i32> (fd, iov, iovcnt, nread):
    fd_read fd mem_ptr_addr iov iovcnt mem_ptr_addr nread

//: stdio: 標準入出力（WASI / LLVM）
//:
//: 目的:
//: - `print` / `read_line` などの基本 I/O を target 非依存で提供します。
//:
//: 実装(アルゴリズム):
//: - wasm では WASI `fd_read` / `fd_write` を呼びます。
//: - llvm では Linux の `syscall(read/write)` で互換 `fd_read` / `fd_write` を実装します。
//: - 文字列は [len][bytes] の形式です。
//:
//: 注意(重要):
//: - 入力は固定長バッファのため長い入力は切り捨てられます。
//: - 失敗時は空文字列や無視で返します（Result 化は未実装）。
//:
//: 計算量:
//: - 文字列長に比例

#if[target=llvm]
fn __linux_syscall_rw <(i32,i32,i32,i32)*>i64> (nr,fd,ptr,len):
    #llvmir:
        define i64 @__linux_syscall_rw(i32 %nr, i32 %fd, i32 %ptr, i32 %len) {
        entry:
            %nr64 = zext i32 %nr to i64
            %fd64 = zext i32 %fd to i64
            %len64 = zext i32 %len to i64
            %idx = zext i32 %ptr to i64
            %buf = getelementptr [67108864 x i8], ptr @__nepl_mem, i64 0, i64 %idx
            %buf64 = ptrtoint ptr %buf to i64
            %ret = call i64 @__nepl_syscall(i64 %nr64, i64 %fd64, i64 %buf64, i64 %len64, i64 0, i64 0, i64 0)
            ret i64 %ret
        }

#if[target=llvm]
fn fd_write <(i32,i32,i32,i32)*>i32> (_fd,iovs,iovs_len,nwritten_ptr):
    let mut total <i32> 0;
    let mut iov_idx <i32> 0;
    let mut err <i32> 0;
    let mut done <i32> 0;
    let fd <i32> _fd;
    while eq done 0:
        do:
            if:
                cond:
                    lt iov_idx iovs_len
                then:
                    let iov_ptr <i32> add iovs mul iov_idx 8;
                    let base <i32> load_i32 iov_ptr;
                    let len <i32> load_i32 add iov_ptr 4;
                    // Linux x86_64: write(fd, buf, count)
                    let n64 <i64> __linux_syscall_rw 1 fd base len;
                    if:
                        cond:
                            lt n64 <i64> cast 0
                        then:
                            set err 1;
                            set done 1;
                        else:
                            let n <i32> cast n64;
                            set total add total n;
                            if:
                                cond:
                                    lt n len
                                then:
                                    set done 1;
                                else:
                                    ();
                    set iov_idx add iov_idx 1;
                else:
                    set done 1;
    store_i32 nwritten_ptr total;
    err

#if[target=llvm]
fn fd_read <(i32,i32,i32,i32)*>i32> (_fd,iovs,iovs_len,nread_ptr):
    let mut total <i32> 0;
    let mut iov_idx <i32> 0;
    let mut err <i32> 0;
    let mut done <i32> 0;
    let fd <i32> _fd;
    while eq done 0:
        do:
            if:
                cond:
                    lt iov_idx iovs_len
                then:
                    let iov_ptr <i32> add iovs mul iov_idx 8;
                    let base <i32> load_i32 iov_ptr;
                    let len <i32> load_i32 add iov_ptr 4;
                    // Linux x86_64: read(fd, buf, count)
                    let n64 <i64> __linux_syscall_rw 0 fd base len;
                    if:
                        cond:
                            lt n64 <i64> cast 0
                        then:
                            set err 1;
                            set done 1;
                        else:
                            let n <i32> cast n64;
                            set total add total n;
                            if:
                                cond:
                                    lt n len
                                then:
                                    set done 1;
                                else:
                                    ();
                    set iov_idx add iov_idx 1;
                else:
                    set done 1;
    store_i32 nread_ptr total;
    err

//: ## stdio_write_bytes
//: `ByteBuf` を stdout へ[書/か]き[出/だ]す
//:
//: ### [目的/もくてき]
//: - `std/streamio` が binary write を `str` [変換/へんかん]なしで[実行/じっこう]できるようにします。
//:
//: ### [関連/かんれん]
//: - [所有権/しょゆうけん]を[移/うつ]さない byte span [出力/しゅつりょく]は `stdio_write_mem` を[使/つか]います。
//:
//: ### [実装/じっそう]
//: - `ByteBuf` の pointer/length を `stdio_write_mem` へ[渡/わた]し、partial write を[吸収/きゅうしゅう]しながら stdout へ[出力/しゅつりょく]します。
//:
//: ### [注意/ちゅうい]
//: - vector [自体/じたい]の[所有権/しょゆうけん]や[確保領域/かくほりょういき]は[呼/よ]び[出/だ]し[側/がわ]が[管理/かんり]します。
//: - [詳細/しょうさい] error [報告/ほうこく]はまだ[行/おこな]いません。
//: - [失敗/しっぱい]しても unit を[返/かえ]して[打/う]ち[切/き]ります。error を[利用者/りようしゃ]へ[返/かえ]すのは `std/stdio` [自体/じたい]の Result [化/か]と[同時/どうじ]に[整理/せいり]する[予定/よてい]です。
//:
//: ### [計算量/けいさんりょう]
//: - [書/か]き[込/こ]み byte [数/すう]を n として O(n) です。
fn stdio_write_mem <(MemPtr<u8>,i32)*>()> (data, data_len):
    let data_ptr <i32> mem_ptr_addr data;
    if:
        le data_len 0
        then:
            ()
        else:
            match std_alloc 8:
                Result::Err _:
                    ()
                Result::Ok iov:
                    match std_alloc 4:
                        Result::Err _:
                            std_free iov 8;
                            ()
                        Result::Ok nwritten:
                            let mut off <i32> 0;
                            let mut done <i32> 0;
                            while eq done 0:
                                do:
                                    if:
                                        ge off data_len
                                        then:
                                            set done 1;
                                            ()
                                        else:
                                            store_i32 iov add data_ptr off;
                                            store_i32 add iov 4 sub data_len off;
                                            store_i32 nwritten 0;
                                            let errno <i32> fd_write 1 iov 1 nwritten;
                                            if:
                                                ne errno 0
                                                then:
                                                    set done 1;
                                                    ()
                                                else:
                                                    let n <i32> load_i32 nwritten;
                                                    if:
                                                        eq n 0
                                                        then:
                                                            set done 1;
                                                            ()
                                                        else:
                                                            set off add off n;
                                                            ();
                            std_free nwritten 4;
                            std_free iov 8;
                            ()

fn stdio_write_bytes <(ByteBuf)*>()> (bytes):
    let data <MemPtr<u8>> get bytes "ptr";
    let data_len <i32> get bytes "len";
    stdio_write_mem data data_len;
    io_bytebuf_free bytes;
    ()

//: ## stdio_read_all_bytes
//: stdin の[残/のこ]りを `ByteBuf` として[読/よ]み[込/こ]む
//:
//: ### [目的/もくてき]
//: - `std/streamio` や `StreamScanner` の binary read [入口/いりぐち]として、stdin [全体/ぜんたい]を `ByteBuf` として[保持/ほじ]します。
//:
//: ### [実装/じっそう]
//: - 64KiB から[開始/かいし]して buffer を[必要/ひつよう]に[応/おう]じて[拡張/かくちょう]し、EOF まで `fd_read` を[反復/はんぷく]します。
//: - [返/かえ]り[値/あたい]の `ByteBuf` は[呼/よ]び[出/だ]し[側/がわ]が[所有/しょゆう]します。
//:
//: ### [注意/ちゅうい]
//: - text helper `read_all` とは[別経路/べつけいろ]です。text [変換/へんかん]を[伴/ともな]わないため、NUL を[含/ふく]む入力もそのまま[保持/ほじ]します。
//:
//: ### [計算量/けいさんりょう]
//: - [読/よ]み[込/こ]んだ byte [数/すう]を n として O(n) です。
fn stdio_read_all_bytes <()*>ByteBuf> ():
    let mut cap <i32> 65536;
    match alloc_ptr<u8> cap:
        Result::Err _e:
            io_bytebuf_empty
        Result::Ok buf0:
            let mut buf <MemPtr<u8>> buf0;
            match alloc_ptr<u8> 8:
                Result::Err _e:
                    match dealloc_ptr<u8> buf cap:
                        Result::Ok _:
                            ()
                        Result::Err _e2:
                            ();
                    io_bytebuf_empty
                Result::Ok iov:
                    match alloc_ptr<u8> 4:
                        Result::Err _e:
                            match dealloc_ptr<u8> iov 8:
                                Result::Ok _:
                                    ()
                                Result::Err _e2:
                                    ();
                            match dealloc_ptr<u8> buf cap:
                                Result::Ok _:
                                    ()
                                Result::Err _e2:
                                    ();
                            io_bytebuf_empty
                        Result::Ok nread_ptr:
                            let mut read_len <i32> 0;
                            let mut done <i32> 0;
                            let mut alloc_failed <i32> 0;
                            let mut mem_failed <i32> 0;

                            while eq done 0:
                                do:
                                    if:
                                        eq read_len cap
                                        then:
                                            let new_cap <i32> mul cap 2;
                                            match realloc_ptr<u8> buf cap new_cap:
                                                Result::Ok new_buf:
                                                    set buf new_buf;
                                                    set cap new_cap;
                                                Result::Err _e:
                                                    set alloc_failed 1;
                                                    set done 1;
                                        else:
                                            ();

                                    if:
                                        eq done 0
                                        then:
                                            match std_store_i32_at iov 8 0 add mem_ptr_addr buf read_len:
                                                Result::Err _e:
                                                    set mem_failed 1;
                                                    set done 1;
                                                Result::Ok _:
                                                    match std_store_i32_at iov 8 4 sub cap read_len:
                                                        Result::Err _e:
                                                            set mem_failed 1;
                                                            set done 1;
                                                        Result::Ok _:
                                                            match std_store_i32_at nread_ptr 4 0 0:
                                                                Result::Err _e:
                                                                    set mem_failed 1;
                                                                    set done 1;
                                                                Result::Ok _:
                                                                    let errno <i32> stdio_fd_read_mem 0 iov 1 nread_ptr;
                                                                    if:
                                                                        ne errno 0
                                                                        then:
                                                                            set done 1;
                                                                        else:
                                                                            match std_load_i32_at nread_ptr 4 0:
                                                                                Result::Err _e:
                                                                                    set mem_failed 1;
                                                                                    set done 1;
                                                                                Result::Ok n:
                                                                                    if:
                                                                                        eq n 0
                                                                                        then:
                                                                                            set done 1;
                                                                                        else:
                                                                                            set read_len add read_len n;
                                        else:
                                            ();

                            match dealloc_ptr<u8> iov 8:
                                Result::Ok _:
                                    ()
                                Result::Err _e:
                                    ();
                            match dealloc_ptr<u8> nread_ptr 4:
                                Result::Ok _:
                                    ()
                                Result::Err _e:
                                    ();

                            if:
                                or eq alloc_failed 1 eq mem_failed 1
                                then:
                                    match dealloc_ptr<u8> buf cap:
                                        Result::Ok _:
                                            ()
                                        Result::Err _e:
                                            ();
                                    io_bytebuf_empty
                                else:
                                    ByteBuf buf read_len

//: print: 文字列を標準出力へ出す
//:
//: 目的:
//: - s をそのまま stdout に書き込みます。
//:
//: 実装(アルゴリズム):
//: - `stdio_write_mem` を[使/つか]い、partial write を[吸収/きゅうしゅう]しながら stdout へ[書/か]き[出/だ]します。
//:
//: 注意(重要):
//: - エラーは無視します。
//:
//: 計算量:
//: - O(n)
//: print: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `print` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/stdio" as *
//: fn main <()*>()> ():
//:     print "sample";
//: ```
fn noshadow print <(str)*>()> (s):
    stdio_write_mem string_data_ptr s load_i32 s

//: read_all: 標準入力を読み込む（固定長）
//:
//: 目的:
//: - stdin から最大 4096 バイト読み込み、文字列として返します。
//:
//: 実装(アルゴリズム):
//: - 1 回の fd_read で読み込みます。
//:
//: 注意(重要):
//: - 失敗時は長さ 0 を返します。
//: - 入力が 4096 バイトを超える場合は切り捨てます。
//:
//: 計算量:
//: - O(n)
//: read_all: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `read_all` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/stdio" as *
//: fn main <()*>()> ():
//:     read_all ();
//: ```
fn read_all <()*>str> ():
    let cap <i32> 4096;
    match std_alloc add 4 cap:
        Result::Err _:
            ""
        Result::Ok out:
            match std_alloc 8:
                Result::Err _:
                    std_free out add 4 cap;
                    ""
                Result::Ok iov:
                    match std_alloc 4:
                        Result::Err _:
                            std_free iov 8;
                            std_free out add 4 cap;
                            ""
                        Result::Ok nread:
                            store_i32 iov add out 4;
                            store_i32 add iov 4 cap;
                            store_i32 nread 0;
                            let errno <i32> fd_read 0 iov 1 nread;
                            let res <str> if:
                                eq errno 0
                                then:
                                    let n <i32> load_i32 nread;
                                    store_i32 out n;
                                    out
                                else:
                                    store_i32 out 0;
                                    out
                            std_free nread 4;
                            std_free iov 8;
                            res

//: read_line: 1 行読み込む
//:
//: 目的:
//: - newline か EOF まで読み込み、文字列として返します。
//:
//: 実装(アルゴリズム):
//: - 1 バイトずつ読み取り、改行か EOF で停止します。
//:
//: 注意(重要):
//: - 最大 1024 バイトまでです。
//: - 失敗時は短い文字列になる可能性があります。
//:
//: 計算量:
//: - O(n)
//: read_line: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `read_line` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/stdio" as *
//: fn main <()*>()> ():
//:     read_line ();
//: ```
fn noshadow read_line <()*>str> ():
    let cap <i32> 1024;
    match std_alloc add 4 cap:
        Result::Err _:
            ""
        Result::Ok out:
            match std_alloc 8:
                Result::Err _:
                    std_free out add 4 cap;
                    ""
                Result::Ok iov:
                    match std_alloc 4:
                        Result::Err _:
                            std_free iov 8;
                            std_free out add 4 cap;
                            ""
                        Result::Ok nread:
                            let mut len <i32> 0;
                            let mut done <i32> 0;

                            while eq done 0:
                                if:
                                    lt len cap
                                    then:
                                        let out_base <i32> add out 4;
                                        let write_ptr <i32> add out_base len;
                                        store_i32 iov write_ptr;
                                        store_i32 add iov 4 1;
                                        store_i32 nread 0;
                                        let errno <i32> fd_read 0 iov 1 nread;
                                        if:
                                            eq errno 0
                                            then:
                                                let n <i32> load_i32 nread;
                                                if:
                                                    eq n 0
                                                    then:
                                                        set done 1;
                                                    else:
                                                        let out_base <i32> add out 4;
                                                        let read_ptr <i32> add out_base len;
                                                        let b <i32> load_u8 read_ptr;
                                                        if:
                                                            eq b 10
                                                            then:
                                                                set done 1;
                                                            else:
                                                                set len add len 1;
                                            else:
                                                set done 1;
                                    else:
                                        set done 1;
                            store_i32 out len;
                            std_free nread 4;
                            std_free iov 8;
                            out

//: println: 改行付き出力
//:
//: 目的:
//: - s を出力し、改行を追加します。
//:
//: 実装(アルゴリズム):
//: - print を 2 回呼びます。
//:
//: 注意(重要):
//: - 改行は "\n" 固定です。
//:
//: 計算量:
//: - O(n)
//: println: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `println` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/stdio" as *
//: fn main <()*>()> ():
//:     println "sample";
//: ```
fn noshadow println <(str)*>()> (s):
    print s;
    print "\n";
    ()

//: print_i32: i32 を文字列にして出力
//:
//: 目的:
//: - v を 10 進文字列にして出力します。
//:
//: 実装(アルゴリズム):
//: - from_i32 相当の手順で文字列を生成し、print します。
//:
//: 注意(重要):
//: - 負数は未対応のため "0" を出力します（暫定動作）。
//:
//: 計算量:
//: - O(d)
//: print_i32: 使い方の最小例
//:
//: [目的/もくてき]:
//: - `print_i32` の典型的な使い方を最小構成で示します。
//: - 値を返す関数は結果の受け取り方も合わせて確認できます。
//:
//: [注意/ちゅうい]:
//: - 例は用途が伝わる最短の呼び出しに絞っています。
//: - 境界条件や詳細な正当性検証は専用テストで扱います。
//:
//: neplg2:test[skip]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/stdio" as *
//: fn main <()*>()> ():
//:     print_i32 0;
//: ```
fn noshadow print_i32 <(i32)*>()> (v):
    let s <i32> :
        if:
            eq v 0
            then:
                match std_alloc 5:
                    Result::Err _:
                        ""
                    Result::Ok out0:
                        store_i32 out0 1;
                        store_u8 add out0 4 48;
                        out0
            else:
                let is_neg <bool> lt v 0;
                let mut n <i32>:
                    if:
                        is_neg
                        then:
                            sub 0 v
                        else:
                            v
                
                match std_alloc 16:
                    Result::Err _:
                        ""
                    Result::Ok scratch:
                        let mut idx <i32> 0;

                        while lt 0 n:
                            do:
                                let rem <i32> rem_u n 10;
                                store_u8 add scratch idx add 48 rem;
                                set idx add idx 1;
                                set n div_u n 10;

                        if:
                            is_neg
                            then:
                                store_u8 add scratch idx 45; // '-' sign
                                set idx add idx 1;
                            else:
                                ();

                        match std_alloc add 4 idx:
                            Result::Err _:
                                std_free scratch 16;
                                ""
                            Result::Ok out:
                                store_i32 out idx;

                                let mut i <i32> 0;
                                while lt i idx:
                                    do:
                                        let i1 <i32> add i 1;
                                        let rev <i32> sub idx i1;
                                        let bptr <i32> add scratch rev;
                                        let b <i32> load_u8 bptr;
                                        let out_base <i32> add out 4;
                                        let outp <i32> add out_base i;
                                        store_u8 outp b;
                                        set i add i 1;

                                std_free scratch 16;
                                out
    print s;
    ()

