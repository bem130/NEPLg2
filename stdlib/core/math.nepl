fn trunc_sat_u_f32_to_i32 <(f32)->i32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i32.trunc_sat_f32_u
    #if[target=llvm]
    #llvmir:
        define i32 @trunc_sat_u_f32_to_i32(float %a) {
        entry:
            %0 = call i32 @llvm.fptoui.sat.i32.f32(float %a)
            ret i32 %0
        }

