//: add: u8 の加算（mod 2^8）
fn add <(u8,u8)->u8> (a,b):
    add_u8 a b

//: sub: u8 の減算（mod 2^8）
fn sub <(u8,u8)->u8> (a,b):
    sub_u8 a b

//: mul: u8 の乗算（mod 2^8）
fn mul <(u8,u8)->u8> (a,b):
    mul_u8 a b

//: div_u: u8 の符号なし除算
fn div_u <(u8,u8)->u8> (a,b):
    div_u_u8 a b

//: rem_u: u8 の符号なし剰余
fn rem_u <(u8,u8)->u8> (a,b):
    rem_u_u8 a b

//: eq: u8 の等値比較
fn eq <(u8,u8)->bool> (a,b):
    eq_u8 a b

//: ne: u8 の非等値比較
fn ne <(u8,u8)->bool> (a,b):
    ne_u8 a b

//: lt_u: u8 の符号なし小なり比較
fn lt_u <(u8,u8)->bool> (a,b):
    lt_u_u8 a b

//: le_u: u8 の符号なし以下比較
fn le_u <(u8,u8)->bool> (a,b):
    le_u_u8 a b

//: gt_u: u8 の符号なし大なり比較
fn gt_u <(u8,u8)->bool> (a,b):
    gt_u_u8 a b

//: ge_u: u8 の符号なし以上比較
fn ge_u <(u8,u8)->bool> (a,b):
    ge_u_u8 a b


//: add: i64 の加算（mod 2^64）
//:
//: [目的/もくてき]:
//: - i64 と i64 を加算します。
//:
//: [実装/じっそう]:
//: - wasm は `i64.add`、llvm は `add i64` を使います。
//:
//: [注意/ちゅうい]:
//: - オーバーフロー時は下位 64-bit が残ります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let a <i64> cast 40;
//:     let b <i64> cast 2;
//:     assert eq add a b <i64> cast 42;
//:     let a <i64> cast 0;
//:     let b <i64> cast 7;
//:     assert eq add a b b;
//: ```
fn add <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.add
    #if[target=llvm]
    #llvmir:
        define i64 @add(i64 %a, i64 %b) {
        entry:
            %0 = add i64 %a, %b
            ret i64 %0
        }

//: sub: i64 の減算（mod 2^64）
//:
//: [目的/もくてき]:
//: - i64 から i64 を減算します。
//:
//: [実装/じっそう]:
//: - wasm は `i64.sub`、llvm は `sub i64` を使います。
//:
//: [注意/ちゅうい]:
//: - 結果は 64-bit 符号付き値として解釈されますが、演算自体は 64-bit ラップです。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let a <i64> cast 44;
//:     let b <i64> cast 2;
//:     assert eq sub a b <i64> cast 42;
//:     let z <i64> cast 0;
//:     let one <i64> cast 1;
//:     assert lt sub z one z;
//: ```
fn sub <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.sub
    #if[target=llvm]
    #llvmir:
        define i64 @sub(i64 %a, i64 %b) {
        entry:
            %0 = sub i64 %a, %b
            ret i64 %0
        }

//: mul: i64 の乗算（mod 2^64）
//:
//: [目的/もくてき]:
//: - i64 と i64 を乗算します。
//:
//: [実装/じっそう]:
//: - wasm は `i64.mul`、llvm は `mul i64` を使います。
//:
//: [注意/ちゅうい]:
//: - 乗算結果が 64-bit を超える場合はラップします。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let a <i64> cast 6;
//:     let b <i64> cast 7;
//:     assert eq mul a b <i64> cast 42;
//:     assert eq mul <i64> cast 0 <i64> cast 999 <i64> cast 0;
//: ```
fn mul <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.mul
    #if[target=llvm]
    #llvmir:
        define i64 @mul(i64 %a, i64 %b) {
        entry:
            %0 = mul i64 %a, %b
            ret i64 %0
        }

//: div_s: i64 の符号付き除算
//:
//: [目的/もくてき]:
//: - i64 を符号付き整数として割り算します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.div_s` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 0 除算は trap します。
//: - 最小値 `-2^63` を `-1` で割るケースも trap します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let n9 <i64> cast -9;
//:     let p9 <i64> cast 9;
//:     let p3 <i64> cast 3;
//:     let n3 <i64> cast -3;
//:     let p <i64> div_s n9 p3;
//:     let q <i64> div_s p9 n3;
//:     assert eq p <i64> cast -3;
//:     assert eq q <i64> cast -3;
//: ```
fn div_s <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.div_s
    #if[target=llvm]
    #llvmir:
        define i64 @div_s(i64 %a, i64 %b) {
        entry:
            %0 = sdiv i64 %a, %b
            ret i64 %0
        }

//: div_u: i64 の符号なし除算
//:
//: [目的/もくてき]:
//: - i64 を符号なし整数として割り算します。
//:
//: [実装/じっそう]:
//: - wasm は `i64.div_u`、llvm は `udiv i64` を使います。
//:
//: [注意/ちゅうい]:
//: - 0 除算は trap します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let a <i64> cast 100;
//:     let b <i64> cast 9;
//:     assert eq div_u a b <i64> cast 11;
//:     let a <i64> cast 9;
//:     let b <i64> cast 10;
//:     assert eq div_u a b <i64> cast 0;
//: ```
fn div_u <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.div_u
    #if[target=llvm]
    #llvmir:
        define i64 @div_u(i64 %a, i64 %b) {
        entry:
            %0 = udiv i64 %a, %b
            ret i64 %0
        }

//: rem_s: i64 の符号付き剰余
//:
//: [目的/もくてき]:
//: - i64 の符号付き剰余（余り）を計算します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.rem_s` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 余りの符号は被除数（左辺）に従います。
//: - 0 除算は trap します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let n10 <i64> cast -10;
//:     let p10 <i64> cast 10;
//:     let p3 <i64> cast 3;
//:     let a <i64> rem_s n10 p3;
//:     let b <i64> rem_s p10 p3;
//:     assert eq a <i64> cast -1;
//:     assert eq b <i64> cast 1;
//: ```
fn rem_s <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.rem_s
    #if[target=llvm]
    #llvmir:
        define i64 @rem_s(i64 %a, i64 %b) {
        entry:
            %0 = srem i64 %a, %b
            ret i64 %0
        }

//: rem_u: i64 の符号なし剰余
//:
//: [目的/もくてき]:
//: - i64 の符号なし剰余を計算します。
//:
//: [実装/じっそう]:
//: - wasm は `i64.rem_u`、llvm は `urem i64` を使います。
//:
//: [注意/ちゅうい]:
//: - 戻り値は 0 以上かつ除数未満です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let a <i64> cast 100;
//:     let b <i64> cast 9;
//:     assert eq rem_u a b <i64> cast 1;
//:     let a <i64> cast 9;
//:     let b <i64> cast 10;
//:     assert eq rem_u a b a;
//: ```
fn rem_u <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.rem_u
    #if[target=llvm]
    #llvmir:
        define i64 @rem_u(i64 %a, i64 %b) {
        entry:
            %0 = urem i64 %a, %b
            ret i64 %0
        }

//: and: i64 のビット AND
//:
//: [目的/もくてき]:
//: - 2つの i64 の各ビットに AND を適用します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.and` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 演算は整数の符号とは無関係にビット単位で行われます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let a <i64> cast 14;
//:     let b <i64> cast 11;
//:     assert eq and a b <i64> cast 10;
//:     assert eq or a b <i64> cast 15;
//:     assert eq xor a b <i64> cast 5;
//: ```
fn and <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.and
    #if[target=llvm]
    #llvmir:
        define i64 @and(i64 %a, i64 %b) {
        entry:
            %0 = and i64 %a, %b
            ret i64 %0
        }

//: or: i64 のビット OR
//:
//: [目的/もくてき]:
//: - 2つの i64 の各ビットに OR を適用します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.or` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 真理値 OR ではなく、ビット論理和です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn or <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.or
    #if[target=llvm]
    #llvmir:
        define i64 @or(i64 %a, i64 %b) {
        entry:
            %0 = or i64 %a, %b
            ret i64 %0
        }

//: xor: i64 のビット XOR
//:
//: [目的/もくてき]:
//: - 2つの i64 の各ビットに XOR を適用します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.xor` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 異なるビットのみ 1 になる排他的論理和です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn xor <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.xor
    #if[target=llvm]
    #llvmir:
        define i64 @xor(i64 %a, i64 %b) {
        entry:
            %0 = xor i64 %a, %b
            ret i64 %0
        }

//: shl: i64 の左シフト
//:
//: [目的/もくてき]:
//: - i64 のビット列を左へシフトします。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.shl` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - シフト量は Wasm 仕様に従い下位 6 bit が使われます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn shl <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.shl
    #if[target=llvm]
    #llvmir:
        define i64 @shl(i64 %a, i64 %b) {
        entry:
            %0 = shl i64 %a, %b
            ret i64 %0
        }

//: shr_s: i64 の算術右シフト
//:
//: [目的/もくてき]:
//: - i64 を符号付き整数として右へシフトします。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.shr_s` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 最上位ビット（符号ビット）が埋め戻されます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn shr_s <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.shr_s
    #if[target=llvm]
    #llvmir:
        define i64 @shr_s(i64 %a, i64 %b) {
        entry:
            %0 = ashr i64 %a, %b
            ret i64 %0
        }

//: shr_u: i64 の論理右シフト
//:
//: [目的/もくてき]:
//: - i64 を符号なし整数として右へシフトします。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.shr_u` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 上位ビットは 0 で埋められます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn shr_u <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.shr_u
    #if[target=llvm]
    #llvmir:
        define i64 @shr_u(i64 %a, i64 %b) {
        entry:
            %0 = lshr i64 %a, %b
            ret i64 %0
        }

//: rotl: i64 の左ローテート
//:
//: [目的/もくてき]:
//: - i64 のビット列を左へ循環シフトします。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.rotl` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - シフトで失われるビットは下位側へ回り込みます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn rotl_i64 <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.rotl
    #if[target=llvm]
    #llvmir:
        declare i64 @llvm.fshl.i64(i64, i64, i64)
        define i64 @rotl_i64(i64 %a, i64 %b) {
        entry:
            %0 = call i64 @llvm.fshl.i64(i64 %a, i64 %a, i64 %b)
            ret i64 %0
        }

//: rotr: i64 の右ローテート
//:
//: [目的/もくてき]:
//: - i64 のビット列を右へ循環シフトします。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.rotr` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - シフトで失われるビットは上位側へ回り込みます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn rotr_i64 <(i64,i64)->i64> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.rotr
    #if[target=llvm]
    #llvmir:
        declare i64 @llvm.fshr.i64(i64, i64, i64)
        define i64 @rotr_i64(i64 %a, i64 %b) {
        entry:
            %0 = call i64 @llvm.fshr.i64(i64 %a, i64 %a, i64 %b)
            ret i64 %0
        }

//: clz: 先頭ゼロビット数の計算
//:
//: [目的/もくてき]:
//: - i64 の先頭側に連続する 0 bit の個数を返します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.clz` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 入力が 0 のときは 64 を返します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn clz_i64 <(i64)->i64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i64.clz
    #if[target=llvm]
    #llvmir:
        declare i64 @llvm.ctlz.i64(i64, i1)
        define i64 @clz_i64(i64 %a) {
        entry:
            %0 = call i64 @llvm.ctlz.i64(i64 %a, i1 false)
            ret i64 %0
        }

//: ctz: 末尾ゼロビット数の計算
//:
//: [目的/もくてき]:
//: - i64 の末尾側に連続する 0 bit の個数を返します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.ctz` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 入力が 0 のときは 64 を返します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn ctz_i64 <(i64)->i64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i64.ctz
    #if[target=llvm]
    #llvmir:
        declare i64 @llvm.cttz.i64(i64, i1)
        define i64 @ctz_i64(i64 %a) {
        entry:
            %0 = call i64 @llvm.cttz.i64(i64 %a, i1 false)
            ret i64 %0
        }

//: popcnt: 1 ビット数の計算
//:
//: [目的/もくてき]:
//: - i64 に立っている 1 bit の個数を返します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.popcnt` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - ハミング重み（population count）として利用できます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn popcnt_i64 <(i64)->i64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i64.popcnt
    #if[target=llvm]
    #llvmir:
        declare i64 @llvm.ctpop.i64(i64)
        define i64 @popcnt_i64(i64 %a) {
        entry:
            %0 = call i64 @llvm.ctpop.i64(i64 %a)
            ret i64 %0
        }

//: rotl: ビット列の左ローテート（i64）
//:
//: [目的/もくてき]:
//: - i64 の循環左シフトを、型名 prefix なしで呼び出せるようにします。
fn rotl <(i64,i64)->i64> (a,b):
    rotl_i64 a b

//: rotr: ビット列の右ローテート（i64）
//:
//: [目的/もくてき]:
//: - i64 の循環右シフトを、型名 prefix なしで呼び出せるようにします。
fn rotr <(i64,i64)->i64> (a,b):
    rotr_i64 a b

//: clz: 先頭ゼロビット数の計算（i64）
//:
//: [目的/もくてき]:
//: - i64 の `clz` を、型名 prefix なしで呼び出せるようにします。
fn clz <(i64)->i64> (a):
    clz_i64 a

//: ctz: 末尾ゼロビット数の計算（i64）
//:
//: [目的/もくてき]:
//: - i64 の `ctz` を、型名 prefix なしで呼び出せるようにします。
fn ctz <(i64)->i64> (a):
    ctz_i64 a

//: popcnt: 1ビット数の計算（i64）
//:
//: [目的/もくてき]:
//: - i64 の `popcnt` を、型名 prefix なしで呼び出せるようにします。
fn popcnt <(i64)->i64> (a):
    popcnt_i64 a

//: eq: i64 の等値比較
//:
//: [目的/もくてき]:
//: - 2つの i64 が等しいかを判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.eq` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 比較はビット列が一致するかで判定されます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let a <i64> cast -1;
//:     let b <i64> cast 1;
//:     let c <i64> cast -2;
//:     let d <i64> cast -1;
//:     assert eq a d;
//:     assert ne a b;
//:     assert lt c d;
//:     assert gt_u a b;
//: ```
fn eq <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.eq
    #if[target=llvm]
    #llvmir:
        define i32 @eq(i64 %a, i64 %b) {
        entry:
            %0 = icmp eq i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: ne: i64 の非等値比較
//:
//: [目的/もくてき]:
//: - 2つの i64 が異なるかを判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.ne` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - `eq` の否定と同値です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn ne <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.ne
    #if[target=llvm]
    #llvmir:
        define i32 @ne(i64 %a, i64 %b) {
        entry:
            %0 = icmp ne i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: lt: i64 の符号付き小なり比較
//:
//: [目的/もくてき]:
//: - i64 を符号付き整数として `a < b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.lt_s` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 負数を含む順序関係を使うときはこちらを使います。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn lt <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.lt_s
    #if[target=llvm]
    #llvmir:
        define i32 @lt(i64 %a, i64 %b) {
        entry:
            %0 = icmp slt i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: lt_u: i64 の符号なし小なり比較
//:
//: [目的/もくてき]:
//: - i64 を符号なし整数として `a < b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.lt_u` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 上位ビットが立っている値は大きな正数として扱われます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn lt_u <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.lt_u
    #if[target=llvm]
    #llvmir:
        define i32 @lt_u(i64 %a, i64 %b) {
        entry:
            %0 = icmp ult i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: le: i64 の符号付き以下比較
//:
//: [目的/もくてき]:
//: - i64 を符号付き整数として `a <= b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.le_s` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - `lt` と `eq` の和集合と同じ真理値になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn le <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.le_s
    #if[target=llvm]
    #llvmir:
        define i32 @le(i64 %a, i64 %b) {
        entry:
            %0 = icmp sle i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: le_u: i64 の符号なし以下比較
//:
//: [目的/もくてき]:
//: - i64 を符号なし整数として `a <= b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.le_u` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 符号付き比較とは結果が異なる場合があります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn le_u <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.le_u
    #if[target=llvm]
    #llvmir:
        define i32 @le_u(i64 %a, i64 %b) {
        entry:
            %0 = icmp ule i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: gt: i64 の符号付き大なり比較
//:
//: [目的/もくてき]:
//: - i64 を符号付き整数として `a > b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.gt_s` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 負数を含む大小比較に使用します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn gt <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.gt_s
    #if[target=llvm]
    #llvmir:
        define i32 @gt(i64 %a, i64 %b) {
        entry:
            %0 = icmp sgt i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: gt_u: i64 の符号なし大なり比較
//:
//: [目的/もくてき]:
//: - i64 を符号なし整数として `a > b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.gt_u` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - 上位ビットが立つ値は大きい値として判定されます。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn gt_u <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.gt_u
    #if[target=llvm]
    #llvmir:
        define i32 @gt_u(i64 %a, i64 %b) {
        entry:
            %0 = icmp ugt i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: ge: i64 の符号付き以上比較
//:
//: [目的/もくてき]:
//: - i64 を符号付き整数として `a >= b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.ge_s` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - `gt` または `eq` が真なら真になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn ge <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.ge_s
    #if[target=llvm]
    #llvmir:
        define i32 @ge(i64 %a, i64 %b) {
        entry:
            %0 = icmp sge i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: ge_u: i64 の符号なし以上比較
//:
//: [目的/もくてき]:
//: - i64 を符号なし整数として `a >= b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm 命令 `i64.ge_u` を直接実行します。
//:
//: [注意/ちゅうい]:
//: - `gt_u` または `eq` が真なら真になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn ge_u <(i64,i64)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i64.ge_u
    #if[target=llvm]
    #llvmir:
        define i32 @ge_u(i64 %a, i64 %b) {
        entry:
            %0 = icmp uge i64 %a, %b
            %1 = zext i1 %0 to i32
            ret i32 %1
        }


//: add: f32 の加算
//:
//: [目的/もくてき]:
//: - 2つの f32 を加算します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.add`、llvm は `fadd float` を実行します。
//:
//: [注意/ちゅうい]:
//: - 丸め・NaN・±∞の扱いは IEEE 754 と各 backend の仕様に従います。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     let x <f32> add 1.5 2.25;
//:     let y <f32> sub x 1.25;
//:     assert eq x 3.75;
//:     assert eq y 2.5;
//: ```
fn add <(f32,f32)->f32> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        f32.add
    #if[target=llvm]
    #llvmir:
        define float @add(float %a, float %b) {
        entry:
            %0 = fadd float %a, %b
            ret float %0
        }

//: sub: f32 の減算
//:
//: [目的/もくてき]:
//: - 2つの f32 の差を計算します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.sub`、llvm は `fsub float` を実行します。
//:
//: [注意/ちゅうい]:
//: - NaN が関与する場合は比較で偽になる点に注意してください。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn sub <(f32,f32)->f32> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        f32.sub
    #if[target=llvm]
    #llvmir:
        define float @sub(float %a, float %b) {
        entry:
            %0 = fsub float %a, %b
            ret float %0
        }

//: mul: f32 の乗算
//:
//: [目的/もくてき]:
//: - 2つの f32 の積を計算します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.mul`、llvm は `fmul float` を実行します。
//:
//: [注意/ちゅうい]:
//: - 大きな値同士では `+∞` や `-∞` へ飽和することがあります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn mul <(f32,f32)->f32> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        f32.mul
    #if[target=llvm]
    #llvmir:
        define float @mul(float %a, float %b) {
        entry:
            %0 = fmul float %a, %b
            ret float %0
        }

//: div: f32 の除算
//:
//: [目的/もくてき]:
//: - 2つの f32 の商を計算します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.div`、llvm は `fdiv float` を実行します。
//:
//: [注意/ちゅうい]:
//: - 整数除算と異なり、0 除算は trap せず ±∞ / NaN になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn div <(f32,f32)->f32> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        f32.div
    #if[target=llvm]
    #llvmir:
        define float @div(float %a, float %b) {
        entry:
            %0 = fdiv float %a, %b
            ret float %0
        }

//: f32_sqrt: f32 の平方根
//:
//: [目的/もくてき]:
//: - f32 の平方根を返します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.sqrt` を実行します。
//: - llvm は `llvm.sqrt.f32` intrinsic を呼びます。
//:
//: [注意/ちゅうい]:
//: - 負数入力は NaN になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn sqrt <(f32)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.sqrt
    #if[target=llvm]
    #llvmir:
        define float @f32_sqrt(float %a) {
        entry:
            %0 = call float @llvm.sqrt.f32(float %a)
            ret float %0
        }

//: f32_abs: f32 の絶対値
//:
//: [目的/もくてき]:
//: - f32 の符号を取り除いた絶対値を返します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.abs` を使います。
//: - llvm は `bitcast -> and mask -> bitcast` で符号ビットのみを落とします。
//:
//: [注意/ちゅうい]:
//: - NaN の payload は backend の仕様に従います。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn abs <(f32)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.abs
    #if[target=llvm]
    #llvmir:
        define float @f32_abs(float %a) {
        entry:
            %bits = bitcast float %a to i32
            %masked = and i32 %bits, 2147483647
            %0 = bitcast i32 %masked to float
            ret float %0
        }

//: neg: f32 の符号反転
//:
//: [目的/もくてき]:
//: - f32 の符号を反転した値 `-a` を返します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.neg`、llvm は `fneg float` を使います。
//:
//: [注意/ちゅうい]:
//: - `-0.0` と `+0.0` は符号が反転します。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn neg <(f32)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.neg
    #if[target=llvm]
    #llvmir:
        define float @neg(float %a) {
        entry:
            %0 = fneg float %a
            ret float %0
        }

//: f32_ceil: f32 の切り上げ
//:
//: [目的/もくてき]:
//: - f32 を「以上の最小整数値」へ切り上げます。
//:
//: [実装/じっそう]:
//: - wasm は `f32.ceil`、llvm は `llvm.ceil.f32` を使います。
//:
//: [注意/ちゅうい]:
//: - 戻り値の型は f32 のままです。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn ceil <(f32)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.ceil
    #if[target=llvm]
    #llvmir:
        define float @f32_ceil(float %a) {
        entry:
            %0 = call float @llvm.ceil.f32(float %a)
            ret float %0
        }

//: f32_floor: f32 の切り下げ
//:
//: [目的/もくてき]:
//: - f32 を「以下の最大整数値」へ切り下げます。
//:
//: [実装/じっそう]:
//: - wasm は `f32.floor`、llvm は `llvm.floor.f32` を使います。
//:
//: [注意/ちゅうい]:
//: - 戻り値の型は f32 のままです。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn floor <(f32)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.floor
    #if[target=llvm]
    #llvmir:
        define float @f32_floor(float %a) {
        entry:
            %0 = call float @llvm.floor.f32(float %a)
            ret float %0
        }

//: f32_trunc: f32 の小数部切り捨て
//:
//: [目的/もくてき]:
//: - f32 の小数部を 0 方向へ切り捨てます。
//:
//: [実装/じっそう]:
//: - wasm は `f32.trunc`、llvm は `llvm.trunc.f32` を使います。
//:
//: [注意/ちゅうい]:
//: - 負数では切り下げではなく 0 方向へ寄ります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn trunc <(f32)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.trunc
    #if[target=llvm]
    #llvmir:
        define float @f32_trunc(float %a) {
        entry:
            %0 = call float @llvm.trunc.f32(float %a)
            ret float %0
        }

//: f32_nearest: f32 の最近接整数丸め
//:
//: [目的/もくてき]:
//: - f32 を最近接整数へ丸めます。
//:
//: [実装/じっそう]:
//: - wasm は `f32.nearest`、llvm は `llvm.nearbyint.f32` を使います。
//:
//: [注意/ちゅうい]:
//: - 中間値（x.5）は backend の丸め規則に従います。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn nearest <(f32)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.nearest
    #if[target=llvm]
    #llvmir:
        define float @f32_nearest(float %a) {
        entry:
            %0 = call float @llvm.nearbyint.f32(float %a)
            ret float %0
        }

//: f32_min: f32 の最小値
//:
//: [目的/もくてき]:
//: - 2つの f32 から小さい方を返します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.min`、llvm は `llvm.minimum.f32` を使います。
//:
//: [注意/ちゅうい]:
//: - NaN 入力時の振る舞いは backend 仕様に従います。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn min <(f32,f32)->f32> (a,b):
    #if[target=wasm]
