            ret float %0
        }

//: trunc_s_f32_to_i32: f32 を i32(符号付き)へ切り捨て変換
//:
//: [目的/もくてき]:
//: - f32 を 0 方向へ切り捨てて符号付き i32 に変換します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.trunc_f32_s`、llvm は `fptosi float to i32` を使います。
//:
//: [注意/ちゅうい]:
//: - NaN や範囲外値は trap（未定義変換）になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn trunc_s_f32_to_i32 <(f32)->i32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i32.trunc_f32_s
    #if[target=llvm]
    #llvmir:
        define i32 @trunc_s_f32_to_i32(float %a) {
        entry:
            %0 = fptosi float %a to i32
            ret i32 %0
        }

//: trunc_u_f32_to_i32: f32 を i32(符号なし)へ切り捨て変換
//:
//: [目的/もくてき]:
