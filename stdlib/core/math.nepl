fn lt_u_u8 <(u8,u8)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.lt_u
    #if[target=llvm]
    #llvmir:
        define i32 @u8_lt_u(i32 %a, i32 %b) {
        entry:
            %cmp = icmp ult i32 %a, %b
            %0 = zext i1 %cmp to i32
            ret i32 %0
        }

//: u8_le_u: u8 の符号なし以下比較
//:
//: [目的/もくてき]:
//: - u8 を符号なし整数として `a <= b` を判定します。
