        local.get $a
        i32.trunc_sat_f64_s
    #if[target=llvm]
    #llvmir:
        define i32 @trunc_sat_s_f64_to_i32(double %a) {
        entry:
            %0 = call i32 @llvm.fptosi.sat.i32.f64(double %a)
            ret i32 %0
        }

//: trunc_sat_u_f64_to_i32: f64 を i32(符号なし)へ飽和変換
//:
//: [目的/もくてき]:
//: - f64 を i32 に変換し、範囲外は 0 か最大値へ丸めます。
//:
//: [実装/じっそう]:
//: - wasm は `i32.trunc_sat_f64_u` を使います。
//: - llvm は `llvm.fptoui.sat.i32.f64` intrinsic を使います。
//:
//: [注意/ちゅうい]:
//: - NaN は 0 になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn trunc_sat_u_f64_to_i32 <(f64)->i32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i32.trunc_sat_f64_u
    #if[target=llvm]
    #llvmir:
        define i32 @trunc_sat_u_f64_to_i32(double %a) {
        entry:
            %0 = call i32 @llvm.fptoui.sat.i32.f64(double %a)
            ret i32 %0
        }

//: trunc_s_f64_to_i64: f64 を i64(符号付き)へ切り捨て変換
//:
//: [目的/もくてき]:
//: - f64 を 0 方向へ切り捨てて i64 に変換します。
//:
//: [実装/じっそう]:
//: - wasm は `i64.trunc_f64_s`、llvm は `fptosi double to i64` を使います。
//:
//: [注意/ちゅうい]:
//: - NaN や範囲外値は trap（未定義変換）になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn trunc_s_f64_to_i64 <(f64)->i64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i64.trunc_f64_s
    #if[target=llvm]
    #llvmir:
        define i64 @trunc_s_f64_to_i64(double %a) {
        entry:
            %0 = fptosi double %a to i64
            ret i64 %0
        }

//: trunc_u_f64_to_i64: f64 を i64(符号なし)へ切り捨て変換
//:
//: [目的/もくてき]:
//: - f64 を 0 方向へ切り捨てて i64 に変換します。
//:
//: [実装/じっそう]:
//: - wasm は `i64.trunc_f64_u`、llvm は `fptoui double to i64` を使います。
//:
//: [注意/ちゅうい]:
//: - NaN や範囲外値は trap（未定義変換）になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn trunc_u_f64_to_i64 <(f64)->i64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i64.trunc_f64_u
    #if[target=llvm]
    #llvmir:
        define i64 @trunc_u_f64_to_i64(double %a) {
        entry:
            %0 = fptoui double %a to i64
            ret i64 %0
        }

//: trunc_sat_s_f64_to_i64: f64 を i64(符号付き)へ飽和変換
//:
//: [目的/もくてき]:
//: - f64 を i64 に変換し、範囲外は最小値/最大値へ丸めます。
//:
//: [実装/じっそう]:
//: - wasm は `i64.trunc_sat_f64_s` を使います。
//: - llvm は `llvm.fptosi.sat.i64.f64` intrinsic を使います。
//:
//: [注意/ちゅうい]:
//: - NaN は 0 になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn trunc_sat_s_f64_to_i64 <(f64)->i64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i64.trunc_sat_f64_s
    #if[target=llvm]
    #llvmir:
        define i64 @trunc_sat_s_f64_to_i64(double %a) {
        entry:
            %0 = call i64 @llvm.fptosi.sat.i64.f64(double %a)
            ret i64 %0
        }

//: trunc_sat_u_f64_to_i64: f64 を i64(符号なし)へ飽和変換
//:
//: [目的/もくてき]:
//: - f64 を i64 に変換し、範囲外は 0 か最大値へ丸めます。
//:
//: [実装/じっそう]:
//: - wasm は `i64.trunc_sat_f64_u` を使います。
//: - llvm は `llvm.fptoui.sat.i64.f64` intrinsic を使います。
//:
//: [注意/ちゅうい]:
//: - NaN は 0 になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn trunc_sat_u_f64_to_i64 <(f64)->i64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i64.trunc_sat_f64_u
    #if[target=llvm]
    #llvmir:
        define i64 @trunc_sat_u_f64_to_i64(double %a) {
        entry:
            %0 = call i64 @llvm.fptoui.sat.i64.f64(double %a)
            ret i64 %0
        }

//: promote_f32_to_f64: f32 を f64 へ拡張変換
//:
//: [目的/もくてき]:
//: - f32 値を精度の高い f64 へ拡張します。
//:
//: [実装/じっそう]:
//: - wasm は `f64.promote_f32`、llvm は `fpext float to double` を使います。
//:
//: [注意/ちゅうい]:
//: - 値は厳密に保持されます（f32 から f64 への拡張で情報は失われません）。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn promote_f32_to_f64 <(f32)->f64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f64.promote_f32
    #if[target=llvm]
    #llvmir:
        define double @promote_f32_to_f64(float %a) {
        entry:
            %0 = fpext float %a to double
            ret double %0
        }

//: demote_f64_to_f32: f64 を f32 へ縮小変換
//:
//: [目的/もくてき]:
//: - f64 値を f32 へ縮小します。
//:
//: [実装/じっそう]:
//: - wasm は `f32.demote_f64`、llvm は `fptrunc double to float` を使います。
//:
//: [注意/ちゅうい]:
//: - 精度は失われる可能性があります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn demote_f64_to_f32 <(f64)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.demote_f64
    #if[target=llvm]
    #llvmir:
        define float @demote_f64_to_f32(double %a) {
        entry:
            %0 = fptrunc double %a to float
            ret float %0
        }

//: reinterpret_i32_to_f32: i32 のビット列を f32 として再解釈
//:
//: [目的/もくてき]:
//: - 32-bit のビット列を変更せずに f32 として扱います。
//:
//: [実装/じっそう]:
//: - wasm は `f32.reinterpret_i32`、llvm は `bitcast i32 to float` を使います。
//:
//: [注意/ちゅうい]:
//: - 数値変換ではなくビット再解釈です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn reinterpret_i32_to_f32 <(i32)->f32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f32.reinterpret_i32
    #if[target=llvm]
    #llvmir:
        define float @reinterpret_i32_to_f32(i32 %a) {
        entry:
            %0 = bitcast i32 %a to float
            ret float %0
        }

//: reinterpret_f32_to_i32: f32 のビット列を i32 として再解釈
//:
//: [目的/もくてき]:
//: - f32 のビット表現をそのまま i32 として読み取ります。
//:
//: [実装/じっそう]:
//: - wasm は `i32.reinterpret_f32`、llvm は `bitcast float to i32` を使います。
//:
//: [注意/ちゅうい]:
//: - 数値変換ではなくビット再解釈です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn reinterpret_f32_to_i32 <(f32)->i32> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i32.reinterpret_f32
    #if[target=llvm]
    #llvmir:
        define i32 @reinterpret_f32_to_i32(float %a) {
        entry:
            %0 = bitcast float %a to i32
            ret i32 %0
        }

//: reinterpret_i64_to_f64: i64 のビット列を f64 として再解釈
//:
//: [目的/もくてき]:
//: - 64-bit のビット列を変更せずに f64 として扱います。
//:
//: [実装/じっそう]:
//: - wasm は `f64.reinterpret_i64`、llvm は `bitcast i64 to double` を使います。
//:
//: [注意/ちゅうい]:
//: - 数値変換ではなくビット再解釈です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn reinterpret_i64_to_f64 <(i64)->f64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        f64.reinterpret_i64
    #if[target=llvm]
    #llvmir:
        define double @reinterpret_i64_to_f64(i64 %a) {
        entry:
            %0 = bitcast i64 %a to double
            ret double %0
        }

//: reinterpret_f64_to_i64: f64 のビット列を i64 として再解釈
//:
//: [目的/もくてき]:
//: - f64 のビット表現をそのまま i64 として読み取ります。
//:
//: [実装/じっそう]:
//: - wasm は `i64.reinterpret_f64`、llvm は `bitcast double to i64` を使います。
//:
//: [注意/ちゅうい]:
//: - 数値変換ではなくビット再解釈です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn reinterpret_f64_to_i64 <(f64)->i64> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i64.reinterpret_f64
    #if[target=llvm]
    #llvmir:
        define i64 @reinterpret_f64_to_i64(double %a) {
        entry:
            %0 = bitcast double %a to i64
            ret i64 %0
        }

//: extend_s: 符号拡張を行う
//:
//: [目的/もくてき]:
//: - 型名 prefix を使わずに符号拡張を呼び出せるようにします。
fn extend_s <(i32)->i64> (a):
    extend_s_i32_to_i64 a

//: wrap: i64 を i32 へ切り詰める
//:
//: [目的/もくてき]:
//: - 型名 prefix を使わずに切り詰め変換を呼び出せるようにします。
fn wrap <(i64)->i32> (a):
    wrap_i64_to_i32 a

//: convert_s: 符号付き整数を浮動小数へ変換する
//:
//: [目的/もくてき]:
//: - 変換関数を型オーバーロードで統一します。
fn convert_s <(i32)->f64> (a):
    convert_s_i32_to_f64 a
fn convert_s <(i64)->f64> (a):
    convert_s_i64_to_f64 a
fn convert_s <(i64)->f32> (a):
    convert_s_i64_to_f32 a

//: trunc_s: 浮動小数を符号付き整数へ切り捨て変換する
//:
//: [目的/もくてき]:
//: - 切り捨て変換を型オーバーロードで統一します。
fn trunc_s <(f64)->i32> (a):
    trunc_s_f64_to_i32 a
fn trunc_s <(f64)->i64> (a):
    trunc_s_f64_to_i64 a
fn trunc_s <(f32)->i64> (a):
    trunc_s_f32_to_i64 a

//: promote: f32 を f64 に拡張する
fn promote <(f32)->f64> (a):
    promote_f32_to_f64 a

//: demote: f64 を f32 に縮小する
fn demote <(f64)->f32> (a):
    demote_f64_to_f32 a

//: and: bool の論理積
//:
//: [目的/もくてき]:
//: - bool の `a && b` 相当を計算します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.and`、llvm は `and i32` を使います。
//:
//: [注意/ちゅうい]:
//: - bool は 0/1 前提です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn and <(bool,bool)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.and
    #if[target=llvm]
    #llvmir:
        define i32 @and(i32 %a, i32 %b) {
        entry:
            %0 = and i32 %a, %b
            ret i32 %0
        }


//: or: bool の論理和
//:
//: [目的/もくてき]:
//: - bool の `a || b` 相当を計算します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.or`、llvm は `or i32` を使います。
//:
//: [注意/ちゅうい]:
//: - bool は 0/1 前提です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn or <(bool,bool)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.or
    #if[target=llvm]
    #llvmir:
        define i32 @or(i32 %a, i32 %b) {
        entry:
            %0 = or i32 %a, %b
            ret i32 %0
        }


//: not: bool の否定
//:
//: [目的/もくてき]:
//: - bool の `!a` を計算します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.eqz`、llvm は `icmp eq` を使います。
//:
//: [注意/ちゅうい]:
//: - bool は 0/1 前提です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn not <(bool)->bool> (a):
    #if[target=wasm]
    #wasm:
        local.get $a
        i32.eqz
    #if[target=llvm]
    #llvmir:
        define i32 @not(i32 %a) {
        entry:
            %0 = icmp eq i32 %a, 0
            %1 = zext i1 %0 to i32
            ret i32 %1
        }

//: 追加整数型 API（u32/u64/u128/i128）
//:
//: [目的/もくてき]:
//: - WASM ネイティブの `i32/i64` を土台に、符号なし整数および 128-bit 相当の基本演算を提供します。
//:
//: [実装/じっそう]:
//: - `u32/u64` は `add/sub/mul/div_u/rem_u` と `lt_u/le_u/gt_u/ge_u` を使います。
//: - `u128/i128` は `i64` 2 ワード（上位/下位）で構成し、加減算と比較を実装します。
//:
//: [注意/ちゅうい]:
//: - `u128/i128` の除算・乗算は未提供です（今後拡張）。
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target core
//:| #import "core/test" as *
//:| #import "core/math" as *
//: fn main <()*>()> ():
//:     assert_eq_i32 3 add 1 2;
//:     assert lt_u <i64> cast 9 <i64> cast 10;
//: ```

//: u128: u128 相当（上位/下位 64-bit）
struct u128:
    hi <i64>
    lo <i64>

//: new: hi/lo から u128 値を構築する
fn new <(i64,i64)->u128> (hi, lo):
    u128 hi lo

//: to_u128: u64 値から u128 値を作る
fn to_u128 <(i64)->u128> (v):
    u128 extend_s_i32_to_i64 0 v

//: add: u128 の加算（mod 2^128）
fn add <(u128,u128)->u128> (a, b):
    let a_hi <i64> get a "hi";
    let a_lo <i64> get a "lo";
    let b_hi <i64> get b "hi";
    let b_lo <i64> get b "lo";
    let lo <i64> add a_lo b_lo;
    let carry <i64> if lt_u lo a_lo:
        then extend_s_i32_to_i64 1
        else extend_s_i32_to_i64 0;
    let hi0 <i64> add a_hi b_hi;
    let hi <i64> add hi0 carry;
    u128 hi lo

//: sub: u128 の減算（mod 2^128）
fn sub <(u128,u128)->u128> (a, b):
    let a_hi <i64> get a "hi";
    let a_lo <i64> get a "lo";
    let b_hi <i64> get b "hi";
    let b_lo <i64> get b "lo";
    let lo <i64> sub a_lo b_lo;
    let borrow <i64> if lt_u a_lo b_lo:
        then extend_s_i32_to_i64 1
        else extend_s_i32_to_i64 0;
    let hi0 <i64> sub a_hi b_hi;
    let hi <i64> sub hi0 borrow;
    u128 hi lo

//: lt: u128 の大小比較（a < b）
fn lt <(u128,u128)->bool> (a, b):
    let a_hi <i64> get a "hi";
    let b_hi <i64> get b "hi";
    let a_lo <i64> get a "lo";
    let b_lo <i64> get b "lo";
    if lt_u a_hi b_hi:
        true
    else:
        if gt_u a_hi b_hi:
            false
        else:
            lt_u a_lo b_lo

//: i128: i128 相当（上位/下位 64-bit, 2 の補数）
struct i128:
    hi <i64>
    lo <i64>

//: new: hi/lo から i128 値を構築する
fn new <(i64,i64)->i128> (hi, lo):
    i128 hi lo

//: to_i128: i64 値を符号拡張して i128 に変換する
fn to_i128 <(i64)->i128> (v):
    let hi <i64> if lt v extend_s_i32_to_i64 0:
        then extend_s_i32_to_i64 -1
        else extend_s_i32_to_i64 0;
    i128 hi v

//: add: i128 の加算（mod 2^128）
fn add <(i128,i128)->i128> (a, b):
    let a_hi <i64> get a "hi";
    let a_lo <i64> get a "lo";
    let b_hi <i64> get b "hi";
    let b_lo <i64> get b "lo";
    let lo <i64> add a_lo b_lo;
    let carry <i64> if lt_u lo a_lo:
        then extend_s_i32_to_i64 1
        else extend_s_i32_to_i64 0;
    let hi0 <i64> add a_hi b_hi;
    let hi <i64> add hi0 carry;
    i128 hi lo

//: sub: i128 の減算（mod 2^128）
fn sub <(i128,i128)->i128> (a, b):
    let a_hi <i64> get a "hi";
    let a_lo <i64> get a "lo";
    let b_hi <i64> get b "hi";
    let b_lo <i64> get b "lo";
    let lo <i64> sub a_lo b_lo;
    let borrow <i64> if lt_u a_lo b_lo:
        then extend_s_i32_to_i64 1
        else extend_s_i32_to_i64 0;
    let hi0 <i64> sub a_hi b_hi;
    let hi <i64> sub hi0 borrow;
    i128 hi lo

//: mul_wide: u64 × u64 の 128-bit 積を返す
//:
//: [目的/もくてき]:
//: - 64-bit 乗算の上位 64-bit と下位 64-bit を同時に求めます。
//:
//: [実装/じっそう]:
//: - 入力を 32-bit 上位/下位に分割し、部分積を合成します。
//: - 途中の加算では `lt_u` でキャリーを検出します。
//:
//: [注意/ちゅうい]:
//: - 符号なし演算として扱います。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn mul_wide <(i64,i64)->u128> (a, b):
    let mask32 <i64> extend_s_i32_to_i64 -1;
    let sh32 <i64> extend_s_i32_to_i64 32;

    let a0 <i64> and a mask32;
    let a1 <i64> shr_u a sh32;
    let b0 <i64> and b mask32;
    let b1 <i64> shr_u b sh32;

    let p0 <i64> mul a0 b0;
    let p1 <i64> mul a0 b1;
    let p2 <i64> mul a1 b0;
    let p3 <i64> mul a1 b1;

    let mid <i64> add p1 p2;
    let carry_mid <i64> if lt_u mid p1:
        then extend_s_i32_to_i64 1
        else extend_s_i32_to_i64 0;

    let lo_add <i64> shl mid sh32;
    let lo <i64> add p0 lo_add;
    let carry_lo <i64> if lt_u lo p0:
        then extend_s_i32_to_i64 1
        else extend_s_i32_to_i64 0;

    let mid_hi <i64> shr_u mid sh32;
    let hi0 <i64> add p3 mid_hi;
    let carry_hi <i64> shl carry_mid sh32;
    let hi1 <i64> add hi0 carry_hi;
    let hi <i64> add hi1 carry_lo;
    u128 hi lo

//: mul: i128 の乗算（mod 2^128）
//:
//: [目的/もくてき]:
//: - i128 同士の積の下位 128-bit を返します。
//:
//: [実装/じっそう]:
//: - `a = a_hi*2^64 + a_lo`, `b = b_hi*2^64 + b_lo` とみなし、
//:   `a_lo*b_lo` の 128-bit 積と交差項 `a_hi*b_lo`, `a_lo*b_hi` を合成します。
//:
//: [注意/ちゅうい]:
//: - 2 の補数表現の mod 2^128 乗算です（オーバーフローはラップ）。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn mul <(i128,i128)->i128> (a, b):
    let a_hi <i64> get a "hi";
    let a_lo <i64> get a "lo";
    let b_hi <i64> get b "hi";
    let b_lo <i64> get b "lo";

    let lo_wide <u128> mul_wide a_lo b_lo;
    let lo <i64> get lo_wide "lo";
    let lo_hi <i64> get lo_wide "hi";

    let cross1 <i64> mul a_hi b_lo;
    let cross2 <i64> mul a_lo b_hi;
    let cross <i64> add cross1 cross2;
    let hi <i64> add lo_hi cross;
    i128 hi lo

//: lt: i128 の大小比較（a < b）
fn lt <(i128,i128)->bool> (a, b):
    let a_hi <i64> get a "hi";
    let b_hi <i64> get b "hi";
    let a_lo <i64> get a "lo";
    let b_lo <i64> get b "lo";
    if lt a_hi b_hi:
        true
    else:
        if gt a_hi b_hi:
            false
        else:
            lt_u a_lo b_lo

