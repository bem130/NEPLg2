//: u8_add: u8 の加算（mod 2^8）
//:
//: [目的/もくてき]:
//: - u8 と u8 を加算します。
//:
//: [実装/じっそう]:
//: - i32 演算で加算した後、`0xff` でマスクして下位 8-bit を残します。
//:
//: [注意/ちゅうい]:
//: - オーバーフロー時は 8-bit でラップします。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn add_u8 <(u8,u8)->u8> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.add
        i32.const 255
        i32.and
    #if[target=llvm]
    #llvmir:
        define i32 @u8_add(i32 %a, i32 %b) {
        entry:
            %sum = add i32 %a, %b
            %0 = and i32 %sum, 255
            ret i32 %0
        }

//: u8_sub: u8 の減算（mod 2^8）
//:
//: [目的/もくてき]:
//: - u8 から u8 を減算します。
//:
//: [実装/じっそう]:
//: - i32 演算で減算した後、`0xff` でマスクして下位 8-bit を残します。
//:
//: [注意/ちゅうい]:
//: - 負の結果は 8-bit でラップします。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn sub_u8 <(u8,u8)->u8> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.sub
        i32.const 255
        i32.and
    #if[target=llvm]
    #llvmir:
        define i32 @u8_sub(i32 %a, i32 %b) {
        entry:
            %dif = sub i32 %a, %b
            %0 = and i32 %dif, 255
            ret i32 %0
        }

//: u8_mul: u8 の乗算（mod 2^8）
//:
//: [目的/もくてき]:
//: - u8 と u8 の積を計算します。
//:
//: [実装/じっそう]:
//: - i32 演算で乗算した後、`0xff` でマスクして下位 8-bit を残します。
//:
//: [注意/ちゅうい]:
//: - 大きな積は 8-bit でラップします。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn mul_u8 <(u8,u8)->u8> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.mul
        i32.const 255
        i32.and
    #if[target=llvm]
    #llvmir:
        define i32 @u8_mul(i32 %a, i32 %b) {
        entry:
            %prd = mul i32 %a, %b
            %0 = and i32 %prd, 255
            ret i32 %0
        }

//: u8_div_u: u8 の符号なし除算
//:
//: [目的/もくてき]:
//: - u8 を符号なし整数として除算します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.div_u`、llvm は `udiv i32` を使います。
//:
//: [注意/ちゅうい]:
//: - 0 除算は trap になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn div_u_u8 <(u8,u8)->u8> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.div_u
    #if[target=llvm]
    #llvmir:
        define i32 @u8_div_u(i32 %a, i32 %b) {
        entry:
            %0 = udiv i32 %a, %b
            ret i32 %0
        }

//: u8_rem_u: u8 の符号なし剰余
//:
//: [目的/もくてき]:
//: - u8 を符号なし整数として剰余を計算します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.rem_u`、llvm は `urem i32` を使います。
//:
//: [注意/ちゅうい]:
//: - 0 除算は trap になります。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn rem_u_u8 <(u8,u8)->u8> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.rem_u
    #if[target=llvm]
    #llvmir:
        define i32 @u8_rem_u(i32 %a, i32 %b) {
        entry:
            %0 = urem i32 %a, %b
            ret i32 %0
        }

//: u8_eq: u8 の等値比較
//:
//: [目的/もくてき]:
//: - u8 の `a == b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.eq`、llvm は `icmp eq` を使います。
//:
//: [注意/ちゅうい]:
//: - 結果は bool（0/1）です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn eq_u8 <(u8,u8)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.eq
    #if[target=llvm]
    #llvmir:
        define i32 @u8_eq(i32 %a, i32 %b) {
        entry:
            %cmp = icmp eq i32 %a, %b
            %0 = zext i1 %cmp to i32
            ret i32 %0
        }

//: u8_ne: u8 の非等値比較
//:
//: [目的/もくてき]:
//: - u8 の `a != b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.ne`、llvm は `icmp ne` を使います。
//:
//: [注意/ちゅうい]:
//: - 結果は bool（0/1）です。
//:
//: [計算量/けいさんりょう]:
//: - O(1)
fn ne_u8 <(u8,u8)->bool> (a,b):
    #if[target=wasm]
    #wasm:
        local.get $a
        local.get $b
        i32.ne
    #if[target=llvm]
    #llvmir:
        define i32 @u8_ne(i32 %a, i32 %b) {
        entry:
            %cmp = icmp ne i32 %a, %b
            %0 = zext i1 %cmp to i32
            ret i32 %0
        }

//: u8_lt_u: u8 の符号なし小なり比較
//:
//: [目的/もくてき]:
//: - u8 を符号なし整数として `a < b` を判定します。
//:
//: [実装/じっそう]:
//: - wasm は `i32.lt_u`、llvm は `icmp ult` を使います。
//:
//: [注意/ちゅうい]:
//: - 結果は bool（0/1）です。
//:
//: [計算量/けいさんりょう]:
