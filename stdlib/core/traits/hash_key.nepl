//: # hash_key
//: hash collection が key に[要求/ようきゅう]する[能力/のうりょく]
//:
//: ### [目的/もくてき]
//: - `HashMap` / `HashSet` が key [比較/ひかく]と default hash [計算/けいさん]を 1 [個/こ]の capability として[受/う]け[取/と]れるようにします。
//: - collection は custom hasher を[受/う]け[取/と]れますが、key [側/がわ]にも canonical な hash [実装/じっそう]を[持/も]たせておき、default hasher や[単体/たんたい] helper の[基準/きじゅん]にします。
//:
//: ### [実装/じっそう]
//: - trait `HashKey` は `clone` / `eq` / `hash32` を[要求/ようきゅう]します。
//: - helper `hashkey_clone` / `hashkey_eq` / `hashkey_hash32` が trait call を[集約/しゅうやく]します。
//:
//: ### [注意/ちゅうい]
//: - `eq` と `hash32` は[整合/せいごう]している[必要/ひつよう]があります。
//: - custom key は `HashKey` を impl し、さらに custom hasher を[使/つか]いたい[場合/ばあい]は hasher trait も[実装/じっそう]します。

#indent 4

#import "core/math" as *
#import "core/cast" as *
#import "alloc/hash/hash32" as *
#import "alloc/hash/fnv1a32" as *
#import "alloc/string" as *

fn hashkey_bytes_loop <(str,i32,i32,Fnv1a32)->Fnv1a32> (s, n, idx, h):
    if:
        ge idx n
        then h
        else:
            let s_data <i32> add s 4
            let p <i32> add s_data idx
            let b <i32> load_u8 p
            hashkey_bytes_loop s n add idx 1 fnv1a32_update h b

//: ## HashKey
//: hash collection が key に[要求/ようきゅう]する[単一/たんいつ] capability
trait HashKey:
    #capability clone
    #capability copy
    fn clone <(Self)->Self> (self):
        self

    fn eq <(Self,Self)->bool> (a, b):
        false

    fn hash32 <(Self)->i32> (self):
        0

//: ## hashkey_clone
//: `HashKey` trait [経由/けいゆ]で key を[複製/ふくせい]する
fn hashkey_clone <.T: HashKey> <(.T)->.T> (x):
    HashKey::clone x

//: ## hashkey_eq
//: `HashKey` trait [経由/けいゆ]で key [比較/ひかく]する
fn hashkey_eq <.T: HashKey> <(.T,.T)->bool> (a, b):
    HashKey::eq a b

//: ## hashkey_hash32
//: `HashKey` trait [経由/けいゆ]で 32-bit hash を[得/え]る
fn hashkey_hash32 <.T: HashKey> <(.T)->i32> (x):
    HashKey::hash32 x

impl HashKey for bool:
    fn clone <(bool)->bool> (self):
        self

    fn eq <(bool,bool)->bool> (a, b):
        if a then b else not b

    fn hash32 <(bool)->i32> (self):
        let k <i32> cast self;
        mix xor k -1640531527

impl HashKey for i32:
    fn clone <(i32)->i32> (self):
        self

    fn eq <(i32,i32)->bool> (a, b):
        eq a b

    fn hash32 <(i32)->i32> (self):
        mix xor self -1640531527

impl HashKey for u8:
    fn clone <(u8)->u8> (self):
        self

    fn eq <(u8,u8)->bool> (a, b):
        eq a b

    fn hash32 <(u8)->i32> (self):
        let k <i32> cast self;
        mix xor k -1640531527

impl HashKey for i64:
    fn clone <(i64)->i64> (self):
        self

    fn eq <(i64,i64)->bool> (a, b):
        eq a b

    fn hash32 <(i64)->i32> (self):
        let lo <i32> cast self;
        let hi64 <i64> shr_u self <i64> cast 32;
        let hi <i32> cast hi64;
        let folded <i32> xor lo hi;
        mix xor folded -1640531527

impl HashKey for str:
    fn clone <(str)->str> (self):
        self

    fn eq <(str,str)->bool> (a, b):
        str_eq a b

    fn hash32 <(str)->i32> (self):
        let n <i32> len self;
        let h0 <Fnv1a32> new_fnv1a32;
        let h1 <Fnv1a32> hashkey_bytes_loop self n 0 h0;
        mix fnv1a32_finalize h1
