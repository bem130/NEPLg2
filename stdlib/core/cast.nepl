#indent 4

#import "core/mem" as *
#import "core/math" as *
#import "core/result" as *

// cast: 型変換ユーティリティ
//
// 目的:
// - 数値/ビット/ポインタの変換を提供します。
//
// 実装(アルゴリズム):
// - 多くは intrinsic に委譲します。
//
// 注意(重要):
// - bitcast は数値変換ではなくビット列の再解釈です。
// - ポインタの再解釈は型安全化方針に反するため、このモジュールでは公開しません。
//
// 計算量:
// - すべて O(1)

// cast: i32 -> f32 変換のエイリアス
//: cast: 主な用途
//:
//: [目的/もくてき]:
//: - cast の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn cast <(i32)->f32> (v):
    #intrinsic "i32_to_f32" <> (v)

// cast: f32 -> i32 変換のエイリアス
//: cast: 主な用途
//:
//: [目的/もくてき]:
//: - cast の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn cast <(f32)->i32> (v):
    #intrinsic "f32_to_i32" <> (v)

// cast: bool -> i32 変換のエイリアス
//: cast: 主な用途
//:
//: [目的/もくてき]:
//: - cast の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn cast <(bool)->i32> (v):
    if:
        v
        then:
            1
        else:
            0

// cast_bool_from_i32: i32 -> bool 変換
//
// 目的:
// - 0 以外を true として返します。
//
// 実装(アルゴリズム):
// - ne v 0 を返します。
//
// 注意(重要):
// - 0/1 以外も true 扱いになります。
//
// 計算量:
// - O(1)
//: cast_bool_from_i32: 主な用途
//:
//: [目的/もくてき]:
//: - cast_bool_from_i32 の主な用途と呼び出し方を示します。
//:
//: [実装/じっそう]:
//: - 定義済み処理をそのまま呼び出す薄いラッパで構成されています。
//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn cast <(i32)->bool> (v):
    ne v 0

// cast: i32 -> u8 変換のエイリアス
//: cast: 主な用途
//:
//: [目的/もくてき]:
