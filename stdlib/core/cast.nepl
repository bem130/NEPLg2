//:
//: [注意/ちゅうい]:
//: - 引数の値は関数呼び出しで移動するため、再利用時は束縛し直してください。
//:
//: [計算量/けいさんりょう]:
//: - 本体処理に準じます。
fn bitcast_f32_to_i32 <(f32)->i32> (v):
    #intrinsic "reinterpret_f32_i32" <> (v)

//: cast: i32 を i64 に変換する
fn cast <(i32)->i64> (v):
    extend_s v

//: cast: i64 を i32 に変換する
fn cast <(i64)->i32> (v):
    wrap v

//: cast: i32 を f64 に変換する
fn cast <(i32)->f64> (v):
    convert_s v

//: cast: f64 を i32 に変換する
fn cast <(f64)->i32> (v):
    trunc_s v

//: cast: i64 を f64 に変換する
fn cast <(i64)->f64> (v):
    convert_s v

//: cast: f64 を i64 に変換する
fn cast <(f64)->i64> (v):
    trunc_s v

//: cast: i64 を f32 に変換する
fn cast <(i64)->f32> (v):
    convert_s v

//: cast: f32 を i64 に変換する
fn cast <(f32)->i64> (v):
    trunc_s v

//: cast: f32 を f64 に昇格する
fn cast <(f32)->f64> (v):
    promote v

//: cast: f64 を f32 に縮小する
fn cast <(f64)->f32> (v):
    demote v

//: cast: i64 を i128 に変換する
fn cast <(i64)->i128> (v):
    to_i128 v

//: cast: i128 を i64 に変換する
fn cast <(i128)->i64> (v):
    get v "lo"

//: cast: i32 を i128 に変換する
fn cast <(i32)->i128> (v):
    to_i128 extend_s v

//: cast: i128 を i32 に変換する
fn cast <(i128)->i32> (v):
    wrap get v "lo"
