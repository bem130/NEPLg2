#indent 4

//: # result
//: [成功/せいこう](Ok) と [失敗/しっぱい](Err) を[表/あらわ]す[基本型/きほんがた]と helper
//:
//: ### [目的/もくてき]
//: - [処理/しょり]の[成功/せいこう] / [失敗/しっぱい]を[値/あたい]として[明示的/めいじてき]に[扱/あつか]うための `Result` と[基本操作/きほんそうさ]を[提供/ていきょう]します。
//: - reboot [後/ご]の stdlib で「[安全/あんぜん] API は `Result` / `Outcome` を[返/かえ]す」という[方針/ほうしん]を[支/ささ]える[最小基盤/さいしょうきばん]です。
//:
//: ### [注意/ちゅうい]
//: - `unwrap_ok` / `unwrap_err` は[便宜上/べんぎじょう][残/のこ]している unsafe helper であり、[通常/つうじょう]は `match` や `unwrap_or` を[優先/ゆうせん]してください。
//: - doctest では trap [依存/いぞん]の `should_panic` を[使/つか]わず、[安全/あんぜん]な[分岐/ぶんき]と `ret:` [比較/ひかく]で[確認/かくにん]します。
//:
//: ### [計算量/けいさんりょう]
//: - [基本操作/きほんそうさ]はすべて O(1) です。
//:
//: neplg2:test
//: ret: 0
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/test" as *
//:| #import "core/result" as *
//: fn main <()*>i32> ():
//:     let checks <Vec<Result<(),str>>>:
//:         checks_new
//:         |> checks_push assert is_ok ok<i32, str> 1
//:         |> checks_push assert is_err err<i32, str> "oops"
//:         |> checks_push assert_eq_i32 1 unwrap_ok ok<i32, str> 1
//:         |> checks_push assert_str_eq "oops" unwrap_err err<i32, str> "oops"
//:         |> checks_push assert_eq_i32 9 unwrap_or err<i32, str> "x" 9
//:     checks_exit_code checks
//: ```
//:
//: neplg2:test[compile_fail]
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "core/result" as *
//: // 型が合わない Err を入れているのでコンパイルエラーを期待
//: fn main <()*>()> ():
//:     let r <i32> "text";
//:     r
//: ```
//:
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/test" as *
//:| #import "core/result" as *
//:| #import "core/math" as *
//: fn inc <(i32)->i32> (x):
//:     add x 1
//:
//: fn strlen <(str)->i32> (s):
//:     4
//:
//: fn main <()*>i32> ():
//:     let r0 ok<i32,str> 9;
//:     let r1 err<i32,str> "oops";
//:     let a map<i32,i32,str> r0 inc;
//:     let b map_err<i32,str,i32> r1 strlen;
//:     let checks <Vec<Result<(),str>>>:
//:         checks_new
//:         |> checks_push assert_eq_i32 10 unwrap_ok a
//:         |> checks_push assert_eq_i32 4 unwrap_err b
//:     checks_exit_code checks
//: ```
//:
//: neplg2:test
//: ret: 0
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/test" as *
//:| #import "core/result" as *
//:| #import "core/math" as *
//: fn positive_double <(i32)->Result<i32,str>> (x):
//:     if gt x 0:
//:         then ok<i32,str> mul x 2
//:         else err<i32,str> "non-positive"
//:
//: fn main <()*>i32> ():
//:     let r0 ok<i32,str> 3;
//:     let r1 ok<i32,str> -1;
//:     let a and_then<i32,i32,str> r0 positive_double;
//:     let b and_then<i32,i32,str> r1 positive_double;
//:     let checks <Vec<Result<(),str>>>:
//:         checks_new
//:         |> checks_push assert_eq_i32 6 unwrap_ok a
//:         |> checks_push assert_str_eq "non-positive" unwrap_err b
//:     checks_exit_code checks
//: ```


//: StdErrorKind: stdlib [全体/ぜんたい]で[共有/きょうゆう]する[軽量/けいりょう]な[失敗/しっぱい][分類/ぶんるい]
//:
//: 目的:
//: - `Result<T, E>` の `E` として[使/つか]う[標準/ひょうじゅん] error kind を[定義/ていぎ]します。
//: - richer な `Diag` とは[分離/ぶんり]し、`core` / `alloc` / `std` が[循環/じゅんかん]せずに[共有/きょうゆう]できるようにします。
//:
//: 注意(重要):
//: - [詳細/しょうさい]な[背景/はいけい]や[位置/いち]は `alloc/diag/error` の `Diag` [側/がわ]で[補/おぎな]います。
//: - reboot [方針/ほうしん]では、[通常/つうじょう]の stdlib API は `Result<T, StdErrorKind>` を[基本/きほん]にします。
//:
//: 計算量:
//: - O(1)
enum StdErrorKind:
    Failure
    OutOfMemory
    EmptyCollection
    IndexOutOfBounds
    KeyNotFound
    CapacityExceeded
    InvalidOperation
    InvalidUtf8
    ParseError
    IoError
    Other

//: Result: 成功(Ok)か失敗(Err)を表す
//:
//: 目的:
//: - 成功値 .T と失敗値 .E を区別して保持します。
//:
//: 実装(アルゴリズム):
//: - enum の 2 変種で表現します。
//:
//: 注意(重要):
//: - Ok/Err は payload を保持します。
//:
//: 計算量:
//: - O(1)
enum Result<.T, .E>:
    Ok <.T>
    Err <.E>

//: ok: 成功値を包む
//:
//: 目的:
//: - v を Ok として返します。
//:
//: 実装(アルゴリズム):
//: - Result::Ok を構築します。
//:
//: 注意(重要):
//: - .E は文脈で決まります。
//:
//: 計算量:
//: - O(1)
fn ok <.T, .E> <(.T)->Result<.T, .E>> (v):
    Result<.T, .E>::Ok v

//: err: 失敗値を包む
//:
//: 目的:
//: - e を Err として返します。
//:
//: 実装(アルゴリズム):
//: - Result::Err を構築します。
//:
//: 注意(重要):
//: - .T は文脈で決まります。
//:
//: 計算量:
//: - O(1)
fn err <.T, .E> <(.E)->Result<.T, .E>> (e):
    Result<.T, .E>::Err e

//: is_ok: 成功か判定する
//:
//: 目的:
//: - Ok なら true、Err なら false を返します。
//:
//: 実装(アルゴリズム):
//: - match で Ok/Err を分岐します。
//:
//: 注意(重要):
//: - 値そのものは取り出しません。
//:
//: 計算量:
//: - O(1)
fn is_ok <.T, .E> <(Result<.T, .E>)->bool> (r):
    match r:
        Result::Ok v:
            true
        Result::Err e:
            false

//: is_err: 失敗か判定する
//:
//: 目的:
//: - Err なら true、Ok なら false を返します。
//:
//: 実装(アルゴリズム):
//: - match で Ok/Err を分岐します。
//:
//: 注意(重要):
//: - is_ok の否定です。
//:
//: 計算量:
//: - O(1)
fn is_err <.T, .E> <(Result<.T, .E>)->bool> (r):
    match r:
        Result::Ok v:
            false
        Result::Err e:
            true

//: unwrap_ok: Ok の中身を取り出す（Err は到達不能）
//:
//: 目的:
//: - Ok(v) なら v を返します。
//:
//: 実装(アルゴリズム):
//: - match で分岐し、Err は unreachable を呼びます。
//:
//: 注意(重要):
//: - Err の可能性がある場合は is_ok や unwrap_or を使ってください。
//:
//: 計算量:
//: - O(1)
fn unwrap_ok <.T, .E> <(Result<.T, .E>)->.T> (r):
    match r:
        Result::Ok v:
            v
        Result::Err e:
            #intrinsic "unreachable" <> ()

//: ## uwok
//: `unwrap_ok` の[短縮名/たんしゅくめい]
//:
//: ### [目的/もくてき]
//: - pipe [記法/きほう]で `Result` を[連続/れんぞく]して[処理/しょり]するときに、`unwrap_ok` より[短/みじか]く[書/か]けるようにします。
//:
//: ### [使用例/しようれい]
//: neplg2:test
//: ```neplg2
//:| #entry main
//:| #target std
//:| #import "std/test" as *
//:| #import "core/result" as *
//:| fn main <()*>i32> ():
//:     assert_eq_i32 1 uwok ok<i32, str> 1;
//:     0
//: ```
//:
//: ### [実装/じっそう]
//: - `unwrap_ok` への[別名/べつめい]です。
//:
//: ### [注意/ちゅうい]
//: - [左側/ひだりがわ]の `Result<T, E>` から `T` が[推論/すいろん]できる[場面/ばめん]では、ふつうは[型注釈/かたちゅうしゃく]は[不要/ふよう]です。
//:
//: ### [計算量/けいさんりょう]
//: - `unwrap_ok` と[同/おな]じです。
fn uwok unwrap_ok;

//: unwrap_err: Err の中身を取り出す（Ok は到達不能）
//:
//: 目的:
//: - Err(e) なら e を返します。
//:
//: 実装(アルゴリズム):
//: - match で分岐し、Ok は unreachable を呼びます。
//:
//: 注意(重要):
//: - Ok の可能性がある場合は is_err や map_err を使ってください。
//:
//: 計算量:
//: - O(1)
fn unwrap_err <.T, .E> <(Result<.T, .E>)->.E> (r):
    match r:
        Result::Err e:
            e
        Result::Ok v:
            #intrinsic "unreachable" <> ()

//: ## uwerr
//: `unwrap_err` の[短縮名/たんしゅくめい]
//:
//: ### [目的/もくてき]
//: - `Result::Err` の[中身/なかみ]を pipe [記法/きほう]でも[短/みじか]く[取/と]り[出/だ]せるようにします。
//:
//: ### [実装/じっそう]
//: - `unwrap_err` への[別名/べつめい]です。
//:
//: ### [注意/ちゅうい]
//: - `Result::Ok` を[渡/わた]すと `unwrap_err` と[同/おな]じく[到達不能/とうたつふのう]になります。
//:
//: ### [計算量/けいさんりょう]
//: - `unwrap_err` と[同/おな]じです。
fn uwerr unwrap_err;

//: unwrap_or: 失敗時のデフォルトを返す
//:
//: 目的:
//: - Ok(v) なら v、Err なら default を返します。
//:
//: 実装(アルゴリズム):
//: - match で分岐します。
//:
//: 注意(重要):
//: - default は eager に評価されます。
//:
//: 計算量:
//: - O(1)
fn unwrap_or <.T, .E> <(Result<.T, .E>, .T)->.T> (r, default):
    match r:
        Result::Ok v:
            v
        Result::Err e:
            default

//: std_error_kind_str: `StdErrorKind` を[文字列/もじれつ]へ[変換/へんかん]する
//:
//: 目的:
//: - [軽量/けいりょう] error kind を test / doc / `Diag` [表示/ひょうじ]で[比較/ひかく]しやすい[短/みじか]い[名前/なまえ]へ[変換/へんかん]します。
//:
//: 注意(重要):
//: - [返/かえ]す[文字列/もじれつ]は stable な[識別子/しきべつし]であり、[人間/にんげん]向け[本文/ほんぶん]ではありません。
//:
//: 計算量:
//: - O(1)
fn std_error_kind_str <(StdErrorKind)->str> (kind):
    match kind:
        StdErrorKind::Failure:
            "Failure"
        StdErrorKind::OutOfMemory:
            "OutOfMemory"
        StdErrorKind::EmptyCollection:
            "EmptyCollection"
        StdErrorKind::IndexOutOfBounds:
            "IndexOutOfBounds"
        StdErrorKind::KeyNotFound:
            "KeyNotFound"
        StdErrorKind::CapacityExceeded:
            "CapacityExceeded"
        StdErrorKind::InvalidOperation:
            "InvalidOperation"
        StdErrorKind::InvalidUtf8:
            "InvalidUtf8"
        StdErrorKind::ParseError:
            "ParseError"
        StdErrorKind::IoError:
            "IoError"
        StdErrorKind::Other:
            "Other"

//: map: Ok の値に関数を適用する
//:
//: 目的:
//: - Ok(v) なら f(v) を Ok で返し、Err はそのまま返します。
//:
//: 実装(アルゴリズム):
//: - match で Ok/Err を分岐し、Ok のときのみ f を適用します。
//:
//: 注意(重要):
//: - f は純粋関数を想定します。
//:
//: 計算量:
//: - O(1)
fn map <.T, .U, .E> <(Result<.T, .E>, (.T)->.U)->Result<.U, .E>> (r, f):
    match r:
        Result::Ok v:
            ok<.U, .E> (f v)
        Result::Err e:
            err<.U, .E> e

//: map_err: Err の値に関数を適用する
//:
//: 目的:
//: - Err(e) なら f(e) を Err で返し、Ok はそのまま返します。
//:
//: 実装(アルゴリズム):
//: - match で Ok/Err を分岐し、Err のときのみ f を適用します。
//:
//: 注意(重要):
//: - f は純粋関数を想定します。
//:
//: 計算量:
//: - O(1)
fn map_err <.T, .E, .F> <(Result<.T, .E>, (.E)->.F)->Result<.T, .F>> (r, f):
    match r:
        Result::Ok v:
            ok<.T, .F> v
        Result::Err e:
            err<.T, .F> (f e)

//: and_then: Ok の値を次の Result 計算へつなぐ
//:
//: 目的:
//: - Ok(v) なら f(v) をそのまま返し、Err はそのまま返します。
//:
//: 実装(アルゴリズム):
//: - match で Ok/Err を分岐し、Ok のときのみ Result を返す関数を呼びます。
//:
//: 注意(重要):
//: - `map` が `a -> b` を受けるのに対し、`and_then` は `a -> Result<b,e>` を受けます。
//:
//: 計算量:
//: - O(1)
fn and_then <.T, .U, .E> <(Result<.T, .E>, (.T)->Result<.U, .E>)->Result<.U, .E>> (r, f):
    match r:
        Result::Ok v:
            f v
        Result::Err e:
            err<.U, .E> e
